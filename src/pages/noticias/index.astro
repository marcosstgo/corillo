---
import BaseLayout from '../../layouts/BaseLayout.astro';

const footerLinks = [
  { href: '/roadmap/', label: 'Roadmap' },
  { href: '/que-es-corillo/', label: 'Sobre Corillo' },
  { href: '/corillo-css/', label: 'Corillo CSS' },
  { href: '/faq/', label: 'FAQ' },
];
---
<BaseLayout
  title="CORILLO — Noticias"
  description="Novedades de CORILLO: updates de plataforma, software, comunidad e infraestructura."
  canonical="https://corillo.live/noticias/"
  footerLinks={footerLinks}
  footerInfo="Noticias del proyecto<br>Puerto Rico"
>
  <fragment slot="head">
    <style is:global>
      .news-shell{max-width:1140px;margin:0 auto;padding:0 20px 80px}
      @media(max-width:600px){.news-shell{padding:0 14px 56px}}
      .news-hero{padding:34px 0 22px}
      .news-hero-grid{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(300px,.8fr);gap:18px;align-items:stretch}
      @media(max-width:980px){.news-hero-grid{grid-template-columns:1fr}}
      .news-kicker{display:flex;align-items:center;gap:10px;justify-content:center;flex-wrap:wrap;margin:0 0 14px}
      .news-dot{width:8px;height:8px;border-radius:999px;background:#00ff9d;box-shadow:0 0 0 6px rgba(0,255,157,.1)}
      .news-intro{max-width:760px;margin:0 auto 26px;text-align:center}
      .news-feature{padding:28px;border-radius:28px}
      .news-feature-top{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:18px}
      .news-date{font-family:var(--crl-mono);font-size:10px;letter-spacing:1.7px;text-transform:uppercase;color:var(--crl-muted)}
      .news-feature-title{font-family:var(--crl-display);font-size:clamp(2.5rem,5vw,4.7rem);line-height:.92;letter-spacing:2px;margin:0 0 14px;max-width:12ch}
      .news-feature-copy{max-width:62ch;font-size:1rem;line-height:1.72;color:rgba(255,255,255,.76);margin:0 0 22px}
      .news-feature-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
      .news-feature-note{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.64);font-size:var(--crl-sm)}
      .news-pulse{padding:22px 20px;border-radius:26px;border:1px solid var(--crl-border);background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01));display:flex;flex-direction:column;gap:18px}
      .news-pulse-head{display:flex;align-items:center;justify-content:space-between;gap:12px}
      .news-pulse-title{margin:0;font-family:var(--crl-display);font-size:1.6rem;letter-spacing:1.4px}
      .news-pulse-sub{margin:0;color:var(--crl-muted);font-size:var(--crl-sm);line-height:1.6}
      .news-pulse-list{display:grid;gap:12px}
      .news-pulse-item{padding:14px 14px 14px 16px;border-radius:18px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06)}
      .news-pulse-item strong{display:block;font-size:var(--crl-sm);margin-bottom:4px}
      .news-pulse-item span{display:block;font-size:var(--crl-xs);line-height:1.6;color:var(--crl-muted)}
      .news-pulse-tags{display:flex;gap:8px;flex-wrap:wrap}
      .news-rule{margin:0 0 28px}
      .news-section-head{display:flex;align-items:end;justify-content:space-between;gap:16px;flex-wrap:wrap;margin:0 0 18px}
      .news-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
      @media(max-width:980px){.news-grid{grid-template-columns:1fr 1fr}}
      @media(max-width:640px){.news-grid{grid-template-columns:1fr}}
      .news-card{display:flex;flex-direction:column;gap:16px;height:100%;padding:22px;border-radius:24px;position:relative;overflow:hidden}
      .news-card::before{content:"";position:absolute;inset:0 0 auto 0;height:2px;background:linear-gradient(90deg, #00bfff, transparent 80%);opacity:.72}
      .news-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
      .news-title{font-family:var(--crl-display);font-size:1.8rem;letter-spacing:1.5px;line-height:.98;margin:0}
      .news-desc{font-size:var(--crl-sm);color:rgba(255,255,255,.66);line-height:1.72;margin:0}
      .news-actions{margin-top:auto;display:flex;align-items:center;gap:10px;justify-content:space-between;flex-wrap:wrap}
      .news-arrow{display:inline-flex;align-items:center;gap:8px;font-size:var(--crl-xs);letter-spacing:1.5px;text-transform:uppercase;color:var(--crl-muted)}
      [data-theme="light"] .news-feature-copy,[data-theme="light"] .news-feature-note{color:rgba(0,0,0,.62)}
      [data-theme="light"] .news-pulse{background:linear-gradient(180deg, rgba(255,255,255,.98), rgba(244,248,250,.96))}
      [data-theme="light"] .news-pulse-item{background:rgba(0,0,0,.025);border-color:rgba(7,17,24,.08)}
      [data-theme="light"] .news-desc{color:rgba(0,0,0,.58)}
      [data-theme="light"] .news-title{color:rgba(0,0,0,.88)}
      [data-theme="light"] .news-feature-title{color:rgba(0,0,0,.88)}
      [data-theme="light"] .news-pulse-title{color:rgba(0,0,0,.88)}
      [data-theme="light"] .news-arrow{color:rgba(0,0,0,.4)}
    </style>
  </fragment>

<div class="crl-hero news-hero">
  <div class="news-kicker">
    <span class="news-dot"></span>
    <p class="crl-hero-eyebrow" style="margin:0">Plataforma · Software · Comunidad</p>
  </div>
  <h1 class="crl-hero-title">NOTICIAS</h1>
  <p class="crl-hero-sub news-intro">Updates de plataforma, software nuevo, cambios en el site y anuncios del proyecto.</p>
</div>
<hr class="crl-divider-fade news-rule">

<div class="news-shell">
  <section class="news-hero-grid">
    <article class="news-feature card-glass">
      <div class="news-feature-top">
        <span class="badge badge-accent"><i class="fa-solid fa-bolt"></i> Nuevo</span>
        <span class="news-date">30 marzo 2026</span>
      </div>
      <h2 class="news-feature-title">REELS: comparte tus mejores momentos</h2>
      <p class="news-feature-copy">Los streamers de CORILLO ya pueden crear clips 9:16 desde sus VODs directamente en el perfil. El servidor convierte el video a vertical con blur de fondo — listo para TikTok, Instagram o YouTube Shorts sin editar nada a mano.</p>
      <div class="news-feature-actions">
        <a class="btn btn-primary" href="/noticias/reels/">Leer nota destacada</a>
        <span class="news-feature-note"><i class="fa-solid fa-scissors"></i> Clips verticales, página pública y descarga directa</span>
      </div>
    </article>

    <aside class="news-pulse">
      <div class="news-pulse-head">
        <div>
          <p class="crl-section-label" style="margin:0 0 6px">Pulso del proyecto</p>
          <h2 class="news-pulse-title">Qué se está moviendo</h2>
        </div>
        <span class="badge badge-dim"><i class="fa-solid fa-wave-square"></i> Vivo</span>
      </div>
      <p class="news-pulse-sub">Las áreas que más actividad tienen en este momento.</p>
      <div class="news-pulse-list">
        <div class="news-pulse-item">
          <strong>Player y multiplayer</strong>
          <span>Siguen siendo los frentes más importantes para llevar más UI real al framework.</span>
        </div>
        <div class="news-pulse-item">
          <strong>Marca y contenido</strong>
          <span>Páginas como Sobre Corillo y Noticias dan contexto al proyecto más allá del código.</span>
        </div>
        <div class="news-pulse-item">
          <strong>SEO técnico</strong>
          <span>Ya hay sitemap, metadata y una base mejor para que Google descubra el site completo.</span>
        </div>
      </div>
      <div class="news-pulse-tags">
        <span class="badge badge-confirm"><i class="fa-solid fa-map"></i> Roadmap activo</span>
        <span class="badge badge-accent"><i class="fa-solid fa-code-branch"></i> Framework propio</span>
      </div>
    </aside>
  </section>

  <section style="margin-top:34px">
    <div class="news-section-head">
      <div>
        <p class="crl-section-label">Últimas notas</p>
        <h2 class="crl-section-title" style="margin:0">Últimas notas</h2>
      </div>
    </div>

    <div class="news-grid">
      <article class="card news-card card-accent">
        <div class="news-meta">
          <span class="badge badge-accent"><i class="fa-solid fa-film"></i> Plataforma</span>
          <span class="news-date">2 abril 2026</span>
        </div>
        <h2 class="news-title">VODs: cada transmisión queda guardada</h2>
        <p class="news-desc">No tienes que hacer nada. Desde el momento en que empiezas a transmitir en CORILLO, todo se graba automáticamente y queda disponible para verse cuando quieras.</p>
        <div class="news-actions">
          <a class="btn btn-primary" href="/noticias/vods/">Leer nota</a>
          <span class="news-arrow">Ver más <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </article>

      <article class="card news-card card-accent">
        <div class="news-meta">
          <span class="badge badge-accent"><i class="fa-solid fa-scissors"></i> Plataforma</span>
          <span class="news-date">30 marzo 2026</span>
        </div>
        <h2 class="news-title">Reels: clips 9:16 desde tus VODs</h2>
        <p class="news-desc">Ya puedes crear clips verticales desde el perfil, elegir el momento exacto y descargarlos o publicarlos en corillo.live/reels/ para que todo el mundo los vea.</p>
        <div class="news-actions">
          <a class="btn btn-primary" href="/noticias/reels/">Leer nota</a>
          <span class="news-arrow">Ver más <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </article>

      <article class="card news-card card-accent">
        <div class="news-meta">
          <span class="badge badge-accent"><i class="fa-solid fa-layer-group"></i> Framework</span>
          <span class="news-date">29 marzo 2026</span>
        </div>
        <h2 class="news-title">Corillo CSS entra en v1.4</h2>
        <p class="news-desc">El framework del proyecto sigue creciendo con componentes reales del player, nueva documentación y una base más sólida para seguir migrando páginas grandes.</p>
        <div class="news-actions">
          <a class="btn btn-primary" href="/noticias/corillo-css-v1-4/">Leer nota</a>
          <span class="news-arrow">Ver más <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </article>

      <article class="card news-card card-confirm">
        <div class="news-meta">
          <span class="badge badge-confirm"><i class="fa-solid fa-circle-info"></i> Marca</span>
          <span class="news-date">29 marzo 2026</span>
        </div>
        <h2 class="news-title">Sobre Corillo ya tiene su espacio</h2>
        <p class="news-desc">La nueva página explica qué es CORILLO, cómo funciona y para quién es, sin rodeos.</p>
        <div class="news-actions">
          <a class="btn btn-primary" href="/noticias/sobre-corillo/">Leer nota</a>
          <span class="news-arrow">Leer más <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </article>

      <article class="card news-card card-dim">
        <div class="news-meta">
          <span class="badge badge-dim"><i class="fa-solid fa-screwdriver-wrench"></i> Plataforma</span>
          <span class="news-date">29 marzo 2026</span>
        </div>
        <h2 class="news-title">Mejoras en player, theme y SEO</h2>
        <p class="news-desc">Se siguió puliendo el player, se mejoró el tema claro en varias páginas y el site quedó mejor preparado para descubrimiento en buscadores.</p>
        <div class="news-actions">
          <a class="btn btn-primary" href="/noticias/player-y-seo/">Leer nota</a>
          <span class="news-arrow">Abrir <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </article>

      <article class="card news-card card-confirm">
        <div class="news-meta">
          <span class="badge badge-confirm"><i class="fa-solid fa-gamepad"></i> Gaming</span>
          <span class="news-date">29 marzo 2026</span>
        </div>
        <h2 class="news-title">La Fiebre: Puerto Rico pone la cultura de autos boricua al frente</h2>
        <p class="news-desc">Fiebru Studios está trabajando un juego de carreras en mundo abierto inspirado en Puerto Rico, con drag racing, personalización, multiplayer y una vibra que se siente de aquí.</p>
        <div class="news-actions">
          <a class="btn btn-primary" href="/noticias/la-fiebre-puerto-rico/">Leer nota</a>
          <span class="news-arrow">Entrar <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </article>
    </div>
  </section>
</div>

</BaseLayout>
