---
import BaseLayout from '../../layouts/BaseLayout.astro';

const footerLinks = [
  { href: '/multiplayer/', label: 'Multiplayer' },
  { href: '/streamers/', label: 'Streamers' },
  { href: '/join/', label: 'Crear Canal' },
  { href: '/roadmap/', label: 'Roadmap' },
  { href: '/que-es-corillo/', label: 'Sobre Corillo' },
  { href: '/legal/', label: 'Términos' },
  { href: '/dmca/', label: 'DMCA' },
  { href: 'https://status.corillo.live', label: 'Status' },
];
---
<BaseLayout
  title="CORILLO — Streamers en Puerto Rico"
  description="Conoce a los streamers de CORILLO, una plataforma de streaming independiente creada en Puerto Rico."
  canonical="https://corillo.live/streamers/"
  navLabel="Streamers"
  footerLinks={footerLinks}
>
  <fragment slot="head">
    <meta name="theme-color" content="#060608" />
    <script src="/assets/streamers.js" is:inline></script>
    <style is:global>
      .hero{text-align:center;padding:64px 24px 40px;max-width:1400px;margin:0 auto}
      .hero-label{font-family:var(--crl-mono);font-size:.85rem;letter-spacing:.2em;color:var(--crl-accent);margin-bottom:12px}
      .hero-title{font-family:var(--crl-display);font-size:clamp(3rem,8vw,6rem);line-height:1;color:var(--crl-white);margin:0 0 16px;letter-spacing:.02em}
      .hero-sub{color:var(--crl-muted);font-size:.95rem;max-width:480px;margin:0 auto 28px}

      .live-pill{
        display:inline-flex;align-items:center;gap:7px;
        background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);
        color:#ef4444;font-family:var(--crl-mono);font-size:.85rem;
        letter-spacing:.1em;padding:6px 14px;border-radius:99px;opacity:0;
      }
      .live-pill.show{opacity:1}
      .live-pill .dot{width:7px;height:7px;border-radius:50%;background:#ef4444;animation:crl-blink 1.2s ease-in-out infinite}

      .grid-wrap{max-width:1400px;margin:0 auto;padding:0 24px 80px}

      .s-card{
        background:var(--crl-surface);border:1px solid var(--crl-border);
        border-radius:16px;overflow:hidden;
        display:flex;flex-direction:column;
        cursor:pointer;text-decoration:none;
        transition:transform .25s cubic-bezier(.34,1.56,.64,1),box-shadow .25s,border-color .25s;
        position:relative;
      }
      .s-card:hover{transform:translateY(-6px);border-color:rgba(255,255,255,.15)}
      .s-card.is-live{border-color:rgba(239,68,68,.4)}
      .s-card.is-live:hover{box-shadow:0 16px 48px rgba(239,68,68,.18)}
      .s-card:not(.is-live):hover{box-shadow:0 16px 48px rgba(0,0,0,.5)}
      .s-card.soon{opacity:.45;pointer-events:none;background:rgba(255,255,255,.02)}

      .s-card-accent{height:3px;width:100%;flex-shrink:0}

      .s-card-top{padding:24px 24px 0;display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
      .s-avatar{width:72px;height:72px;border-radius:50%;object-fit:cover;flex-shrink:0;border:3px solid rgba(255,255,255,.08)}
      .s-avatar-fallback{
        width:72px;height:72px;border-radius:50%;
        display:flex;align-items:center;justify-content:center;
        font-family:var(--crl-display);font-size:2rem;
        color:rgba(255,255,255,.9);flex-shrink:0;border:3px solid rgba(255,255,255,.08);
      }
      .s-badges{display:flex;flex-direction:column;align-items:flex-end;gap:6px}
      .s-live-badge{
        display:none;align-items:center;gap:5px;
        background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.4);
        color:#ef4444;font-family:var(--crl-mono);
        font-size:.62rem;letter-spacing:.08em;
        padding:4px 9px;border-radius:99px;
      }
      .s-live-badge .dot{width:5px;height:5px;border-radius:50%;background:#ef4444;animation:crl-blink 1.2s ease-in-out infinite}
      .is-live .s-live-badge{display:flex}
      .s-viewers{display:none;font-family:var(--crl-mono);font-size:.92rem;color:var(--crl-muted);letter-spacing:.05em}
      .is-live .s-viewers{display:block}

      .s-card-body{padding:16px 24px 20px;flex:1;display:flex;flex-direction:column;gap:8px}
      .s-name{font-family:var(--crl-display);font-size:1.7rem;letter-spacing:.04em;color:var(--crl-white);line-height:1;margin:0}
      .s-sub{font-family:var(--crl-mono);font-size:.92rem;letter-spacing:.08em;color:var(--crl-accent);margin:0}
      .s-bio{font-size:.85rem;color:var(--crl-muted);line-height:1.55;margin:4px 0 0;flex:1}
      .s-stream-title{font-family:var(--crl-mono);font-size:.75rem;color:var(--crl-accent);margin:4px 0 0}

      .s-card-footer{padding:0 24px 20px;display:flex;align-items:center;justify-content:space-between;gap:10px}
      .s-socials{display:flex;gap:8px}
      .s-social-btn{
        width:32px;height:32px;border-radius:8px;
        border:1px solid var(--crl-border);background:transparent;
        color:var(--crl-muted);font-size:.92rem;
        display:flex;align-items:center;justify-content:center;
        text-decoration:none;transition:color .2s,border-color .2s,background .2s;
      }
      .s-social-btn:hover{color:var(--crl-white);border-color:var(--crl-muted);background:rgba(255,255,255,.05)}
      .s-social-btn.twitch:hover{color:#9147ff;border-color:#9147ff}
      .s-social-btn.instagram:hover{color:#e1306c;border-color:#e1306c}
      .s-social-btn.tiktok:hover{color:#69c9d0;border-color:#69c9d0}

      .s-watch-btn{
        font-family:var(--crl-mono);font-size:.92rem;letter-spacing:.06em;
        padding:8px 16px;border-radius:8px;
        border:1px solid var(--crl-border);background:transparent;
        color:var(--crl-white);text-decoration:none;white-space:nowrap;
        transition:background .2s,border-color .2s;
      }
      .s-watch-btn:hover{background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.2)}
      .is-live .s-watch-btn{background:#ef4444;border-color:#ef4444;color:#fff}
      .is-live .s-watch-btn:hover{background:#dc2626;border-color:#dc2626}

      @media(max-width:600px){
        .hero{padding:40px 16px 28px}
        .grid-wrap{padding:0 16px 60px}
        .s-card-top{padding:16px 16px 0}
        .s-avatar,.s-avatar-fallback{width:52px;height:52px;font-size:1.5rem}
        .s-card-body{padding:12px 16px 14px}
        .s-name{font-size:1.3rem}
        .s-bio{display:none}
        .s-card-footer{padding:0 16px 14px}
        .s-socials{display:none}
      }

      /* ── LIVE SIDEBAR ── */
      .with-sidebar{display:grid;grid-template-columns:180px 1fr;align-items:start}
      .live-aside{border-right:1px solid var(--crl-border);position:sticky;top:0;height:100vh;overflow-y:auto;scrollbar-width:none;display:flex;flex-direction:column;padding:12px 0}
      .live-aside::-webkit-scrollbar{display:none}
      .cs-row{display:flex;align-items:center;gap:10px;padding:8px 16px;text-decoration:none;color:inherit;transition:background .15s}
      .cs-row:hover{background:rgba(0,191,255,.04)}
      .cs-ava{width:30px;height:30px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--crl-display);font-size:14px;color:#000}
      .cs-row.is-live .cs-ava{box-shadow:0 0 0 2px var(--crl-live),0 0 8px rgba(232,200,74,.25)}
      .cs-row:not(.is-live) .cs-ava{opacity:.28}
      .cs-info{flex:1;min-width:0}
      .cs-name{font-family:var(--crl-mono);font-size:10px;font-weight:700;letter-spacing:.5px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
      .cs-status{font-size:10px;color:var(--crl-muted);margin-top:1px}
      .cs-status.live{color:var(--crl-live)}
      .aside-mobile-icons{display:none}
      .aside-mobile-sep{display:none}
      @media(max-width:820px){
        .with-sidebar{grid-template-columns:44px 1fr}
        .live-aside{width:44px;padding:6px 0;overflow:hidden}
        .cs-row{padding:4px;justify-content:center}
        .cs-info{display:none}
        .aside-mobile-icons{display:flex;flex-direction:column;align-items:center;gap:4px;padding:6px 0}
        .aside-mobile-icon{width:34px;height:34px;display:flex;align-items:center;justify-content:center;border-radius:8px;color:rgba(255,255,255,.38);font-size:1rem;transition:.15s;text-decoration:none}
        .aside-mobile-icon:hover{color:var(--crl-white)}
        .aside-mobile-sep{display:block;border:none;border-top:1px solid var(--crl-border);margin:4px 6px}
      }
      [data-theme="light"] .aside-mobile-icon{color:rgba(5,16,21,.42)}
      [data-theme="light"] .aside-mobile-icon:hover{color:#0c1a20}
      [data-theme="light"] .aside-mobile-sep{border-color:rgba(0,0,0,.1)}
    </style>
  </fragment>

<div class="with-sidebar">
<aside class="live-aside">
  <div class="aside-mobile-icons">
    <a href="/reels/" class="aside-mobile-icon" title="Reels"><i class="fa-solid fa-scissors"></i></a>
    <a href="/vods/" class="aside-mobile-icon" title="VODs"><i class="fa-solid fa-play"></i></a>
    <a href="/noticias/" class="aside-mobile-icon" title="Noticias"><i class="fa-solid fa-newspaper"></i></a>
    <a href="/perfil/" class="aside-mobile-icon" title="Mi Perfil"><i class="fa-solid fa-user"></i></a>
  </div>
  <hr class="aside-mobile-sep">
  <div id="sidebarRows"></div>
</aside>
<div class="sidebar-content">
<main>
  <div class="hero">
    <div class="hero-label">CORILLO · PLATAFORMA INDEPENDIENTE</div>
    <h1 class="hero-title">STREAMERS</h1>
    <p class="hero-sub">Los creadores de contenido que hacen vibrar la plataforma desde Puerto Rico y más allá.</p>
    <div class="live-pill" id="livePill">
      <span class="dot"></span>
      <span id="liveCount">0</span> EN VIVO
    </div>
  </div>

  <div class="grid-wrap">
    <div class="crl-grid crl-grid-auto" id="grid"></div>
  </div>
</main>

<script>
(function () {
  const POLL_MS = 15000;
  const API_URL = '/mediamtx-api/v3/paths/list';
  const PROFILE_URL = '/chat-api/profile/';

  const grid = document.getElementById('grid')!;

  (window as any).STREAMERS.forEach((s: any) => {
    if (s.soon) {
      const el = document.createElement('div');
      el.className = 's-card soon';
      el.innerHTML = `
        <div class="s-card-accent" style="background:${s.color}"></div>
        <div class="s-card-top">
          <div class="s-avatar-fallback" style="background:${s.color}">?</div>
        </div>
        <div class="s-card-body">
          <p class="s-name">${s.name}</p>
          <p class="s-sub">${s.sub}</p>
        </div>`;
      grid.appendChild(el);
      return;
    }

    const card = document.createElement('a');
    card.className = 's-card';
    card.href = `/${s.key}/`;
    card.dataset.key = s.key;
    card.innerHTML = `
      <div class="s-card-accent" style="background:${s.color}"></div>
      <div class="s-card-top">
        <img class="s-avatar" id="ava-${s.key}"
             src="/assets/thumbs/${s.key}.jpg"
             onerror="this.style.display='none';document.getElementById('avaf-${s.key}').style.display='flex'"
             alt="${s.name}" style="display:none">
        <div class="s-avatar-fallback" id="avaf-${s.key}" style="background:${s.color}">${s.ava}</div>
        <div class="s-badges">
          <span class="s-live-badge"><span class="dot"></span>EN VIVO</span>
          <span class="s-viewers" id="vw-${s.key}"></span>
        </div>
      </div>
      <div class="s-card-body">
        <h2 class="s-name">${s.name}</h2>
        <p class="s-sub">${s.sub}</p>
        <p class="s-stream-title" id="stitle-${s.key}" style="display:none"></p>
        <p class="s-bio crl-clamp-3" id="bio-${s.key}"></p>
      </div>
      <div class="s-card-footer">
        <div class="s-socials" id="soc-${s.key}"></div>
        <a href="/${s.key}/" class="s-watch-btn" id="btn-${s.key}">VER CANAL →</a>
      </div>`;
    grid.appendChild(card);
  });

  // Load profiles async
  (window as any).STREAMERS.filter((s: any) => s.key).forEach(async (s: any) => {
    try {
      const res = await fetch(PROFILE_URL + s.key);
      if (!res.ok) return;
      const d = await res.json();

      if (d.avatar_url) {
        const img = document.getElementById('ava-' + s.key) as HTMLImageElement | null;
        const fb  = document.getElementById('avaf-' + s.key);
        if (img) { img.src = d.avatar_url; img.style.display = ''; if (fb) fb.style.display = 'none'; }
      }
      const bio = document.getElementById('bio-' + s.key);
      if (bio && d.bio) bio.textContent = d.bio;

      const stitle = document.getElementById('stitle-' + s.key);
      if (stitle && d.stream_title) { stitle.textContent = '▶ ' + d.stream_title; stitle.style.display = ''; }

      const soc = document.getElementById('soc-' + s.key);
      if (soc) {
        if (d.twitch)    soc.innerHTML += `<a href="https://twitch.tv/${d.twitch}" class="s-social-btn twitch" target="_blank" rel="noopener" onclick="event.stopPropagation()"><i class="fa-brands fa-twitch"></i></a>`;
        if (d.instagram) soc.innerHTML += `<a href="https://instagram.com/${d.instagram}" class="s-social-btn instagram" target="_blank" rel="noopener" onclick="event.stopPropagation()"><i class="fa-brands fa-instagram"></i></a>`;
        if (d.tiktok)    soc.innerHTML += `<a href="https://tiktok.com/@${d.tiktok}" class="s-social-btn tiktok" target="_blank" rel="noopener" onclick="event.stopPropagation()"><i class="fa-brands fa-tiktok"></i></a>`;
      }
    } catch {}
  });

  // Poll live status
  let liveSet = new Set<string>();

  async function poll() {
    try {
      const res   = await fetch(API_URL, { signal: AbortSignal.timeout(5000) });
      const d     = await res.json();
      const items = d.items || [];

      liveSet = new Set(items.filter((p: any) => p.ready).map((p: any) => p.name.replace('live/', '')));

      let count = 0;
      (window as any).STREAMERS.filter((s: any) => s.key).forEach((s: any) => {
        const card = document.querySelector(`[data-key="${s.key}"]`);
        if (!card) return;
        const live = liveSet.has(s.key);
        card.classList.toggle('is-live', live);

        const path  = items.find((p: any) => p.name === 'live/' + s.key);
        const views = path ? (path.readers || []).length : 0;
        const vw    = document.getElementById('vw-' + s.key);
        if (vw) vw.textContent = views + (views === 1 ? ' viewer' : ' viewers');

        const btn = document.getElementById('btn-' + s.key);
        if (btn) btn.textContent = live ? '▶ VER EN VIVO →' : 'VER CANAL →';

        if (live) count++;
      });

      const pill = document.getElementById('livePill')!;
      document.getElementById('liveCount')!.textContent = String(count);
      pill.classList.toggle('show', count > 0);
    } catch {}
  }

  poll();
  setInterval(poll, POLL_MS);
  document.addEventListener('visibilitychange', () => { if (!document.hidden) poll(); });
})();

// Live sidebar
(async () => {
  const rows = document.getElementById('sidebarRows');
  if (!rows) return;
  const STREAMERS = (window as any).STREAMERS || [];
  try {
    const r = await fetch('/mediamtx-api/v3/paths/list', { signal: AbortSignal.timeout(4000) });
    const data = await r.json();
    const live = new Set(
      (data.items || []).filter((p: any) => p.ready).map((p: any) => (p.name as string).replace('live/', ''))
    );
    rows.innerHTML = STREAMERS.filter((s: any) => !s.soon).map((s: any) => {
      const isLive = live.has(s.key);
      return `<a href="/${s.key}/" class="cs-row${isLive ? ' is-live' : ''}" title="${s.name}">
        <div class="cs-ava" style="background:${s.color}">${s.ava}</div>
        <div class="cs-info">
          <div class="cs-name">${s.name}</div>
          <div class="cs-status${isLive ? ' live' : ''}">${isLive ? 'En vivo' : 'Offline'}</div>
        </div>
      </a>`;
    }).join('');
  } catch {}
})();
</script>

</div></div>
</BaseLayout>
