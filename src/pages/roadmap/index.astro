---
import BaseLayout from '../../layouts/BaseLayout.astro';

const footerLinks = [
  { href: '/multiplayer/', label: 'Multiplayer' },
  { href: '/streamers/', label: 'Streamers' },
  { href: '/join/', label: 'Crear Canal' },
  { href: '/que-es-corillo/', label: 'Sobre Corillo' },
  { href: '/vods/', label: 'VODs' },
  { href: '/legal/', label: 'Términos' },
  { href: 'https://status.corillo.live', label: 'Status' },
];
---
<BaseLayout
  title="CORILLO — Roadmap del proyecto"
  description="Mira hacia dónde va CORILLO, qué ya funciona hoy y qué sigue en el roadmap del proyecto."
  canonical="https://corillo.live/roadmap/"
  footerLinks={footerLinks}
>

<div class="crl-hero">
  <div class="crl-hero-mark">
    <svg class="crl-brand-logo crl-logo-hero" viewBox="0 0 250 88" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs><radialGradient id="rm-hg" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#00bfff" stop-opacity="0.25"/><stop offset="100%" stop-color="#00bfff" stop-opacity="0"/></radialGradient></defs>
      <text class="crl-brand-word" x="0" y="74" font-family="Bebas Neue, cursive" font-size="82">C</text>
      <circle cx="72" cy="42" r="36" fill="url(#rm-hg)"/>
      <circle class="crl-brand-ring-outer" cx="72" cy="42" r="34" stroke-width="9" fill="none"/>
      <circle cx="72" cy="42" r="20" stroke="#00bfff" stroke-width="6" fill="none"/>
      <circle cx="72" cy="42" r="8" fill="#00bfff"/>
      <circle cx="72" cy="42" r="3.5" fill="#00ff9d"/>
      <text class="crl-brand-word" x="114" y="74" font-family="Bebas Neue, cursive" font-size="82">RILLO</text>
    </svg>
  </div>
  <p class="crl-hero-eyebrow">Plataforma independiente · Puerto Rico</p>
  <h1 class="crl-hero-title">ROADMAP</h1>
  <p class="crl-hero-sub">Hacia dónde va el corillo. Lo que ya funciona, lo que viene, y las chulerías que nos hacen diferentes.</p>
  <div class="crl-hero-actions">
    <a class="btn btn-primary" href="/join/"><i class="fa-solid fa-arrow-right"></i> Únete</a>
    <a class="btn" href="/streamers/"><i class="fa-solid fa-users"></i> Streamers</a>
  </div>
</div>
<hr class="crl-divider-fade crl-divider-flush">

<div class="crl-container-narrow">

  <p class="crl-section-label">Listo</p>

  <div class="card crl-card-stack card-accent">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">Plataforma base</div>
        <div class="crl-card-desc">Todo lo que funciona hoy en corillo.live</div>
      </div>
      <span class="badge badge-accent"><i class="fa-solid fa-check"></i> Listo</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Streaming HLS multi-canal en vivo</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Chat en vivo por canal</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> @bot con inteligencia artificial</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Bot comenta el stream en tiempo real con visión</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Vista multiplayer — todos los canales en vivo</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Diseño responsive dark / light mode</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> SEO — OG tags por canal para redes sociales</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Anti-spam y rate limit en el chat</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Historial de chat persistente</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Username persistente entre sesiones</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Player universal — un template para todos los canales</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Perfil de streamer — avatar, bio, redes, paneles</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Dashboard — stream key, editar perfil, VOD settings</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Onboarding via formulario + aprobación por Telegram</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Stream keys protegidas y regenerables</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Monitor de bitrate con auto-kick</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Thumbnails auto-generados cada 60s por canal en vivo</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Fondo con último screenshot cuando el canal está offline</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Directorio de streamers con status en vivo</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Guía de configuración OBS y Meld Studio</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Notificaciones Telegram al admin — streamer en vivo, bitrate alto</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Deploy automático con GitHub Actions</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> WebRTC WHEP — latencia ultra-baja ~200ms</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Monitoreo del servidor — status.corillo.live</li>
    </ul>
  </div>

  <div class="card crl-card-stack card-accent">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">VODs</div>
        <div class="crl-card-desc">Grabación automática y reproducción de transmisiones pasadas</div>
      </div>
      <span class="badge badge-accent"><i class="fa-solid fa-check"></i> Listo</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Grabación automática al iniciar stream</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Thumbnail del VOD auto-generado</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Preview de 4s en hover sin reproducir</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Player individual de VOD con autoplay</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Últimas 5 transmisiones en el player del canal</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Browser de VODs con filtro por canal</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Plan free (5 VODs) y pro (ilimitado)</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Clips de 30s desde el live o un VOD</li>
    </ul>
  </div>

  <div class="card crl-card-stack card-accent">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">PWA y notificaciones push</div>
        <div class="crl-card-desc">Instala corillo como app y recibe avisos cuando tu streamer va en vivo</div>
      </div>
      <span class="badge badge-accent"><i class="fa-solid fa-check"></i> Listo</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> PWA instalable en móvil y desktop</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Notificaciones push por canal — sin cuenta</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Contador de viewers en tiempo real</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Botón compartir — Web Share API + clipboard</li>
    </ul>
  </div>

  <div class="card crl-card-stack card-accent">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">Corillo CSS</div>
        <div class="crl-card-desc">Framework CSS dark-first construido sobre la plataforma</div>
      </div>
      <span class="badge badge-accent"><i class="fa-solid fa-check"></i> Listo</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Tokens <code>--crl-*</code> — paleta boricua completa</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> 37 componentes — sin dependencias, 40 KB</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Dark-first con light mode automático</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Prefijo <code>crl-*</code> consistente en todos los componentes — v1.2.0</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Table, Tabs, Accordion, Select, KPI Card, Form validation</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Desplegado en 9 páginas principales de Corillo</li>
      <li><i class="fa-solid fa-check crl-feature-ico crl-text-accent"></i> Docs en <a href="/corillo-css/" class="crl-link-accent">corillo.live/corillo-css/</a></li>
    </ul>
  </div>

  <p class="crl-section-label">Diferenciadores</p>

  <div class="card crl-card-stack crl-card-cool">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">Features propios de la plataforma</div>
        <div class="crl-card-desc">Lo que existe aquí y no es estándar en otras plataformas</div>
      </div>
      <span class="badge crl-badge-cool"><i class="fa-solid fa-star"></i> Único</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Bot con visión — ve el stream y comenta como viewer</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Pre-check offline antes de intentar HLS — carga instantánea</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Auto-switch VOD → live cuando el streamer vuelve</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Preview de VODs en hover sin reproducirlos</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Notificaciones push por canal individual — sin app</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Clips del live en segundos sin salir del player</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Layout KATANA — dos canales simultáneos fijo</li>
      <li><i class="fa-solid fa-star crl-feature-ico crl-ico-cool"></i> Monitor de bitrate con auto-kick automático</li>
    </ul>
  </div>

  <p class="crl-section-label">Próximo</p>

  <div class="card crl-card-stack card-confirm">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">Comunidad</div>
        <div class="crl-card-desc">Más interacción entre el chat y los streamers</div>
      </div>
      <span class="badge badge-confirm"><i class="fa-solid fa-bolt"></i> En camino</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-solid fa-circle-dot crl-feature-ico crl-text-confirm"></i> Reacciones emoji en el chat en tiempo real</li>
      <li><i class="fa-solid fa-circle-dot crl-feature-ico crl-text-confirm"></i> GIFs animados del stream en cards del homepage</li>
      <li><i class="fa-solid fa-circle-dot crl-feature-ico crl-text-confirm"></i> Dashboard de stats — viewers pico, duración, frecuencia</li>
      <li><i class="fa-solid fa-circle-dot crl-feature-ico crl-text-confirm"></i> Moderación — ban temporal, lista negra de palabras</li>
    </ul>
  </div>

  <p class="crl-section-label">Futuro</p>

  <div class="card crl-card-stack card-dim">
    <div class="crl-card-head">
      <div>
        <div class="crl-card-title">Largo plazo</div>
        <div class="crl-card-desc">El largo plazo — ideas que ya están en la lista</div>
      </div>
      <span class="badge badge-dim"><i class="fa-regular fa-clock"></i> Pendiente</span>
    </div>
    <ul class="crl-feature-list">
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Raid — redirigir tu audiencia a otro canal al terminar</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Co-streaming — cualquier combinación de canales en pantalla dividida</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Notificaciones por Telegram — /sub katatonia desde el bot</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Clips compartibles — URL única tipo /clips/&#123;id&#125;</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Registro abierto al público — sin aprobación manual</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Modelo de sostenibilidad — corillo pro</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> Categorías y tags por stream</li>
      <li><i class="fa-regular fa-clock crl-feature-ico crl-text-muted"></i> App móvil nativa</li>
    </ul>
  </div>

</div>

</BaseLayout>
