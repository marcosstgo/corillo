---
import BaseLayout from '../../layouts/BaseLayout.astro';

const footerLinks = [
  { href: '/multiplayer/', label: 'Multiplayer' },
  { href: '/streamers/', label: 'Streamers' },
  { href: '/join/', label: 'Crear Canal' },
  { href: '/que-es-corillo/', label: 'Sobre Corillo' },
  { href: '/configuracion/', label: 'Config OBS' },
  { href: '/legal/', label: 'Términos' },
  { href: '/dmca/', label: 'DMCA' },
  { href: 'https://status.corillo.live', label: 'Status' },
];
---
<BaseLayout
  title="CORILLO — Política DMCA"
  description="Política DMCA y proceso de reclamaciones de derechos de autor de CORILLO."
  canonical="https://corillo.live/dmca/"
  navLabel="DMCA"
  navRightHref="/legal/"
  navRightIcon="fa-solid fa-scale-balanced"
  footerLinks={footerLinks}
>
  <fragment slot="head">
    <meta name="theme-color" content="#060608" />
    <style>
      .page-wrap{max-width:860px;margin:0 auto;padding:40px 24px 80px}
      @media(max-width:600px){.page-wrap{padding:24px 16px 60px}}

      .page-header{margin-bottom:48px;padding-bottom:24px;border-bottom:1px solid var(--crl-border)}
      .page-title{font-family:var(--crl-display);font-size:clamp(2.5rem,6vw,4rem);letter-spacing:3px;line-height:1}
      .page-title span{color:var(--crl-accent)}
      .page-meta{font-family:var(--crl-mono);font-size:.78rem;letter-spacing:2px;color:var(--crl-muted);text-transform:uppercase;margin-top:10px}

      .lang-tabs{display:flex;gap:8px;margin-bottom:32px}
      .lang-tab{
        font-family:var(--crl-mono);font-size:.78rem;letter-spacing:1.5px;text-transform:uppercase;
        padding:6px 14px;border-radius:6px;border:1px solid var(--crl-border);
        background:transparent;color:var(--crl-muted);cursor:pointer;transition:.15s;
      }
      .lang-tab.active{border-color:rgba(232,200,74,.4);color:var(--crl-accent);background:rgba(232,200,74,.06)}
      .lang-tab:hover:not(.active){border-color:var(--crl-border-h);color:var(--crl-white)}

      .content-block{display:none}
      .content-block.active{display:block}

      .alert-box{
        background:rgba(223,48,48,.07);border:1px solid rgba(223,48,48,.2);
        border-radius:10px;padding:20px 24px;margin-bottom:32px;
        display:flex;gap:14px;align-items:flex-start;
      }
      .alert-box i{color:var(--crl-confirm);font-size:1.1rem;margin-top:2px;flex-shrink:0}
      .alert-box p{color:rgba(255,255,255,.8);margin:0;line-height:1.7;font-size:.95rem}
      [data-theme="light"] .alert-box p{color:rgba(0,0,0,.8)}

      .legal-section{margin-bottom:40px;scroll-margin-top:80px}
      .legal-section h2{
        font-family:var(--crl-display);letter-spacing:2px;font-size:1.6rem;
        color:var(--crl-white);margin-bottom:14px;padding-bottom:10px;
        border-bottom:1px solid var(--crl-border);
      }
      .legal-section h2 .num{color:var(--crl-accent);margin-right:8px}
      .legal-section p{color:rgba(255,255,255,.7);line-height:1.8;margin-bottom:12px;font-size:.95rem}
      .legal-section ul,.legal-section ol{padding-left:20px;margin-bottom:12px}
      .legal-section li{color:rgba(255,255,255,.7);line-height:1.8;margin:6px 0;font-size:.95rem}
      .legal-section a{color:var(--crl-accent);text-decoration:underline;text-decoration-color:rgba(232,200,74,.3)}
      .legal-section a:hover{text-decoration-color:var(--crl-accent)}
      .legal-section strong{color:var(--crl-white)}
      [data-theme="light"] .legal-section p,[data-theme="light"] .legal-section li{color:rgba(0,0,0,.7)}

      .steps-grid{display:grid;gap:14px;margin:20px 0}
      .step-card{
        background:rgba(12,12,16,.6);border:1px solid var(--crl-border);border-radius:10px;
        padding:18px 20px;display:flex;gap:16px;align-items:flex-start;
      }
      [data-theme="light"] .step-card{background:rgba(255,255,255,.7)}
      .step-num{
        font-family:var(--crl-display);font-size:2rem;color:rgba(232,200,74,.25);
        line-height:1;flex-shrink:0;width:32px;
      }
      .step-content h3{font-family:var(--crl-mono);font-size:.92rem;letter-spacing:2px;text-transform:uppercase;color:var(--crl-accent);margin-bottom:6px}
      .step-content p{color:rgba(255,255,255,.7);font-size:.9rem;line-height:1.6;margin:0}
      [data-theme="light"] .step-content p{color:rgba(0,0,0,.7)}

      .contact-card{
        background:rgba(232,200,74,.05);border:1px solid rgba(232,200,74,.15);
        border-radius:10px;padding:24px;margin-top:16px;
      }
      .contact-card p{margin:6px 0;font-size:.95rem;color:rgba(255,255,255,.75)}
      .contact-card strong{color:var(--crl-white)}
      .contact-card .email-big{
        font-family:var(--crl-mono);font-size:1rem;color:var(--crl-accent);
        display:block;margin:12px 0;
      }
      [data-theme="light"] .contact-card p{color:rgba(0,0,0,.75)}
      [data-theme="light"] .contact-card strong{color:#12120f}

      .warning-box{
        background:rgba(12,12,16,.6);border:1px solid var(--crl-border);
        border-radius:8px;padding:16px 20px;margin:16px 0;
      }
      .warning-box p{color:rgba(255,255,255,.6);margin:0;font-size:.88rem;line-height:1.7}
      [data-theme="light"] .warning-box p{color:rgba(0,0,0,.6)}
    </style>
  </fragment>

<main>
  <div class="page-wrap">

    <div class="page-header">
      <div class="page-title">POLÍTICA <span>DMCA</span></div>
      <div class="page-meta">Digital Millennium Copyright Act · Última actualización: 1 de marzo de 2026</div>
    </div>

    <div class="lang-tabs">
      <button class="lang-tab active" onclick="setLang('es')">Español</button>
      <button class="lang-tab" onclick="setLang('en')">English</button>
    </div>

    <!-- ESPAÑOL -->
    <div class="content-block active" id="block-es">

      <div class="alert-box">
        <i class="fa-solid fa-shield-halved"></i>
        <p>CORILLO respeta los derechos de propiedad intelectual y opera bajo el <strong>Safe Harbor de la DMCA</strong> (17 U.S.C. § 512). Respondemos a todas las notificaciones válidas de infracción de derechos de autor de manera oportuna.</p>
      </div>

      <div class="legal-section">
        <h2><span class="num">01</span>Cómo Funciona el Proceso</h2>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-num">1</div>
            <div class="step-content">
              <h3>Envía tu reclamación</h3>
              <p>Envía una notificación DMCA válida a hello@marcossantiago.com con todos los elementos requeridos.</p>
            </div>
          </div>
          <div class="step-card">
            <div class="step-num">2</div>
            <div class="step-content">
              <h3>Revisamos en 48-72 horas</h3>
              <p>Evaluamos la reclamación para verificar que cumple con los requisitos legales de la DMCA.</p>
            </div>
          </div>
          <div class="step-card">
            <div class="step-num">3</div>
            <div class="step-content">
              <h3>Acción inmediata</h3>
              <p>Si la reclamación es válida, suspendemos o eliminamos el contenido infractor de inmediato.</p>
            </div>
          </div>
          <div class="step-card">
            <div class="step-num">4</div>
            <div class="step-content">
              <h3>Notificamos al Streamer</h3>
              <p>Informamos al streamer sobre la reclamación. Puede presentar una contra-notificación si considera que es un error.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="legal-section">
        <h2><span class="num">02</span>Requisitos de la Notificación DMCA</h2>
        <p>Para que su reclamación sea válida bajo la DMCA, debe incluir <strong>todos</strong> los siguientes elementos:</p>
        <ol>
          <li>Identificación de la obra protegida por derechos de autor que alega ha sido infringida</li>
          <li>Identificación del material que alega está infringiendo y su ubicación en CORILLO (URL específica)</li>
          <li>Su información de contacto: nombre completo, dirección, número de teléfono y correo electrónico</li>
          <li>Una declaración de que cree de buena fe que el uso no está autorizado por el titular de los derechos, su agente o la ley</li>
          <li>Una declaración, bajo pena de perjurio, de que la información en su notificación es precisa y que usted es el titular de los derechos o está autorizado para actuar en su nombre</li>
          <li>Su firma física o electrónica</li>
        </ol>
        <div class="warning-box">
          <p><strong>Advertencia:</strong> Presentar una reclamación DMCA falsa puede resultar en responsabilidad civil y criminal. Solo presente reclamaciones si realmente es titular de los derechos o está autorizado para hacerlo.</p>
        </div>
      </div>

      <div class="legal-section">
        <h2><span class="num">03</span>Contra-Notificación</h2>
        <p>Si su contenido fue eliminado y cree que fue un error, puede presentar una contra-notificación que incluya:</p>
        <ol>
          <li>Identificación del material eliminado y su ubicación antes de ser removido</li>
          <li>Una declaración, bajo pena de perjurio, de que cree de buena fe que el material fue eliminado por error</li>
          <li>Su nombre, dirección y número de teléfono</li>
          <li>Una declaración de que acepta la jurisdicción del tribunal federal del distrito donde reside</li>
          <li>Su firma física o electrónica</li>
        </ol>
        <p>Si recibimos una contra-notificación válida, podemos restaurar el contenido en 10-14 días hábiles a menos que el reclamante original inicie una acción legal.</p>
      </div>

      <div class="legal-section">
        <h2><span class="num">04</span>Política de Reincidencia</h2>
        <p>CORILLO tiene una política de tolerancia cero para infractores reincidentes. Un Streamer que reciba <strong>tres reclamaciones DMCA válidas</strong> será suspendido permanentemente de la plataforma.</p>
      </div>

      <div class="legal-section">
        <h2><span class="num">05</span>Enviar Reclamación</h2>
        <p>Envíe su notificación DMCA únicamente por correo electrónico a:</p>
        <div class="contact-card">
          <p><strong>Agente DMCA Designado</strong></p>
          <p>CORILLO — Marcos Santiago</p>
          <p>Puerto Rico, Estados Unidos</p>
          <a href="mailto:hello@marcossantiago.com" class="email-big">hello@marcossantiago.com</a>
          <p style="font-size:.92rem;color:var(--crl-muted)">Asunto del email: "DMCA Takedown Notice — [nombre de su obra]"</p>
        </div>
      </div>

    </div>

    <!-- ENGLISH -->
    <div class="content-block" id="block-en">

      <div class="alert-box">
        <i class="fa-solid fa-shield-halved"></i>
        <p>CORILLO respects intellectual property rights and operates under the <strong>DMCA Safe Harbor</strong> (17 U.S.C. § 512). We respond to all valid copyright infringement notices in a timely manner.</p>
      </div>

      <div class="legal-section">
        <h2><span class="num">01</span>How the Process Works</h2>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-num">1</div>
            <div class="step-content">
              <h3>Submit your claim</h3>
              <p>Send a valid DMCA notice to hello@marcossantiago.com with all required elements.</p>
            </div>
          </div>
          <div class="step-card">
            <div class="step-num">2</div>
            <div class="step-content">
              <h3>We review within 48-72 hours</h3>
              <p>We evaluate the claim to verify it meets the legal requirements of the DMCA.</p>
            </div>
          </div>
          <div class="step-card">
            <div class="step-num">3</div>
            <div class="step-content">
              <h3>Immediate action</h3>
              <p>If the claim is valid, we suspend or remove the infringing content immediately.</p>
            </div>
          </div>
          <div class="step-card">
            <div class="step-num">4</div>
            <div class="step-content">
              <h3>We notify the Streamer</h3>
              <p>We inform the streamer about the claim. They may file a counter-notice if they believe it was an error.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="legal-section">
        <h2><span class="num">02</span>DMCA Notice Requirements</h2>
        <p>For your claim to be valid under the DMCA, it must include <strong>all</strong> of the following elements:</p>
        <ol>
          <li>Identification of the copyrighted work you claim has been infringed</li>
          <li>Identification of the material you claim is infringing and its location on CORILLO (specific URL)</li>
          <li>Your contact information: full name, address, phone number and email address</li>
          <li>A statement that you believe in good faith that the use is not authorized by the copyright owner, its agent, or the law</li>
          <li>A statement, under penalty of perjury, that the information in your notice is accurate and that you are the copyright owner or authorized to act on their behalf</li>
          <li>Your physical or electronic signature</li>
        </ol>
        <div class="warning-box">
          <p><strong>Warning:</strong> Filing a false DMCA claim can result in civil and criminal liability. Only file claims if you are truly the rights holder or authorized to do so.</p>
        </div>
      </div>

      <div class="legal-section">
        <h2><span class="num">03</span>Counter-Notice</h2>
        <p>If your content was removed and you believe it was an error, you may file a counter-notice that includes:</p>
        <ol>
          <li>Identification of the removed material and its location before removal</li>
          <li>A statement, under penalty of perjury, that you believe in good faith the material was removed by mistake</li>
          <li>Your name, address and phone number</li>
          <li>A statement that you consent to the jurisdiction of the federal court in the district where you reside</li>
          <li>Your physical or electronic signature</li>
        </ol>
        <p>If we receive a valid counter-notice, we may restore the content within 10-14 business days unless the original claimant initiates legal action.</p>
      </div>

      <div class="legal-section">
        <h2><span class="num">04</span>Repeat Infringer Policy</h2>
        <p>CORILLO has a zero-tolerance policy for repeat infringers. A Streamer who receives <strong>three valid DMCA claims</strong> will be permanently suspended from the platform.</p>
      </div>

      <div class="legal-section">
        <h2><span class="num">05</span>Submit a Claim</h2>
        <p>Send your DMCA notice only by email to:</p>
        <div class="contact-card">
          <p><strong>Designated DMCA Agent</strong></p>
          <p>CORILLO — Marcos Santiago</p>
          <p>Puerto Rico, United States</p>
          <a href="mailto:hello@marcossantiago.com" class="email-big">hello@marcossantiago.com</a>
          <p style="font-size:.92rem;color:var(--crl-muted)">Email subject: "DMCA Takedown Notice — [name of your work]"</p>
        </div>
      </div>

    </div>
  </div>
</main>

<script>
function setLang(lang: string) {
  document.querySelectorAll('.content-block').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.lang-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('block-' + lang)!.classList.add('active');
  document.querySelectorAll('.lang-tab').forEach(t => {
    if ((t as HTMLElement).textContent!.toLowerCase().includes(lang === 'es' ? 'español' : 'english')) {
      t.classList.add('active');
    }
  });
  localStorage.setItem('corillo-lang', lang);
}
const savedLang = localStorage.getItem('corillo-lang') || 'es';
if (savedLang === 'en') setLang('en');
</script>

</BaseLayout>
