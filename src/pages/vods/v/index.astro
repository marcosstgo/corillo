---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import LiveSidebar from '../../../components/LiveSidebar.astro';

const footerLinks = [
  { href: '/multiplayer/', label: 'Multiplayer' },
  { href: '/streamers/', label: 'Streamers' },
  { href: '/join/', label: 'Crear Canal' },
  { href: '/legal/', label: 'Términos' },
  { href: 'https://status.corillo.live', label: 'Status' },
];
---
<BaseLayout
  title="VOD — CORILLO"
  description="Transmisión grabada en CORILLO — plataforma independiente desde Puerto Rico."
  canonical="https://corillo.live/vods/v/"
  navLabel="VOD"
  navRightHref="/vods/"
  navRightIcon="fa-solid fa-film"
  footerLinks={footerLinks}
>
  <fragment slot="head">
    <meta name="theme-color" content="#030a0e" />
    <style is:global>
      .player-wrap{background:#000;width:100%;aspect-ratio:16/9;max-height:70vh;display:flex;align-items:center;justify-content:center;position:relative}
      .player-wrap video{width:100%;height:100%;display:block}

      .meta-bar{max-width:900px;margin:0 auto;padding:20px 24px 0}
      .meta-channel{display:flex;align-items:center;gap:12px;margin-bottom:12px}
      .meta-ava{width:36px;height:36px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--crl-display);font-size:16px;color:#030a0e}
      .meta-name{font-family:var(--crl-display);font-size:1.5rem;letter-spacing:3px}
      .meta-title{font-size:1.1rem;font-weight:600;margin:8px 0 4px;color:var(--crl-white);line-height:1.3}
      .meta-stats{display:flex;align-items:center;gap:20px;font-family:var(--crl-mono);font-size:11px;color:var(--crl-muted);letter-spacing:.5px;flex-wrap:wrap}
      .meta-stats i{color:var(--crl-accent);font-size:.65rem}
      .meta-divider{border:none;border-top:1px solid var(--crl-border);margin:16px 0}

      .actions{max-width:900px;margin:0 auto;padding:0 24px 16px;display:flex;gap:10px;flex-wrap:wrap}
      .action-btn{font-family:var(--crl-mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;padding:8px 16px;border-radius:6px;border:1px solid var(--crl-border);background:transparent;color:var(--crl-muted);cursor:pointer;transition:.15s;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
      .action-btn:hover{border-color:var(--crl-border-h);color:var(--crl-white)}
      .action-btn.primary{border-color:rgba(0,191,255,.4);color:var(--crl-accent)}
      .action-btn.primary:hover{background:rgba(0,191,255,.08)}

      .unmute-btn{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);z-index:10;font-family:var(--crl-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;padding:10px 20px;border-radius:8px;border:1px solid rgba(0,191,255,.5);background:rgba(3,10,14,.85);color:var(--crl-accent);cursor:pointer;display:flex;align-items:center;gap:8px;backdrop-filter:blur(8px);transition:.15s;white-space:nowrap}
      .unmute-btn:hover{background:rgba(0,191,255,.1);border-color:var(--crl-accent)}
      .unmute-btn.hidden{display:none}

      .not-found{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;gap:16px;text-align:center;padding:40px}
      .not-found-icon{font-size:3rem;color:var(--crl-muted);margin-bottom:8px}
      .not-found h2{font-family:var(--crl-display);font-size:2.5rem;letter-spacing:4px;color:rgba(232,246,255,.2)}
      .not-found p{font-family:var(--crl-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--crl-muted)}

      /* ── Related sections ── */
      .related-wrap{max-width:900px;margin:0 auto;padding:0 24px 48px;display:flex;flex-direction:column;gap:32px}
      .rel-sec{display:flex;flex-direction:column;gap:14px}
      .rel-hd{display:flex;align-items:center;gap:12px}
      .rel-title{font-family:var(--crl-display);font-size:20px;letter-spacing:3px;white-space:nowrap;flex-shrink:0}
      .rel-count{font-family:var(--crl-mono);font-size:11px;letter-spacing:1.5px;color:var(--crl-muted);flex-shrink:0}
      .rel-rule{flex:1;height:1px;background:var(--crl-border)}
      .rel-more{font-family:var(--crl-mono);font-size:10px;letter-spacing:1px;color:var(--crl-accent);white-space:nowrap;text-decoration:none;flex-shrink:0;transition:opacity .15s}
      .rel-more:hover{opacity:.7}
      .rel-rail{display:flex;gap:12px;overflow-x:auto;scrollbar-width:none;padding-bottom:4px;scroll-snap-type:x mandatory}
      .rel-rail::-webkit-scrollbar{display:none}

      /* ── Related card ── */
      .rel-card{flex:0 0 190px;scroll-snap-align:start;border-radius:6px;overflow:hidden;background:var(--crl-surface);border:1px solid var(--crl-border);text-decoration:none;color:inherit;transition:border-color .15s,transform .15s;display:flex;flex-direction:column}
      .rel-card:hover{border-color:var(--crl-border-h);transform:translateY(-2px)}
      .rel-card-thumb{position:relative;aspect-ratio:16/9;background:linear-gradient(135deg,#050a10,#0a1820);overflow:hidden;flex-shrink:0}
      .rel-card-thumb img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
      .rel-card-dur{position:absolute;bottom:4px;right:4px;font-family:var(--crl-mono);font-size:9px;font-weight:700;background:rgba(0,0,0,.8);color:#fff;padding:2px 5px;border-radius:2px}
      .rel-live-pill{position:absolute;top:6px;left:6px;font-family:var(--crl-mono);font-size:9px;font-weight:700;letter-spacing:1.5px;background:#CE1126;color:#fff;padding:2px 6px;border-radius:2px;display:flex;align-items:center;gap:4px}
      .rel-live-pill::before{content:'';width:5px;height:5px;border-radius:50%;background:#fff;animation:blink 1.8s infinite}
      .rel-viewers{position:absolute;top:6px;right:6px;font-family:var(--crl-mono);font-size:9px;font-weight:700;background:rgba(0,0,0,.65);color:#fff;padding:2px 5px;border-radius:2px}
      .rel-card-body{padding:9px 10px 11px;display:flex;gap:8px;align-items:flex-start}
      .rel-card-ava{width:28px;height:28px;border-radius:3px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--crl-display);font-size:13px;color:#000}
      .rel-card-ava.is-live{box-shadow:0 0 0 2px var(--crl-surface),0 0 0 3px #CE1126}
      .rel-card-info{min-width:0;flex:1}
      .rel-card-name{font-family:var(--crl-display);font-size:15px;letter-spacing:1.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.1;margin-bottom:3px}
      .rel-card-sub{font-family:var(--crl-mono);font-size:10px;color:var(--crl-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
      .rel-card-thumb-bg{position:absolute;inset:0;opacity:.8;mix-blend-mode:overlay}
    </style>
  </fragment>

<LiveSidebar>
<div id="content"></div>
<div id="related"></div>

<script>
const PB = 'https://pb.corillo.live';

function fmtDuration(s: number) {
  if (!s) return '—';
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const ss = Math.floor(s % 60);
  if (h > 0) return `${h}h ${m.toString().padStart(2,'0')}m`;
  return `${m}:${ss.toString().padStart(2,'0')}`;
}

function fmtSize(bytes: number) {
  if (!bytes) return '—';
  if (bytes > 1073741824) return (bytes / 1073741824).toFixed(1) + ' GB';
  return (bytes / 1048576).toFixed(0) + ' MB';
}

function fmtDate(iso: string) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('es-PR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
}

function streamerInfo(channel: string) {
  const s = ((window as any).STREAMERS || []).find((x: any) => x.key === channel);
  return s || { key: channel, name: channel.toUpperCase(), color: '#00bfff' };
}

function showNotFound() {
  document.getElementById('content')!.innerHTML = `
    <div class="not-found">
      <div class="not-found-icon"><i class="fa-solid fa-film"></i></div>
      <h2>VOD NO ENCONTRADO</h2>
      <p>Este VOD no existe o fue eliminado</p>
      <a href="/vods/" class="action-btn primary" style="margin-top:8px"><i class="fa-solid fa-arrow-left"></i> Ver todos los VODs</a>
    </div>`;
}

async function init() {
  const id = new URLSearchParams(location.search).get('id');
  if (!id) { showNotFound(); return; }

  let vod: any;
  try {
    const r = await fetch(`${PB}/api/collections/vods/records/${id}`);
    if (!r.ok) { showNotFound(); return; }
    vod = await r.json();
  } catch { showNotFound(); return; }

  const s = streamerInfo(vod.channel);
  const colorStyle = s.color ? `background:${s.color}` : 'background:var(--crl-accent)';
  const videoUrl   = `/vods/${vod.channel}/${vod.filename}`;
  const posterAttr = vod.thumb ? `poster="${vod.thumb}"` : '';

  const pageTitle = vod.title ? `${vod.title} — ${s.name}` : s.name;
  document.title = `${pageTitle} — VOD — CORILLO`;

  document.getElementById('content')!.innerHTML = `
    <div class="player-wrap">
      <video id="vodVideo" controls autoplay muted playsinline preload="metadata" src="${videoUrl}" ${posterAttr}></video>
      <button class="unmute-btn" id="unmuteBtn"><i class="fa-solid fa-volume-xmark"></i> Activar sonido</button>
    </div>
    <div class="meta-bar">
      <div class="meta-channel">
        <div class="meta-ava" style="${colorStyle}">${(s.name||'?')[0].toUpperCase()}</div>
        <a href="/${vod.channel}/" class="meta-name" style="color:${s.color||'var(--crl-white)'};text-decoration:none">${s.name}</a>
      </div>
      ${vod.title ? `<div class="meta-title">${vod.title}</div>` : ''}
      <div class="meta-stats">
        <span><i class="fa-regular fa-calendar"></i> ${fmtDate(vod.date)}</span>
        <span><i class="fa-solid fa-clock"></i> ${fmtDuration(vod.duration)}</span>
        <span><i class="fa-solid fa-weight-hanging"></i> ${fmtSize(vod.size)}</span>
      </div>
      <hr class="meta-divider">
    </div>
    <div class="actions">
      <a href="/${vod.channel}/" class="action-btn"><i class="fa-solid fa-tower-broadcast"></i> Canal de ${s.name}</a>
      <a href="/vods/?ch=${vod.channel}" class="action-btn"><i class="fa-solid fa-film"></i> Más VODs de ${s.name}</a>
      <button class="action-btn" id="copyLinkBtn"><i class="fa-solid fa-link"></i> Copiar enlace</button>
      <button class="action-btn" id="clipVodBtn"><i class="fa-solid fa-scissors"></i> Descargar clip</button>
    </div>`;

  const video = document.getElementById('vodVideo') as HTMLVideoElement;
  const unmuteBtn = document.getElementById('unmuteBtn')!;
  unmuteBtn.addEventListener('click', () => { video.muted = false; unmuteBtn.classList.add('hidden'); });
  video.addEventListener('volumechange', () => { if (!video.muted) unmuteBtn.classList.add('hidden'); });

  document.getElementById('copyLinkBtn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(location.href).then(() => {
      const btn = document.getElementById('copyLinkBtn')!;
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Copiado';
      setTimeout(() => { btn.innerHTML = '<i class="fa-solid fa-link"></i> Copiar enlace'; }, 2000);
    });
  });

  // Load related content async (non-blocking)
  loadRelated(vod.channel, id);

  const clipVodBtn = document.getElementById('clipVodBtn') as HTMLButtonElement;
  clipVodBtn.addEventListener('click', async () => {
    const t = Math.floor(video.currentTime || 0);
    const orig = clipVodBtn.innerHTML;
    clipVodBtn.disabled = true;
    clipVodBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Generando…';
    try {
      const r = await fetch(`/chat-api/clip/vod/${vod.id}?t=${t}`, { signal: AbortSignal.timeout(30000) });
      if (!r.ok) throw new Error();
      const blob = await r.blob();
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `clip_${vod.channel}_${t}s.mp4`;
      a.click();
      URL.revokeObjectURL(a.href);
      clipVodBtn.innerHTML = '<i class="fa-solid fa-check"></i> Guardado';
      setTimeout(() => { clipVodBtn.innerHTML = orig; clipVodBtn.disabled = false; }, 2000);
    } catch {
      clipVodBtn.innerHTML = '<i class="fa-solid fa-xmark"></i> Error';
      setTimeout(() => { clipVodBtn.innerHTML = orig; clipVodBtn.disabled = false; }, 2500);
    }
  });
}

init();

/* ── Related content ─────────────────────────────────── */
function relativeTime(dateStr: string) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 2)  return 'Hace un momento';
  if (mins < 60) return `Hace ${mins}m`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24)  return `Hace ${hrs}h`;
  const days = Math.floor(hrs / 24);
  if (days === 1) return 'Ayer';
  if (days < 7)  return `Hace ${days} días`;
  return `Hace ${Math.floor(days / 7)} sem`;
}

function relCard(vod: any) {
  const s = streamerInfo(vod.channel);
  const dur = vod.duration ? fmtDuration(vod.duration) : '';
  const thumb = vod.thumb
    ? `<img src="${vod.thumb}" alt="" loading="lazy" onerror="this.style.display='none'">`
    : `<div class="rel-card-thumb-bg" style="background:${s.color||'#1e3a4a'}"></div>`;
  return `<a href="/vods/v/?id=${vod.id}" class="rel-card">
    <div class="rel-card-thumb">${thumb}${dur ? `<span class="rel-card-dur">${dur}</span>` : ''}</div>
    <div class="rel-card-body">
      <div class="rel-card-ava" style="background:${s.color||'#1e3a4a'}">${(s.ava||s.name[0]).toUpperCase()}</div>
      <div class="rel-card-info">
        <div class="rel-card-name">${s.name}</div>
        <div class="rel-card-sub">${relativeTime(vod.date)}</div>
      </div>
    </div>
  </a>`;
}

function liveCard(s: any, viewers: number) {
  const t = Math.floor(Date.now() / 60000);
  return `<a href="/${s.key}/" class="rel-card">
    <div class="rel-card-thumb">
      <img src="/assets/thumbs/${s.key}.jpg?t=${t}" alt="" loading="lazy" onerror="this.style.display='none'">
      <span class="rel-live-pill">LIVE</span>
      ${viewers > 0 ? `<span class="rel-viewers">${viewers}</span>` : ''}
    </div>
    <div class="rel-card-body">
      <div class="rel-card-ava is-live" style="background:${s.color||'#1e3a4a'}">${(s.ava||s.name[0]).toUpperCase()}</div>
      <div class="rel-card-info">
        <div class="rel-card-name">${s.name}</div>
        <div class="rel-card-sub">${viewers > 0 ? viewers + ' viewers' : 'En vivo'}</div>
      </div>
    </div>
  </a>`;
}

function relSection(title: string, count: string, moreHref: string, moreLabel: string, cards: string) {
  return `<div class="rel-sec">
    <div class="rel-hd">
      <span class="rel-title">${title}</span>
      ${count ? `<span class="rel-count">${count}</span>` : ''}
      <div class="rel-rule"></div>
      ${moreHref ? `<a href="${moreHref}" class="rel-more">${moreLabel}</a>` : ''}
    </div>
    <div class="rel-rail">${cards}</div>
  </div>`;
}

async function loadRelated(channel: string, currentId: string) {
  const sections: string[] = [];

  // 1. Live now
  try {
    const r = await fetch('/mediamtx-api/v3/paths/list', { signal: AbortSignal.timeout(4000) });
    const j = await r.json();
    const items = (j.items || []) as any[];
    const liveStreamers = ((window as any).STREAMERS || []).filter((s: any) => {
      const path = items.find((p: any) => p.name === 'live/' + s.key);
      return path?.ready;
    }).map((s: any) => {
      const path = items.find((p: any) => p.name === 'live/' + s.key);
      return { ...s, _viewers: path?.readers?.length ?? 0 };
    });
    if (liveStreamers.length) {
      const cards = liveStreamers.map((s: any) => liveCard(s, s._viewers)).join('');
      sections.push(relSection('EN VIVO AHORA', `${liveStreamers.length} streamers`, '/multiplayer/', 'Multiplayer →', cards));
    }
  } catch {}

  // 2. Más del mismo canal
  try {
    const enc = encodeURIComponent(`channel='${channel}'&&id!='${currentId}'`);
    const r = await fetch(`${PB}/api/collections/vods/records?filter=${enc}&sort=-date&perPage=8&fields=id,channel,filename,thumb,duration,date`);
    const j = await r.json();
    const vods = j.items || [];
    if (vods.length) {
      const s = streamerInfo(channel);
      const cards = vods.map(relCard).join('');
      sections.push(relSection(`MÁS DE ${s.name}`, `${vods.length} VODs`, `/vods/?ch=${channel}`, 'Ver todos →', cards));
    }
  } catch {}

  // 3. De otros canales
  try {
    const enc = encodeURIComponent(`channel!='${channel}'`);
    const r = await fetch(`${PB}/api/collections/vods/records?filter=${enc}&sort=-date&perPage=10&fields=id,channel,filename,thumb,duration,date`);
    const j = await r.json();
    const vods = j.items || [];
    // one per channel, max 6
    const seen = new Set<string>();
    const unique = vods.filter((v: any) => { if (seen.has(v.channel)) return false; seen.add(v.channel); return true; }).slice(0, 6);
    if (unique.length) {
      const cards = unique.map(relCard).join('');
      sections.push(relSection('DE OTROS CANALES', '', '/vods/', 'Ver todos →', cards));
    }
  } catch {}

  if (sections.length) {
    document.getElementById('related')!.innerHTML =
      `<div class="related-wrap">${sections.join('')}</div>`;
  }
}

</script>

</LiveSidebar>
</BaseLayout>
