function setupHls(key) {
  const vid  = document.getElementById('featuredVideo');
  const wrap = document.getElementById('featuredVideoWrap');

  vid.pause();
  vid.src = '';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  wrap.classList.remove('playing');

  const url = `/live/${encodeURIComponent(key)}/index.m3u8`;

  if (vid.canPlayType('application/vnd.apple.mpegurl')) {
    vid.src = url;
    vid.play().catch(() => {});
    wrap.classList.add('playing');
  } else if (window.Hls?.isSupported()) {
    hlsInstance = new window.Hls({ lowLatencyMode: true, maxBufferLength: 8 });
    hlsInstance.loadSource(url);
    hlsInstance.attachMedia(vid);
    hlsInstance.on(window.Hls.Events.MANIFEST_PARSED, () => {
      vid.play().catch(() => {});
      wrap.classList.add('playing');
    });
    hlsInstance.on(window.Hls.Events.ERROR, (_, data) => {
      if (data.fatal) wrap.classList.remove('playing');
    });
  }
}

/* ── Rotation ────────────────────────────────────────── */
function startRotation(live, paths) {
  clearInterval(rotateTimer);
  livePlayers = live.map(s => s.key);
  if (!livePlayers.length) return;

  // Set initial featured
  const preferredIdx = featuredKey ? livePlayers.indexOf(featuredKey) : -1;
  rotateIdx = preferredIdx >= 0 ? preferredIdx : 0;
  const firstKey = livePlayers[rotateIdx];
  if (firstKey !== featuredKey) setFeaturedLive(firstKey, paths);

  if (livePlayers.length === 1) { startProgressBar(); return; }

  startProgressBar();
  rotateTimer = setInterval(() => {
    rotateIdx = (rotateIdx + 1) % livePlayers.length;
    const nextKey = livePlayers[rotateIdx];
    // Fade transition
    const wrap = document.getElementById('featuredVideoWrap');
    wrap.style.transition = 'opacity .28s';
    wrap.style.opacity = '0.4';
    setTimeout(() => {
      setFeaturedLive(nextKey, lastPaths);
      wrap.style.opacity = '1';
      setTimeout(() => { wrap.style.transition = ''; wrap.style.opacity = ''; }, 350);
    }, 280);
    startProgressBar();
  }, ROTATE_MS);
}

/* ── Live section ────────────────────────────────────── */
function renderLiveSection(live, paths) {
  const section = document.getElementById('liveSection');
  const rail    = document.getElementById('liveRail');
  const countEl = document.getElementById('liveCountEl');
  if (!section) return;

  if (!live.length) { section.style.display = 'none'; return; }

  section.style.display = '';
  if (countEl) countEl.textContent = live.length;

  const t = Math.floor(Date.now() / 60000);
  rail.innerHTML = live.map(s => {
    const viewers = getViewers(paths, s.key);
    if (!cardBitrates[s.key]) cardBitrates[s.key] = jitter(5000, 600);
    const bitrate = cardBitrates[s.key];
    return `<a class="ch" href="/${s.key}/">
      <div class="ch-thumb">
        <div class="ch-thumb-glow" style="background:${s.color || '#1e3a4a'}"></div>
        <div class="ch-thumb-noise"></div>
        <div class="ch-thumb-inner">${s.ava || s.name[0]}</div>
        <img class="ch-thumb-img" src="/assets/thumbs/${s.key}.jpg?t=${t}" onerror="this.style.display='none'" alt="">
        <div class="ch-top">
          <span class="ch-live">LIVE</span>
          <span class="ch-viewers"><i class="fa-solid fa-eye"></i>${viewers}</span>
        </div>
        <div class="ch-bottom"><span class="ch-bitrate">${fmtKbps(bitrate)}bps</span></div>
      </div>
      <div class="ch-body">
        <div class="ch-ava ring-live" style="background:${s.color || '#1e3a4a'}">${s.ava || s.name[0]}</div>
        <div class="ch-info">
          <div class="ch-name">${s.host ? '<span class="ch-host">H</span>' : ''}${s.name}</div>
          <div class="ch-sub">${s.sub || 'corillo.live'}</div>
        </div>
      </div>
    </a>`;
  }).join('');
}

/* ── Channel grid ────────────────────────────────────── */
function renderChannelGrid(paths) {
  const liveSet = getLiveSet(paths);
  const grid    = document.getElementById('channelGrid');

  // Last VOD thumb per channel — used as background for offline cards
  const vodThumbs = {};
  _recentVods.forEach(v => { if (v.thumb) vodThumbs[v.channel] = v.thumb; });

  // When live section is active show only offline; search filters both
  let list = liveSet.size > 0
    ? STREAMERS.filter(s => !liveSet.has(s.key))
    : STREAMERS;
  if (searchQuery) {
    list = STREAMERS.filter(s =>
      s.name.toLowerCase().includes(searchQuery) ||
      s.key.toLowerCase().includes(searchQuery)
    );
  }

  const withSoon = searchQuery
    ? list
    : [...list, ...(window.STREAMERS || []).filter(s => s.soon)];

  if (!withSoon.length) {
    const msg = 'No hay canales disponibles';
    grid.innerHTML = `<div class="grid-empty"><i class="fa-solid fa-satellite-dish"></i><p>${msg}</p></div>`;
    return;
  }

  const visible = searchQuery ? withSoon : withSoon.slice(0, 8);

  const cardsHtml = visible.map(s => {
    if (s.soon) return `
      <div class="ch soon">
        <div class="ch-thumb">
          <div class="ch-thumb-glow" style="background:${s.color || 'linear-gradient(135deg,#2a2a3a,#1a1a28)'}"></div>
          <div class="ch-thumb-noise"></div>
          <div class="ch-thumb-inner">?</div>
        </div>
        <div class="ch-body">
          <div class="ch-ava" style="background:${s.color || '#1e3a4a'}">${s.ava || '?'}</div>
          <div class="ch-info">
            <div class="ch-name">???</div>
            <div class="ch-sub">${s.sub || 'Próximamente'}</div>
          </div>
        </div>
      </div>`;

    const live    = liveSet.has(s.key);
    const viewers = live ? getViewers(paths, s.key) : 0;
    if (live && !cardBitrates[s.key]) cardBitrates[s.key] = jitter(5000, 600);
    if (!live) delete cardBitrates[s.key];
    const bitrate = cardBitrates[s.key];

    return `
      <a class="ch" href="/${s.key}/">
        <div class="ch-thumb">
          <div class="ch-thumb-glow" style="background:${s.color || '#1e3a4a'}"></div>
          <div class="ch-thumb-noise"></div>
          <div class="ch-thumb-inner">${s.ava || s.name[0]}</div>
          ${live
            ? `<img class="ch-thumb-img" src="/assets/thumbs/${s.key}.jpg?t=${Math.floor(Date.now()/60000)}" onerror="this.style.display='none'" alt="">`
            : vodThumbs[s.key]
              ? `<img class="ch-thumb-img ch-thumb-vod" src="${vodThumbs[s.key]}" alt="" loading="lazy" onerror="this.style.display='none'">`
              : ''
          }
          <div class="ch-top">
            ${live
              ? `<span class="ch-live">LIVE</span><span class="ch-viewers"><i class="fa-solid fa-eye"></i>${viewers}</span>`
              : `<span class="ch-badge-off">OFF</span>`
            }
          </div>
          ${live ? `<div class="ch-bottom"><span class="ch-bitrate">${fmtKbps(bitrate)}bps</span></div>` : ''}
        </div>
        <div class="ch-body">
          <div class="ch-ava ${live ? 'ring-live' : ''}" style="background:${s.color || '#1e3a4a'}">${s.ava || s.name[0]}</div>
          <div class="ch-info">
            <div class="ch-name">${s.host ? '<span class="ch-host">H</span>' : ''}${s.name}</div>
            <div class="ch-sub">${s.sub || 'corillo.live'}</div>
          </div>
        </div>
      </a>`;
  }).join('');

  grid.innerHTML = cardsHtml;
}

function renderVodsRow() {
  const carousel = document.getElementById('vodsCarousel');
  if (!carousel || !_recentVods.length) return;
  carousel.innerHTML = vodCards(_recentVods);
  attachPreviewListeners(carousel);
  const ids = [...carousel.querySelectorAll('[id^="card-ava-"]')].map(el => el.id.replace('card-ava-', ''));
  if (ids.length) loadCardAvatars(ids);
}

/* ── Sidebar ─────────────────────────────────────────── */
function renderSidebar(live, offline, paths) {
  const liveSection = document.getElementById('sidebarLiveSection');
  const liveRows    = document.getElementById('sidebarLiveRows');
  const offlineRows = document.getElementById('sidebarOfflineRows');
  const liveBadge   = document.getElementById('sidebarLiveBadge');
  if (!liveSection) return;

  if (live.length) {
    liveSection.style.display = '';
    if (liveBadge) { liveBadge.textContent = live.length; liveBadge.style.display = ''; }
    const t = Math.floor(Date.now() / 60000);
    liveRows.innerHTML = live.map(s => {
      const v = getViewers(paths, s.key);
      return `<a href="/${s.key}/" class="channel-row is-live">
        <div class="sidebar-row-inner">
          ${rowAva(s)}
          <div class="ch-row-info nav-text">
            <div class="ch-row-name">${s.name}</div>
            <div class="ch-row-status live">${v > 0 ? v + ' viewers' : 'En vivo'}</div>
          </div>
          <div class="live-pip nav-text"></div>
        </div>
      </a>`;
    }).join('');
  } else {
    liveSection.style.display = 'none';
    if (liveBadge) liveBadge.style.display = 'none';
  }

  const MAX = 8;
  const showAllBtn = document.getElementById('sidebarShowAll');
  const renderOffline = list => list.map(s => `
    <a href="/${s.key}/" class="channel-row">
      <div class="sidebar-row-inner">
        ${rowAva(s, true)}
        <div class="ch-row-info nav-text">
          <div class="ch-row-name">${s.name}</div>
          <div class="ch-row-status">Offline</div>
        </div>
      </div>
    </a>`).join('');

  if (offline.length > MAX) {
    offlineRows.innerHTML = renderOffline(offline.slice(0, MAX));
    showAllBtn.style.display = '';
    showAllBtn.onclick = () => {
      offlineRows.innerHTML = renderOffline(offline);
      showAllBtn.style.display = 'none';
    };
  } else {
    offlineRows.innerHTML = renderOffline(offline);
    showAllBtn.style.display = 'none';
  }
}

/* ── Drawer ──────────────────────────────────────────── */
function renderDrawer(live, offline, paths) {
  const liveSection = document.getElementById('drawerLiveSection');
  const liveRows    = document.getElementById('drawerLiveRows');
  const offlineRows = document.getElementById('drawerOfflineRows');

  if (live.length) {
    liveSection.style.display = '';
    liveRows.innerHTML = live.map(s => {
      const v = getViewers(paths, s.key);
      return `<a href="/${s.key}/" class="channel-row is-live" onclick="window.closeDrawer()">
        ${rowAva(s)}
        <div class="ch-row-info">
          <div class="ch-row-name">${s.name}</div>
          <div class="ch-row-status live">En vivo</div>
        </div>
        ${v > 0 ? `<div class="ch-row-viewers">${v}</div>` : '<div class="live-pip"></div>'}
      </a>`;
    }).join('');
  } else {
    liveSection.style.display = 'none';
  }

  const MAX = 8;
  const showAllBtn = document.getElementById('drawerShowAll');
  const renderOffline = list => list.map(s => `
    <a href="/${s.key}/" class="channel-row" onclick="window.closeDrawer()">
      ${rowAva(s, true)}
      <div class="ch-row-info">
        <div class="ch-row-name">${s.name}</div>
        <div class="ch-row-status">Offline</div>
      </div>
    </a>`).join('');

  if (offline.length > MAX) {
    offlineRows.innerHTML = renderOffline(offline.slice(0, MAX));
    showAllBtn.style.display = '';
    showAllBtn.onclick = () => {
      offlineRows.innerHTML = renderOffline(offline);
      showAllBtn.style.display = 'none';
    };
  } else {
    offlineRows.innerHTML = renderOffline(offline);
    showAllBtn.style.display = 'none';
  }
}

function openDrawer() {
  document.getElementById('drawer').classList.add('open');
  document.getElementById('drawerOverlay').classList.add('open');
}
window.closeDrawer = () => {
  document.getElementById('drawer').classList.remove('open');
  document.getElementById('drawerOverlay').classList.remove('open');
};

/* ── Digest ──────────────────────────────────────────── */
async function loadDigest() {
  try {
    const r = await fetch('/chat-api/digest', { signal: AbortSignal.timeout(5000) });
    const j = await r.json();
    if (j.digest) {
      document.getElementById('digestText').textContent = j.digest;
      document.getElementById('digestAge').textContent  = 'Claude · ahora';
    }
  } catch { /* digest is optional */ }
}

/* ── Theme ───────────────────────────────────────────── */
function toggleTheme() {
  const current = document.documentElement.getAttribute('data-theme');
  const next = current === 'light' ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', next);
  localStorage.setItem('corillo-theme', next);
}

/* ── Footer version ──────────────────────────────────── */
async function loadVersion() {
  try {
    const r = await fetch('/version.json', { signal: AbortSignal.timeout(3000) });
    const j = await r.json();
    const el = document.getElementById('footVersion');
    if (el && j.version) el.textContent = 'v' + j.version;
  } catch {}
}

/* ── Footer accordion ────────────────────────────────── */
function initFooter() {
  document.querySelectorAll('[data-foot-toggle]').forEach(title => {
    const links = title.nextElementSibling;
    if (!links) return;
    title.setAttribute('aria-expanded', 'false');
    title.addEventListener('click', () => {
      const isOpen = title.getAttribute('aria-expanded') === 'true';
      title.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      links.classList.toggle('open', !isOpen);
    });
  });
}

/* ── Main poll ───────────────────────────────────────── */
async function poll() {
  const now    = Date.now();
  const needVods = now - _vodLoadedAt > VOD_TTL;
  const tasks  = [fetchPaths()];
  if (needVods) tasks.push(loadVodData());
  const [paths] = await Promise.all(tasks);
  if (needVods) renderVodsRow();
  lastPaths    = paths;
  const liveSet = getLiveSet(paths);
  const live    = STREAMERS.filter(s => liveSet.has(s.key));
  const offline = STREAMERS.filter(s => !liveSet.has(s.key));
  const total   = STREAMERS.length;

  // Attach viewer counts to live streamers for ticker
  const liveWithViewers = live.map(s => ({ ...s, _viewers: getViewers(paths, s.key) }));

  document.getElementById('liveCountEl').textContent = live.length;
  document.getElementById('totalCountEl').textContent = total;

  // Sidebar + Drawer
  renderSidebar(live, offline, paths);
  renderDrawer(live, offline, paths);

  // Live section + channel grid
  renderLiveSection(live, paths);
  renderChannelGrid(paths);

  // Featured player
  if (live.length > 0) {
    if (featuredKey === undefined || featuredKey === null || !liveSet.has(featuredKey)) {
      clearInterval(rotateTimer);
      rotateTimer = null;
      startRotation(live, paths);
    } else {
      statsBase.viewers = getViewers(paths, featuredKey);
      const vEl = document.getElementById('featuredViewersMeta');
      if (vEl) vEl.textContent = statsBase.viewers;
    }
  } else {
    if (featuredKey !== null) {
      clearInterval(rotateTimer);
      rotateTimer = null;
      setFeaturedOffline();
    }
  }
}

/* ── Reels strip ─────────────────────────────────────── */
async function loadReelsStrip() {
  try {
    const res  = await fetch(`${PB_URL}/api/collections/reels/records?filter=${encodeURIComponent('public=true')}&sort=-date&perPage=6`);
    const data = await res.json();
    const items = data.items || [];
    if (!items.length) return;
    const strip = document.getElementById('reelsStrip');
    const track = document.getElementById('reelsTrack');
    items.forEach(r => {
      const dur   = r.duration ? `${r.duration}s` : '';
      const thumb = r.thumb ? `background-image:url('${r.thumb}')` : '';
      const a = document.createElement('a');
      a.className = 'reel-card';
      a.href = `/reels/?start=${r.id}`;
      a.innerHTML = `
        <div class="reel-card-thumb" style="${thumb}">
          <div class="reel-card-play"><i class="fa-solid fa-play"></i></div>
          ${dur ? `<div class="reel-card-dur">${dur}</div>` : ''}
        </div>
        <div class="reel-card-info">
          <div class="reel-card-ch">${r.channel.toUpperCase()}</div>
        </div>`;
      track.appendChild(a);
    });
    strip.style.display = '';
  } catch {}
}

/* ── Init ────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', async () => {
  initFooter();
  loadVersion();

  document.getElementById('menuBtn').addEventListener('click', openDrawer);
  document.getElementById('drawerClose').addEventListener('click', window.closeDrawer);
  document.getElementById('drawerOverlay').addEventListener('click', window.closeDrawer);
  document.getElementById('themeBtn').addEventListener('click', toggleTheme);
  document.getElementById('themeBtnDrawer').addEventListener('click', toggleTheme);

  // Sidebar collapse
  const sidebar = document.getElementById('leftSidebar');
  const pageRight = sidebar?.nextElementSibling;
  const savedCollapsed = localStorage.getItem('corillo-sidebar') === 'collapsed';
  if (savedCollapsed) sidebar?.classList.add('collapsed');
  document.getElementById('sidebarToggle')?.addEventListener('click', () => {
    const collapsed = sidebar.classList.toggle('collapsed');
    localStorage.setItem('corillo-sidebar', collapsed ? 'collapsed' : 'open');
  });

  // Search
  const searchInput = document.getElementById('searchInput');
  const searchClear = document.getElementById('searchClear');
  searchInput?.addEventListener('input', e => {
    searchQuery = e.target.value.trim().toLowerCase();
    searchClear.style.display = searchQuery ? '' : 'none';
    renderChannelGrid(lastPaths);
  });
  searchClear?.addEventListener('click', () => {
    searchInput.value = '';
    searchQuery = '';
    searchClear.style.display = 'none';
    searchInput.focus();
    renderChannelGrid(lastPaths);
  });
  if (searchClear) searchClear.style.display = 'none';

  // Patch STREAMERS names + avatars from PocketBase before first render
  const activeStreamers = STREAMERS.filter(s => !s.soon);
  try {
    const results = await Promise.allSettled(
      activeStreamers.map(s =>
        fetch('/chat-api/profile/' + s.key, { signal: AbortSignal.timeout(4000) })
          .then(r => r.ok ? r.json() : null)
      )
    );
    results.forEach((res, i) => {
      if (res.status === 'fulfilled' && res.value) {
        if (res.value.display_name) activeStreamers[i].name = res.value.display_name;
        if (res.value.avatar_url)   activeStreamers[i].avatar_url = res.value.avatar_url;
      }
    });
  } catch {}

  await poll();

  loadDigest();
  loadReelsStrip();

  setInterval(poll, POLL_MS);

  // Refresh live thumbnails every 60s without full re-render
  setInterval(() => {
    const t = Math.floor(Date.now() / 60000);
    document.querySelectorAll('.ch-thumb-img').forEach(img => {
      img.src = img.src.replace(/\?t=\d+/, `?t=${t}`);
    });
  }, 60000);

  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) { cache.t = 0; poll(); }
  });
});
</script>

