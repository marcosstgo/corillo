---
<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>CORILLO — Stream Platform</title>
  <meta name="description" content="Plataforma de streaming independiente desde Puerto Rico. Sin algoritmos, sin baneos." />
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://corillo.live/">
  <meta property="og:title" content="CORILLO — Stream Platform">
  <meta property="og:description" content="Plataforma de streaming independiente desde Puerto Rico. Sin algoritmos, sin baneos arbitrarios. Solo tú, tu setup y tu audiencia.">
  <meta property="og:image" content="https://corillo.live/assets/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="es_PR">
  <meta property="og:site_name" content="CORILLO">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="https://corillo.live/">
  <meta name="twitter:title" content="CORILLO — Stream Platform">
  <meta name="twitter:description" content="Plataforma de streaming independiente desde Puerto Rico. Sin algoritmos, sin baneos arbitrarios.">
  <meta name="twitter:image" content="https://corillo.live/assets/og-image.png">
  <meta name="twitter:image:alt" content="CORILLO — plataforma de streaming desde Puerto Rico">
  <link rel="manifest" href="/manifest.json">
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png">
  <meta name="theme-color" content="#030a0e">
<link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <script src="https://cdn.jsdelivr.net/npm/hls.js@1.5.18/dist/hls.min.js" is:inline></script>
  <script src="/assets/streamers.js" is:inline></script>
  <link rel="stylesheet" href="/assets/corillo.css">
  <script>
    (function(){
      const t = localStorage.getItem('corillo-theme');
      if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
  <style is:global>
    :root { --dim: #1a3040; }
    html,body{overflow-x:hidden}
    body{font-size:15px;line-height:1.6;min-height:100vh}

    /* ── NAV ── */
    nav{position:sticky;top:0;z-index:100;height:52px;display:flex;align-items:center;padding:0 32px;background:rgba(3,10,14,.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--crl-border);gap:24px}
    .nav-logo{display:flex;align-items:center}
    .nav-logo svg{height:36px;width:auto}
    .nav-spacer{flex:1}
    .nav-live{display:none;align-items:center;gap:7px;font-family:var(--crl-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--crl-live);background:rgba(232,200,74,.07);border:1px solid rgba(232,200,74,.3);padding:4px 10px 4px 8px;border-radius:999px}
    .live-dot{width:7px;height:7px;border-radius:50%;background:var(--crl-live);box-shadow:0 0 8px rgba(232,200,74,.6);animation:crl-blink 1.4s infinite;flex-shrink:0}
    .nav-btn{font-family:var(--crl-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:7px 16px;border-radius:6px;border:1px solid var(--crl-border);background:transparent;color:rgba(232,246,255,.4);cursor:pointer;transition:.15s}
    .nav-btn:hover{border-color:var(--crl-border-h);color:var(--crl-white)}
    .nav-btn.solid{background:var(--crl-accent);color:#030a0e;border-color:transparent;font-weight:700}
    .nav-btn.solid:hover{opacity:.88;box-shadow:0 0 28px rgba(0,191,255,.45)}
    .nav-menu-btn{display:none;width:32px;height:32px;border-radius:6px;border:1px solid var(--crl-border);background:transparent;color:var(--crl-muted);cursor:pointer;align-items:center;justify-content:center;font-size:.85rem;transition:.15s}
    .nav-menu-btn:hover{border-color:var(--crl-border-h);color:var(--crl-white)}
    .nav-theme-btn{width:32px;height:32px;padding:0;display:inline-flex;align-items:center;justify-content:center;font-size:.85rem;letter-spacing:0}
    .drawer-tools{display:flex;align-items:center;gap:8px}
    [data-theme="light"] nav{background:rgba(240,239,233,.96)}
    [data-theme="light"] .nav-btn{color:rgba(5,16,21,.74)}
    [data-theme="light"] .nav-btn:hover{color:#0c1a20;background:rgba(0,0,0,.05)}
    [data-theme="light"] .nav-btn.solid{color:#030a0e;background:var(--crl-accent);border-color:transparent}
    [data-theme="light"] .nav-btn.solid:hover{color:#030a0e;background:#35d3ff;opacity:1;box-shadow:0 0 28px rgba(0,191,255,.28)}
    [data-theme="light"] .nav-menu-btn{color:rgba(5,16,21,.62)}
    [data-theme="light"] .nav-menu-btn:hover{color:#0c1a20;background:rgba(0,0,0,.05)}
    [data-theme="light"] .drawer{background:#f0efe9}
    [data-theme="light"] .nav-link{color:rgba(5,16,21,.72)}
    [data-theme="light"] .nav-link i{color:rgba(5,16,21,.42)}
    [data-theme="light"] .nav-link:hover{color:#0c1a20;background:rgba(0,0,0,.05)}
    [data-theme="light"] .nav-link:hover i{color:var(--crl-accent)}
    [data-theme="light"] .sidebar-nav-link{color:rgba(5,16,21,.68)}
    [data-theme="light"] .sidebar-nav-link i{color:rgba(5,16,21,.4)}
    [data-theme="light"] .sidebar-nav-link:hover{color:#0c1a20;background:rgba(0,0,0,.04)}
    [data-theme="light"] .sidebar-nav-link:hover i{color:var(--crl-accent)}
    [data-theme="light"] .sidebar-show-all{color:rgba(5,16,21,.44)}
    [data-theme="light"] .site-footer{background:#e8edf0}
    [data-theme="light"] .foot-brand svg .crl-brand-word{fill:#0c1a20}
    [data-theme="light"] .foot-brand svg .crl-brand-ring-outer{stroke:#0c1a20}
    [data-theme="light"] .foot-tagline{color:rgba(0,0,0,.34)}
    [data-theme="light"] .foot-col-title{color:#0c1a20}
    [data-theme="light"] .foot-chev{color:rgba(0,0,0,.35)}
    [data-theme="light"] .foot-copy{color:rgba(0,0,0,.34)}
    [data-theme="light"] .foot-version{color:rgba(0,0,0,.28)}
    [data-theme="light"] .foot-social{color:rgba(0,0,0,.42)}
    [data-theme="light"] .foot-social:hover{color:#0c1a20}
    [data-theme="light"] .aside-mobile-icon{color:rgba(5,16,21,.42)}
    [data-theme="light"] .aside-mobile-icon:hover{color:#0c1a20}
    [data-theme="light"] .aside-mobile-sep{border-color:rgba(0,0,0,.1)}
    [data-theme="light"] .featured-name{color:#fff}
    [data-theme="light"] .featured-sub{color:rgba(255,255,255,.62)}
    [data-theme="light"] .featured-viewers{color:rgba(255,255,255,.7);background:rgba(3,10,14,.72)}
    [data-theme="light"] .featured-actions .nav-btn{color:rgba(255,255,255,.88);border-color:rgba(255,255,255,.18);background:rgba(3,10,14,.38)}
    [data-theme="light"] .featured-actions .nav-btn:hover{color:#fff;border-color:rgba(255,255,255,.3);background:rgba(3,10,14,.62)}
    [data-theme="light"] .featured-actions .nav-btn.solid{color:#030a0e;background:var(--crl-accent);border-color:transparent}
    [data-theme="light"] .featured-actions .nav-btn.solid:hover{color:#030a0e;background:#35d3ff;opacity:1;box-shadow:0 0 28px rgba(0,191,255,.32)}

    /* ── LAYOUT ── */
    .layout{display:grid;grid-template-columns:220px 1fr;min-height:calc(100vh - 52px)}

    /* ── SIDEBAR ── */
    aside{border-right:1px solid var(--crl-border);padding:24px 0;position:sticky;top:52px;height:calc(100vh - 52px);overflow-y:auto;scrollbar-width:none;display:flex;flex-direction:column}
    aside::-webkit-scrollbar{display:none}
    .aside-section{margin-bottom:8px}
    .aside-label{font-family:var(--crl-mono);font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--crl-muted);padding:0 20px 10px}
    .channel-row{display:flex;align-items:center;gap:10px;padding:8px 20px;cursor:pointer;transition:background .15s;position:relative;color:inherit}
    .channel-row:hover{background:rgba(0,191,255,.04)}
    .channel-row.active{background:rgba(0,191,255,.08)}
    .channel-row.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--crl-accent);box-shadow:0 0 8px rgba(0,191,255,.5)}
    .ch-ava{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--crl-display);font-size:15px;color:#000}
    .channel-row.is-live .ch-ava{box-shadow:0 0 0 2px var(--crl-live),0 0 10px rgba(232,200,74,.25)}
    .ch-info{flex:1;min-width:0}
    .ch-name{font-family:var(--crl-mono);font-size:11px;font-weight:700;letter-spacing:.5px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
    .ch-status{font-size:11px;color:var(--crl-muted);margin-top:1px}
    .ch-status.live{color:var(--crl-live)}
    .ch-viewers{font-family:var(--crl-mono);font-size:10px;color:var(--crl-muted);flex-shrink:0}
    [data-theme="light"] .ch-name{color:#0c1a20}
    [data-theme="light"] .ch-status{color:rgba(5,16,21,.46)}
    [data-theme="light"] .ch-status.live{color:var(--crl-live)}
    [data-theme="light"] .ch-viewers{color:rgba(5,16,21,.44)}
    .live-pip{width:6px;height:6px;border-radius:50%;background:var(--crl-live);flex-shrink:0;box-shadow:0 0 8px rgba(232,200,74,.7)}
    .aside-divider{border:none;border-top:1px solid var(--crl-border);margin:12px 0}
    .aside-footer{margin-top:auto;padding:16px 20px;font-family:var(--crl-mono);font-size:9px;letter-spacing:1.5px;color:var(--dim);text-transform:uppercase;line-height:1.8}
    .aside-mobile-icons,.aside-mobile-sep{display:none}

    /* ── FEATURED ── */
    main{padding:0;overflow:hidden}
    .featured-wrap{position:relative;background:#000;aspect-ratio:16/7;overflow:hidden;cursor:pointer}
    .featured-bg{position:absolute;inset:0;background:linear-gradient(135deg,#020b12 0%,#061520 50%,#020d18 100%)}
    .featured-bg::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(0,191,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(0,191,255,.035) 1px,transparent 1px);background-size:40px 40px;pointer-events:none}
    .glow-a,.glow-b{position:absolute;inset:0;pointer-events:none;transition:opacity 1.1s ease}
    .glow-b{opacity:0}
    .featured-letter{position:absolute;right:-10px;bottom:-50px;font-family:var(--crl-display);font-size:min(28rem,44vw);line-height:1;letter-spacing:-8px;color:rgba(255,255,255,.016);pointer-events:none;user-select:none;transition:opacity .5s ease}
    .featured-letter.out{opacity:0}
    .featured-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:none}
    .featured-wrap.playing .featured-video{display:block}
    .featured-wrap.playing .featured-bg{opacity:0}
    .featured-wrap.playing .featured-offline{opacity:0;pointer-events:none}
    .featured-offline{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity .3s}
    .featured-offline-icon{width:64px;height:64px;border-radius:50%;border:1px solid rgba(0,191,255,.15);display:flex;align-items:center;justify-content:center;color:var(--crl-muted);font-size:1.4rem}
    .featured-offline p{font-family:var(--crl-mono);font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--crl-muted)}
    .featured-viewers{position:absolute;top:20px;right:24px;display:none;align-items:center;gap:7px;font-family:var(--crl-mono);font-size:11px;background:rgba(3,10,14,.75);backdrop-filter:blur(8px);border:1px solid var(--crl-border);padding:5px 12px;border-radius:4px;color:rgba(232,246,255,.6)}
    .featured-wrap.playing .featured-viewers{display:flex}
    .featured-overlay{position:absolute;inset:0;padding:32px 32px 24px;background:linear-gradient(to right,rgba(3,10,14,.95) 0%,rgba(3,10,14,.78) 30%,rgba(3,10,14,.18) 60%,transparent 78%),linear-gradient(to top,rgba(3,10,14,.88) 0%,rgba(3,10,14,.35) 35%,transparent 62%);display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-end;gap:14px;opacity:0;transition:opacity .25s;pointer-events:none}
    .featured-wrap:not(.playing) .featured-overlay{opacity:1;pointer-events:all}
    .featured-wrap.playing .featured-overlay{opacity:1;pointer-events:all}
    #featuredContent{transition:opacity .38s ease,transform .38s ease;display:contents}
    #featuredContent.out{opacity:0;transform:translateY(10px)}
    .featured-live-tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--crl-mono);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;background:var(--crl-live);color:#030a0e;padding:3px 10px;border-radius:3px;margin-bottom:10px}
    .featured-name{font-family:var(--crl-display);font-size:clamp(2.5rem,5vw,4.5rem);letter-spacing:3px;line-height:.9;color:var(--crl-white)}
    .featured-name span{color:var(--crl-accent);text-shadow:0 0 30px rgba(0,191,255,.4)}
    .featured-sub{font-family:var(--crl-mono);font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--crl-muted);margin-top:8px}
    .featured-actions{display:flex;gap:10px;transition:opacity .38s ease,transform .38s ease}
    .featured-actions.out{opacity:0;transform:translateY(10px)}
    .rotate-bar{position:absolute;bottom:0;left:0;height:2px;background:var(--crl-accent);opacity:.5;width:0;transition:none}

    /* ── CONTENT ── */
    .content-section{padding:32px}
    .section-header{display:flex;align-items:center;gap:12px;margin-bottom:20px}
    .section-header h2{font-family:var(--crl-display);font-size:1.6rem;letter-spacing:3px;color:var(--crl-white);line-height:1}
    .section-count{font-family:var(--crl-mono);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--crl-muted)}
    .section-line{flex:1;height:1px;background:var(--crl-border)}
    .live-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
    .cards-carousel{grid-column:1/-1;display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .vods-row-header{grid-column:1/-1}
    .no-live-msg{grid-column:1/-1;display:flex;flex-direction:column;align-items:center;padding:48px 24px;gap:12px;border:1px dashed var(--crl-border);border-radius:8px;color:var(--crl-muted);font-family:var(--crl-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase}
    .stream-card{border-radius:8px;overflow:hidden;border:1px solid var(--crl-border);background:var(--crl-surface);cursor:pointer;transition:transform .18s,border-color .18s,box-shadow .18s;display:block;color:inherit}
    .stream-card:hover{transform:translateY(-3px);border-color:rgba(0,191,255,.3);box-shadow:0 12px 40px rgba(0,0,0,.5),0 0 0 1px rgba(0,191,255,.07)}
    .stream-thumb{aspect-ratio:16/9;position:relative;overflow:hidden;background:linear-gradient(135deg,#071118,#0d1c28)}
    .stream-thumb-inner{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
    .stream-thumb-letter{font-family:var(--crl-display);font-size:3.5rem;letter-spacing:4px;color:rgba(0,191,255,.06)}
    .stream-thumb-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transform:scale(1.35);}
    .stream-thumb-preview{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity .3s;pointer-events:none;}
    .stream-card:hover .stream-thumb-preview{opacity:1;}
    .stream-live-tag{position:absolute;top:8px;left:8px;display:flex;align-items:center;gap:5px;font-family:var(--crl-mono);font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;background:var(--crl-live);color:#030a0e;padding:3px 8px;border-radius:3px}
    .stream-viewers{position:absolute;top:8px;right:8px;font-family:var(--crl-mono);font-size:10px;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);color:rgba(232,246,255,.7);padding:3px 8px;border-radius:3px;display:flex;align-items:center;gap:5px}
    .stream-body{padding:10px 12px;display:flex;align-items:center;gap:10px}
    .stream-card-ava{width:34px;height:34px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:var(--crl-display);font-size:16px;color:rgba(0,0,0,.8);align-self:flex-start;margin-top:2px;position:relative;overflow:hidden}
    .stream-card-ava.is-live{box-shadow:0 0 0 2px var(--crl-live),0 0 10px rgba(0,255,157,.2)}
    .stream-card-ava img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%}
    .stream-card-info{flex:1;min-width:0}
    .stream-name{font-family:var(--crl-mono);font-size:12px;font-weight:700;letter-spacing:1px;margin-bottom:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
    .stream-desc{font-size:11px;color:var(--crl-muted);overflow:hidden;white-space:nowrap;text-overflow:ellipsis}

    /* ── FEATURED VOD EMPTY STATE ── */
    .featured-vod-thumb{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity .6s;pointer-events:none}
    .featured-vod-thumb.show{opacity:.4}
    .featured-wrap.playing .featured-vod-thumb{opacity:0!important}
    .featured-wrap.vod-preview-mode .featured-video{display:block}
    .featured-wrap.vod-preview-mode .featured-bg{opacity:0}
    .featured-wrap.vod-preview-mode .featured-offline{opacity:0;pointer-events:none}
    .featured-wrap.vod-preview-mode .featured-overlay{opacity:1;pointer-events:all}
    .featured-vod-tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--crl-mono);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;background:rgba(13,28,40,.8);color:rgba(232,246,255,.5);border:1px solid var(--crl-border);padding:3px 10px;border-radius:3px;margin-bottom:10px}

    /* ── VOD CARDS EN GRID ── */
    .vod-duration{position:absolute;bottom:6px;right:8px;font-family:var(--crl-mono);font-size:10px;background:rgba(0,0,0,.75);backdrop-filter:blur(4px);color:rgba(232,246,255,.8);padding:2px 7px;border-radius:3px}
    .vods-row-header{grid-column:1/-1;display:flex;align-items:center;gap:12px}
    .vods-row-header span{font-family:var(--crl-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--crl-muted)}
    .vods-row-header .section-line{flex:1}
    .vods-row-header a{font-family:var(--crl-mono);font-size:10px;letter-spacing:1px;color:var(--crl-accent);white-space:nowrap;transition:.15s}
    .vods-row-header a:hover{opacity:.75}

    /* ── OFFLINE FEATURED SLIDER ── */
    .offline-slider-wrap{grid-column:1/-1}
    .offline-sl-hd{display:flex;align-items:center;gap:12px;margin-bottom:14px}
    .offline-sl-hd span{font-family:var(--crl-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--crl-muted)}
    .offline-sl-hd a{font-family:var(--crl-mono);font-size:10px;color:var(--crl-accent);white-space:nowrap;transition:.15s}
    .offline-sl-hd a:hover{opacity:.75}
    .offline-stage{position:relative;aspect-ratio:16/9;border-radius:10px;overflow:hidden;background:var(--crl-surface);border:1px solid var(--crl-border);cursor:pointer}
    .offline-slide{position:absolute;inset:0;opacity:0;transition:opacity .5s ease;pointer-events:none;text-decoration:none;color:inherit;display:block}
    .offline-slide.active{opacity:1;pointer-events:auto;z-index:1}
    .offline-slide-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-color:var(--crl-surface)}
    .offline-slide-grad{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.9) 0%,rgba(0,0,0,.15) 55%,transparent 100%)}
    .offline-slide-info{position:absolute;bottom:0;left:0;right:0;padding:20px 20px 16px}
    .offline-slide-tag{display:inline-flex;align-items:center;gap:5px;font-family:var(--crl-mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;background:rgba(0,0,0,.55);border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);padding:3px 8px;border-radius:3px;margin-bottom:8px}
    .offline-slide-name{font-family:var(--crl-display);font-size:clamp(1.8rem,5vw,2.8rem);letter-spacing:2px;color:#fff;line-height:1}
    .offline-slide-meta{font-family:var(--crl-mono);font-size:10px;letter-spacing:1px;color:rgba(255,255,255,.45);margin-top:6px}
    .offline-bar-wrap{position:absolute;bottom:0;left:0;right:0;height:2px;background:rgba(255,255,255,.08);z-index:2}
    .offline-bar{height:100%;background:var(--crl-accent);width:0%;opacity:.7}
    .offline-dots{display:flex;justify-content:center;gap:6px;margin-top:10px}
    .offline-dot{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.18);border:none;padding:0;cursor:pointer;transition:background .2s,transform .2s;flex-shrink:0}
    .offline-dot.active{background:var(--crl-accent);transform:scale(1.4)}

    /* ── REELS STRIP ── */
    .reels-strip{padding:0 32px 40px;margin-top:-21px}
    .reels-strip-hd{display:flex;align-items:center;gap:12px;margin-bottom:14px}
    .reels-strip-hd span{font-family:var(--crl-mono);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--crl-muted)}
    .reels-strip-hd .section-line{flex:1}
    .reels-strip-hd a{font-family:var(--crl-mono);font-size:10px;color:var(--crl-accent);white-space:nowrap;transition:.15s}
    .reels-strip-hd a:hover{opacity:.75}
    .reels-strip-track{display:flex;gap:10px;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;padding-bottom:4px}
    .reels-strip-track::-webkit-scrollbar{display:none}
    .reel-card{flex-shrink:0;width:110px;border-radius:8px;overflow:hidden;background:var(--crl-surface);border:1px solid var(--crl-border);text-decoration:none;color:inherit;transition:transform .18s,border-color .18s}
    .reel-card:hover{transform:translateY(-3px);border-color:rgba(0,191,255,.3)}
    .reel-card-thumb{aspect-ratio:9/16;position:relative;background:linear-gradient(135deg,var(--crl-surface),var(--crl-panel));background-size:cover;background-position:center}
    .reel-card-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.35)}
    .reel-card-play i{font-size:1.4rem;color:rgba(255,255,255,.7)}
    .reel-card-dur{position:absolute;bottom:6px;right:6px;font-family:var(--crl-mono);font-size:9px;background:rgba(0,0,0,.72);backdrop-filter:blur(4px);color:rgba(232,246,255,.8);padding:2px 6px;border-radius:3px}
    .reel-card-info{padding:7px 8px}
    .reel-card-ch{font-family:var(--crl-mono);font-size:10px;font-weight:700;letter-spacing:.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    /* ── DRAWER ── */
    .drawer-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.6);backdrop-filter:blur(4px)}
    .drawer-overlay.open{display:block}
    .drawer{position:fixed;top:0;left:0;bottom:0;z-index:201;width:260px;background:var(--crl-surface);border-right:1px solid var(--crl-border);display:flex;flex-direction:column;transform:translateX(-100%);transition:transform .25s cubic-bezier(.4,0,.2,1)}
    .drawer.open{transform:translateX(0)}
    .drawer-header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--crl-border);flex-shrink:0}
    .drawer-close{width:30px;height:30px;border-radius:6px;border:1px solid var(--crl-border);background:transparent;color:var(--crl-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85rem;transition:.15s}
    .drawer-close:hover{color:var(--crl-white);border-color:var(--crl-border-h)}
    .drawer-body{flex:1;overflow-y:auto;scrollbar-width:none;padding:16px 0}
    .drawer-body::-webkit-scrollbar{display:none}
    .nav-link{display:flex;align-items:center;gap:10px;padding:9px 20px;font-family:var(--crl-mono);font-size:11px;letter-spacing:.5px;color:rgba(232,246,255,.55);transition:.15s;border-radius:0}
    .nav-link i{width:14px;text-align:center;font-size:.75rem;color:var(--crl-muted)}
    .nav-link:hover{color:var(--crl-white);background:rgba(0,191,255,.05)}
    .nav-link:hover i{color:var(--crl-accent)}
    .aside-nav{padding:8px 0}
    .sidebar-nav-link{display:flex;align-items:center;gap:10px;padding:8px 20px;font-family:var(--crl-mono);font-size:12px;letter-spacing:.5px;color:rgba(232,246,255,.45);transition:.15s}
    .sidebar-nav-link i{width:12px;text-align:center;font-size:.7rem;color:var(--crl-muted)}
    .sidebar-nav-link:hover{color:var(--crl-white);background:rgba(0,191,255,.04)}
    .sidebar-nav-link:hover i{color:var(--crl-accent)}
    .sidebar-show-all{display:block;width:100%;padding:8px 20px;background:transparent;border:none;color:rgba(232,246,255,.35);font-family:var(--crl-mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;text-align:left;transition:.15s;gap:8px}
    .sidebar-show-all:hover{color:var(--crl-accent)}
    .rdot{display:inline-flex;align-items:center;justify-content:center;width:14px;flex-shrink:0}
    .rdot::before{content:'';display:block;width:7px;height:7px;border-radius:50%;background:var(--crl-accent);animation:crl-blink 1.8s ease-in-out infinite}

    /* ── FOOTER ── */
    .site-footer{border-top:1px solid var(--crl-border);padding:48px 32px 28px;margin-top:16px;background:var(--crl-panel);position:relative;overflow:hidden}
    .site-footer::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 40% at 50% 0%,rgba(0,191,255,.06),transparent);pointer-events:none}
    .foot-top{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
    @media(max-width:900px){.foot-top{grid-template-columns:1fr 1fr;gap:32px}}
    @media(max-width:520px){.foot-top{grid-template-columns:1fr}}
    .foot-brand{display:flex;align-items:center;gap:8px;margin-bottom:14px}
    .foot-brand svg{height:28px;width:auto;opacity:.75}
    .foot-tagline{font-family:var(--crl-mono);font-size:9px;letter-spacing:1.5px;color:rgba(255,255,255,.25);text-transform:uppercase;line-height:1.8}
    .foot-col-title{display:flex;align-items:center;gap:7px;font-family:var(--crl-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--crl-white);margin-bottom:14px;font-weight:700}
    .foot-col-links{display:flex;flex-direction:column;gap:9px}
    .foot-col-links>div{display:flex;flex-direction:column;gap:9px}
    .foot-col-links a{font-size:var(--crl-sm);color:rgba(255,255,255,.4);transition:.15s;text-decoration:none}
    .foot-col-links a:hover{color:var(--crl-white)}
    [data-theme="light"] .foot-col-links a{color:rgba(0,0,0,.4)}
    [data-theme="light"] .foot-col-links a:hover{color:rgba(0,0,0,.85)}
    .foot-chev{margin-left:auto;font-size:10px;color:var(--crl-muted);transition:transform .25s;display:none}
    @media(max-width:520px){
      .foot-chev{display:block}
      .foot-col-title{cursor:pointer;user-select:none;margin-bottom:0;padding:12px 0;border-bottom:1px solid var(--crl-border)}
      .foot-col-title[aria-expanded="true"]{color:var(--crl-accent);border-color:transparent}
      .foot-col-title[aria-expanded="true"] .foot-chev{transform:rotate(180deg);color:var(--crl-accent)}
      .foot-top > div:not(:first-child){border-top:1px solid var(--crl-border)}
      .foot-col-links{display:grid;grid-template-rows:0fr;transition:grid-template-rows .25s ease;overflow:hidden;gap:0}
      .foot-col-links.open{grid-template-rows:1fr}
      .foot-col-links > div{overflow:hidden;display:flex;flex-direction:column;gap:9px}
      .foot-col-links.open > div{padding:14px 0}
    }
    .foot-bottom{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;padding-top:24px;border-top:1px solid var(--crl-border)}
    .foot-copy{font-family:var(--crl-mono);font-size:9px;letter-spacing:1px;color:rgba(255,255,255,.18);text-transform:uppercase}
    .foot-credits{display:flex;align-items:center;justify-content:center;gap:8px;padding-top:18px;font-family:var(--crl-mono);font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.18)}
    .foot-credits-icon{display:inline-block;animation:crl-bounce 2.2s ease-in-out infinite}
    .foot-credits-icon--ai{animation-delay:.7s}
    .foot-credits-sep{opacity:.4}
    .foot-credits-link{color:rgba(255,255,255,.28);text-decoration:none;transition:color .2s}
    .foot-credits-link:hover{color:var(--crl-accent)}
    [data-theme="light"] .foot-credits{color:rgba(0,0,0,.22)}
    [data-theme="light"] .foot-credits-link{color:rgba(0,0,0,.32)}
    [data-theme="light"] .foot-credits-link:hover{color:var(--crl-accent)}
    .foot-socials{display:flex;align-items:center;gap:4px}
    .foot-social{width:32px;height:32px;border-radius:8px;border:1px solid var(--crl-border);display:inline-flex;align-items:center;justify-content:center;color:rgba(255,255,255,.35);font-size:.85rem;transition:.15s;text-decoration:none}
    .foot-social:hover{border-color:var(--crl-border-h);color:var(--crl-white)}
    .foot-version{font-family:var(--crl-mono);font-size:9px;color:rgba(255,255,255,.15)}

    /* ── RESPONSIVE ── */
    @media(max-width:1100px){.live-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:820px){
      .layout{grid-template-columns:44px 1fr}
      aside{width:44px;padding:8px 0;overflow:hidden}
      .aside-nav,.aside-label,.aside-footer,.sidebar-show-all{display:none}
      aside .ch-info,aside .ch-viewers,aside .live-pip{display:none}
      #sidebarDivider{display:none!important}
      .aside-divider{display:none}
      aside .channel-row{padding:5px;justify-content:center}
      aside .ch-ava{width:32px;height:32px;font-size:13px;flex-shrink:0}
      aside .channel-row:not(.is-live) .ch-ava{opacity:.28}
      .aside-mobile-icons{display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 0}
      .aside-mobile-icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:8px;color:rgba(255,255,255,.38);font-size:1.05rem;transition:.15s;text-decoration:none}
      .aside-mobile-icon:hover{color:var(--crl-white)}
      .aside-mobile-sep{border:none;border-top:1px solid var(--crl-border);margin:6px 8px}
      .nav-menu-btn{display:flex}
      .featured-wrap{aspect-ratio:16/9}
    }
    @media(max-width:600px){nav{padding:0 12px;gap:8px}.nav-live{font-size:9px;padding:3px 7px 3px 6px;letter-spacing:1px;white-space:nowrap}.nav-btn{font-size:9px;padding:5px 10px;letter-spacing:1px;white-space:nowrap}.content-section{padding:20px 16px}.featured-overlay{padding:24px 16px 16px}.reels-strip{padding:0 16px 32px}
      .live-grid{display:flex;flex-direction:column;gap:0;margin-bottom:40px}
      .cards-carousel .stream-card{flex:0 0 72vw;scroll-snap-align:start}
      .live-grid .vods-row-header{grid-column:unset;margin-top:16px;margin-bottom:12px}
      .cards-carousel{display:flex;flex-direction:row;overflow-x:auto;scroll-snap-type:x mandatory;gap:12px;padding-bottom:8px;scrollbar-width:none}
      .cards-carousel::-webkit-scrollbar{display:none}
    }
  </style>
</head>
