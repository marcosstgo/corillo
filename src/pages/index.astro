<script>
const POLL_MS     = 15000;
const API_TIMEOUT = 5000;
const CACHE_MS    = 8000;
const ROTATE_MS   = 4000;
const PB_URL      = 'https://pb.corillo.live';
const VOD_TTL     = 120000;

let cache: { t: number; data: any[] | null } = { t: 0, data: null };
let hlsInstance: any = null;
let featuredKey: string | null = null;
let pollTimer: ReturnType<typeof setInterval> | null = null;
let rotateTimer: ReturnType<typeof setInterval> | null = null;
let rafId: number | null = null;
let rotateStart: number | null = null;
let livePlayers: string[] = [];
let rotateIdx   = 0;
let lastPaths: any[]   = [];
let glowActive  = 'a';
let prevLiveKeys: string | null = null;

let _recentVods: any[]       = [];
let _lastVodByChannel: Record<string, string> = {};
let _vodLoadedAt       = 0;
let vodRotateIdx       = 0;
let vodRotateTimer: ReturnType<typeof setInterval> | null = null;

let _sliderIdx   = 0;
let _sliderTimer: ReturnType<typeof setTimeout> | null = null;
let _gridState: string | null = null;
const SLIDE_INTERVAL = 60000;
let vodInitialized     = false;

async function fetchPaths() {
  const now = Date.now();
  if (cache.data && now - cache.t < CACHE_MS) return cache.data;
  const ctrl = new AbortController();
  const tid  = setTimeout(() => ctrl.abort(), API_TIMEOUT);
  try {
    const r = await fetch('/mediamtx-api/v3/paths/list', { signal: ctrl.signal });
    clearTimeout(tid);
    const j = await r.json();
    cache = { t: now, data: j.items || [] };
  } catch {
    clearTimeout(tid as any);
    if (!cache.data) cache.data = [];
  }
  return cache.data!;
}

function getLiveSet(paths: any[]) {
  const s = new Set<string>();
  for (const p of paths) {
    if (!p.ready) continue;
    const m = p.name.match(/^live\/(.+)$/);
    if (m) s.add(m[1]);
  }
  return s;
}

function getViewers(paths: any[], key: string) {
  const p = paths.find((p: any) => p.name === 'live/' + key);
  return p ? (p.readers?.length ?? 0) : 0;
}

async function fetchRecentVods(limit: number) {
  try {
    const r = await fetch(
      `${PB_URL}/api/collections/vods/records?sort=-date&perPage=${limit}&fields=id,channel,filename,thumb,preview,duration,date`,
      { signal: AbortSignal.timeout(5000) }
    );
    return (await r.json()).items || [];
  } catch { return []; }
}

async function loadVodData() {
  const vods = await fetchRecentVods(30);
  const _seen = new Set<string>();
  _recentVods = vods.filter((v: any) => {
    if (_seen.has(v.channel)) return false;
    _seen.add(v.channel);
    return true;
  }).slice(0, 6);
  _lastVodByChannel = {};
  for (const v of vods) {
    if (!_lastVodByChannel[v.channel]) _lastVodByChannel[v.channel] = v.date;
  }
  _vodLoadedAt = Date.now();
}

function fmtDuration(s: number) {
  if (!s) return '';
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  return h > 0
    ? `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`
    : `${m}:${String(sec).padStart(2,'0')}`;
}

function relativeTime(dateStr: string) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 2)  return 'Hace un momento';
  if (mins < 60) return `Hace ${mins}m`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24)  return `Hace ${hrs}h`;
  const days = Math.floor(hrs / 24);
  if (days === 1) return 'Ayer';
  if (days < 7)  return `Hace ${days} días`;
  return `Hace ${Math.floor(days / 7)} sem`;
}

function applyVodContent(vod: any) {
  const vid  = document.getElementById('featuredVideo') as HTMLVideoElement;
  const wrap = document.getElementById('featuredWrap')!;
  const s    = ((window as any).STREAMERS || []).find((x: any) => x.key === vod.channel) || { name: vod.channel.toUpperCase(), color: '' };
  setGlow(s.color);
  document.getElementById('featuredLetter')!.textContent = s.name.charAt(0);
  document.getElementById('featuredInfo')!.innerHTML = `
    <div class="featured-vod-tag"><i class="fa-solid fa-film" style="font-size:8px"></i> Última transmisión</div>
    <div class="featured-name">${splitName(s.name)}</div>
    <div class="featured-sub">${relativeTime(vod.date)}${vod.duration ? ' · ' + fmtDuration(vod.duration) : ''}</div>`;
  document.getElementById('featuredActions')!.innerHTML = `
    <a href="/vods/v/?id=${vod.id}" class="nav-btn solid"><i class="fa-solid fa-play"></i> Ver VOD</a>
    <a href="/vods/" class="nav-btn"><i class="fa-solid fa-film"></i> Todos los VODs</a>`;
  const thumb = document.getElementById('featuredVodThumb')!;
  if (vod.thumb) {
    thumb.style.backgroundImage = `url('${vod.thumb}')`;
    thumb.classList.add('show');
  } else {
    thumb.style.backgroundImage = '';
    thumb.classList.remove('show');
  }
  if (_hover && vod.preview) {
    vid.src = vod.preview;
    vid.loop = true;
    vid.muted = true;
    vid.play().catch(() => {});
    wrap.classList.add('vod-preview-mode');
  } else {
    vid.pause();
    vid.src = '';
    wrap.classList.remove('vod-preview-mode');
  }
}

function startVodRotation() {
  clearInterval(vodRotateTimer!);
  if (_recentVods.length <= 1) return;
  startProgressBar();
  vodRotateTimer = setInterval(() => {
    vodRotateIdx = (vodRotateIdx + 1) % _recentVods.length;
    const content = document.getElementById('featuredContent')!;
    const actions = document.getElementById('featuredActions')!;
    const letter  = document.getElementById('featuredLetter')!;
    content.classList.add('out');
    actions.classList.add('out');
    letter.classList.add('out');
    setTimeout(() => {
      applyVodContent(_recentVods[vodRotateIdx]);
      content.classList.remove('out');
      actions.classList.remove('out');
      setTimeout(() => letter.classList.remove('out'), 60);
    }, 380);
    startProgressBar();
  }, ROTATE_MS);
}

function stopVodRotation() {
  clearInterval(vodRotateTimer!);
  vodRotateTimer = null;
  cancelAnimationFrame(rafId!);
  document.getElementById('rotateBar')!.style.width = '0%';
  document.getElementById('featuredWrap')!.classList.remove('vod-preview-mode');
  document.getElementById('featuredVodThumb')!.classList.remove('show');
}

function renderFeaturedVod() {
  const wrap      = document.getElementById('featuredWrap')!;
  const vid       = document.getElementById('featuredVideo') as HTMLVideoElement;
  const offlineEl = document.getElementById('featuredOffline')!;
  const vod = _recentVods[0];

  if (!vod || !vod.filename) {
    vid.src = '';
    wrap.classList.remove('playing', 'vod-preview-mode');
    document.getElementById('featuredVodThumb')!.classList.remove('show');
    document.getElementById('featuredInfo')!.innerHTML = '';
    document.getElementById('featuredActions')!.innerHTML = '';
    document.getElementById('featuredLetter')!.textContent = '';
    return;
  }

  vodRotateIdx = 0;
  offlineEl.style.cssText = 'opacity:0;pointer-events:none';
  document.getElementById('featuredViewers')!.style.display = 'none';
  wrap.classList.remove('playing');
  applyVodContent(vod);
  startVodRotation();
}

function avaStyle(s: any)   { return s.color ? `background:${s.color}` : 'background:#1e3a4a' }
function initial(name: string) { return name.charAt(0).toUpperCase() }
function avaContent(s: any) {
  return s.avatar_url
    ? `<img src="${s.avatar_url}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`
    : initial(s.name);
}
function splitName(n: string)  { return n.length <= 4 ? `<span>${n}</span>` : `${n.slice(0,-3)}<span>${n.slice(-3)}</span>` }

function hexToRgba(hex: string, alpha: number) {
  if (!hex || hex.length < 7) return `rgba(0,191,255,${alpha})`;
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function setGlow(color: string) {
  const grad = `radial-gradient(ellipse 70% 90% at 25% 55%, ${hexToRgba(color, .18)}, transparent 65%)`;
  const incoming = glowActive === 'a' ? 'b' : 'a';
  const inEl  = document.getElementById('glow' + incoming.toUpperCase())!;
  const outEl = document.getElementById('glow' + glowActive.toUpperCase())!;
  inEl.style.background = grad;
  inEl.style.opacity = '1';
  outEl.style.opacity = '0';
  glowActive = incoming;
}

function startProgressBar() {
  cancelAnimationFrame(rafId!);
  const bar = document.getElementById('rotateBar')!;
  bar.style.transition = 'none';
  bar.style.width = '0%';
  rotateStart = performance.now();
  function tick(now: number) {
    const pct = Math.min(100, ((now - rotateStart!) / ROTATE_MS) * 100);
    bar.style.width = pct + '%';
    if (pct < 100) rafId = requestAnimationFrame(tick);
  }
  rafId = requestAnimationFrame(tick);
}

function applyFeaturedContent(key: string, paths: any[]) {
  const s = ((window as any).STREAMERS || []).find((x: any) => x.key === key) || { key, name: key.toUpperCase() };
  const viewers = getViewers(paths, key);
  document.getElementById('featuredInfo')!.innerHTML = `
    <div class="featured-live-tag">
      <span class="live-dot" style="width:5px;height:5px;box-shadow:none"></span>
      En vivo
    </div>
    <div class="featured-name">${splitName(s.name)}</div>
    <div class="featured-sub">${s.sub || 'corillo.live · Puerto Rico'}</div>`;
  document.getElementById('featuredActions')!.innerHTML = `
    <a href="/${key}/" class="nav-btn solid"><i class="fa-solid fa-play"></i> Ver stream</a>
    ${s.twitch ? `<a href="https://twitch.tv/${s.twitch}" target="_blank" class="nav-btn"><i class="fab fa-twitch"></i> Twitch</a>` : ''}`;
  document.getElementById('featuredViewerCount')!.textContent = viewers;
  document.getElementById('featuredLetter')!.textContent = initial(s.name);
  setGlow(s.color);
}

function setFeatured(key: string | null, paths: any[], animate: boolean) {
  const wrap = document.getElementById('featuredWrap')!;
  const vid  = document.getElementById('featuredVideo') as HTMLVideoElement;

  if (!key) {
    if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
    const wasLive = featuredKey !== null;
    featuredKey = null;
    if (wasLive || !vodInitialized) {
      vodInitialized = true;
      cancelAnimationFrame(rafId!);
      document.getElementById('rotateBar')!.style.width = '0%';
      renderFeaturedVod();
    }
    return;
  }

  if (key === featuredKey) {
    document.getElementById('featuredViewerCount')!.textContent = getViewers(paths, key);
    return;
  }

  document.getElementById('featuredOffline')!.style.cssText = '';
  document.getElementById('featuredViewers')!.style.display = '';
  wrap.classList.remove('playing', 'vod-preview-mode');
  document.getElementById('featuredVodThumb')!.classList.remove('show');

  const doSwitch = () => {
    vodInitialized = false;
    featuredKey = key;
    applyFeaturedContent(key, paths);

    vid.pause();
    vid.src = '';
    if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
    const url = `/live/${encodeURIComponent(key)}/index.m3u8`;
    if (vid.canPlayType('application/vnd.apple.mpegurl')) {
      vid.src = url; vid.play().catch(()=>{});
    } else if ((window as any).Hls && (window as any).Hls.isSupported()) {
      hlsInstance = new (window as any).Hls({ lowLatencyMode: true, maxBufferLength: 8 });
      hlsInstance.loadSource(url);
      hlsInstance.attachMedia(vid);
      hlsInstance.on((window as any).Hls.Events.MANIFEST_PARSED, () => vid.play().catch(()=>{}));
    }
    wrap.classList.add('playing');
  };

  if (animate && featuredKey) {
    const content = document.getElementById('featuredContent')!;
    const actions = document.getElementById('featuredActions')!;
    const letter  = document.getElementById('featuredLetter')!;
    content.classList.add('out');
    actions.classList.add('out');
    letter.classList.add('out');
    setTimeout(() => {
      doSwitch();
      content.classList.remove('out');
      actions.classList.remove('out');
      setTimeout(() => letter.classList.remove('out'), 60);
    }, 380);
  } else {
    doSwitch();
  }
}

function startRotation(live: any[]) {
  clearInterval(rotateTimer!);
  livePlayers = live.map((s: any) => s.key);
  if (livePlayers.length === 0) return;
  cancelAnimationFrame(rafId!);
  stopVodRotation();
  if (livePlayers.length === 1) {
    document.getElementById('rotateBar')!.style.width = '0%';
    return;
  }
  const idx = livePlayers.indexOf(featuredKey!);
  rotateIdx = idx >= 0 ? idx : 0;
  startProgressBar();
  rotateTimer = setInterval(() => {
    rotateIdx = (rotateIdx + 1) % livePlayers.length;
    const key = livePlayers[rotateIdx];
    setFeatured(key, lastPaths, true);
    updateSidebarActive(key);
    startProgressBar();
  }, ROTATE_MS);
}

function resetRotation(newKey: string) {
  rotateIdx = livePlayers.indexOf(newKey);
  if (rotateIdx < 0) rotateIdx = 0;
  clearInterval(rotateTimer!);
  if (livePlayers.length > 1) {
    startProgressBar();
    rotateTimer = setInterval(() => {
      rotateIdx = (rotateIdx + 1) % livePlayers.length;
      const key = livePlayers[rotateIdx];
      setFeatured(key, lastPaths, true);
      updateSidebarActive(key);
      startProgressBar();
    }, ROTATE_MS);
  }
}

function updateSidebarActive(key: string) {
  document.querySelectorAll('#sidebarLiveRows .channel-row').forEach(el => {
    el.classList.toggle('active', (el as HTMLElement).dataset.key === key);
  });
}

function renderSidebar(live: any[], offline: any[], paths: any[], activeFeatured: string | null) {
  const liveSection = document.getElementById('sidebarLiveSection')!;
  const liveRows    = document.getElementById('sidebarLiveRows')!;
  const divider     = document.getElementById('sidebarDivider')!;
  const offlineRows = document.getElementById('sidebarOfflineRows')!;

  if (live.length) {
    liveSection.style.display = '';
    divider.style.display     = '';
    liveRows.innerHTML = live.map((s: any) => {
      const viewers = getViewers(paths, s.key);
      const active  = s.key === activeFeatured ? ' active' : '';
      return `<a href="/${s.key}/" class="channel-row is-live${active}" data-key="${s.key}">
        <div class="ch-ava" style="${avaStyle(s)}">${avaContent(s)}</div>
        <div class="ch-info">
          <div class="ch-name"${s.color ? ` style="color:${s.color}"` : ''}>${s.name}</div>
          <div class="ch-status live">En vivo</div>
        </div>
        ${viewers > 0 ? `<div class="ch-viewers">${viewers}</div>` : '<div class="live-pip"></div>'}
      </a>`;
    }).join('');
  } else {
    liveSection.style.display = 'none';
    divider.style.display     = 'none';
  }

  const MAX = 8;
  const showAllBtn = document.getElementById('sidebarShowAll')!;
  const renderOffline = (list: any[]) => list.map(s => `
    <a href="/${s.key}/" class="channel-row">
      <div class="ch-ava" style="${avaStyle(s)};opacity:.45">${avaContent(s)}</div>
      <div class="ch-info">
        <div class="ch-name">${s.name}</div>
        <div class="ch-status">Offline</div>
      </div>
    </a>`).join('');

  if (offline.length > MAX) {
    offlineRows.innerHTML = renderOffline(offline.slice(0, MAX));
    showAllBtn.style.display = '';
    showAllBtn.onclick = () => {
      offlineRows.innerHTML = renderOffline(offline);
      showAllBtn.style.display = 'none';
    };
  } else {
    offlineRows.innerHTML = renderOffline(offline);
    showAllBtn.style.display = 'none';
  }
}

document.getElementById('sidebarLiveRows')!.addEventListener('click', (e: Event) => {
  const row = (e.target as Element).closest('[data-key]') as HTMLElement | null;
  if (!row) return;
  e.preventDefault();
  const key = row.dataset.key!;
  if (key === featuredKey) return;
  setFeatured(key, lastPaths, true);
  updateSidebarActive(key);
  resetRotation(key);
});

function renderDrawer(live: any[], offline: any[], paths: any[]) {
  const liveSection = document.getElementById('drawerLiveSection')!;
  const liveRows    = document.getElementById('drawerLiveRows')!;
  const offlineRows = document.getElementById('drawerOfflineRows')!;
  if (live.length) {
    liveSection.style.display = '';
    liveRows.innerHTML = live.map((s: any) => {
      const v = getViewers(paths, s.key);
      return `<a href="/${s.key}/" class="channel-row is-live" onclick="window.closeDrawer()">
        <div class="ch-ava" style="${avaStyle(s)}">${avaContent(s)}</div>
        <div class="ch-info">
          <div class="ch-name"${s.color ? ` style="color:${s.color}"` : ''}>${s.name}</div>
          <div class="ch-status live">En vivo</div>
        </div>
        ${v > 0 ? `<div class="ch-viewers">${v}</div>` : '<div class="live-pip"></div>'}
      </a>`;
    }).join('');
  } else {
    liveSection.style.display = 'none';
  }
  const MAX = 8;
  const showAllBtn = document.getElementById('drawerShowAll')!;
  const renderOffline = (list: any[]) => list.map(s => `
    <a href="/${s.key}/" class="channel-row" onclick="window.closeDrawer()">
      <div class="ch-ava" style="${avaStyle(s)};opacity:.45">${avaContent(s)}</div>
      <div class="ch-info">
        <div class="ch-name">${s.name}</div>
        <div class="ch-status">Offline</div>
      </div>
    </a>`).join('');

  if (offline.length > MAX) {
    offlineRows.innerHTML = renderOffline(offline.slice(0, MAX));
    showAllBtn.style.display = '';
    showAllBtn.onclick = () => {
      offlineRows.innerHTML = renderOffline(offline);
      showAllBtn.style.display = 'none';
    };
  } else {
    offlineRows.innerHTML = renderOffline(offline);
    showAllBtn.style.display = 'none';
  }
}

function openDrawer()  {
  document.getElementById('drawer')!.classList.add('open');
  document.getElementById('drawerOverlay')!.classList.add('open');
}
(window as any).closeDrawer = () => {
  document.getElementById('drawer')!.classList.remove('open');
  document.getElementById('drawerOverlay')!.classList.remove('open');
};
document.getElementById('menuBtn')!.addEventListener('click', openDrawer);
document.getElementById('drawerClose')!.addEventListener('click', (window as any).closeDrawer);
document.getElementById('drawerOverlay')!.addEventListener('click', (window as any).closeDrawer);

function updateNav(count: number) {
  const el = document.getElementById('navLive')!;
  el.style.display = count > 0 ? 'flex' : 'none';
  document.getElementById('navLiveCount')!.textContent = `${count} en vivo`;
}

const _hover = window.matchMedia('(hover: hover)').matches;

function goToSlide(n: number) {
  const slides = document.querySelectorAll('.offline-slide');
  const dots   = document.querySelectorAll('.offline-dot');
  if (!slides.length) return;
  slides[_sliderIdx].classList.remove('active');
  if (dots[_sliderIdx]) dots[_sliderIdx].classList.remove('active');
  _sliderIdx = ((n % slides.length) + slides.length) % slides.length;
  slides[_sliderIdx].classList.add('active');
  if (dots[_sliderIdx]) dots[_sliderIdx].classList.add('active');
  startSliderTimer();
}

function startSliderTimer() {
  clearTimeout(_sliderTimer!);
  const bar = document.getElementById('offlineBar');
  if (!bar) return;
  bar.style.transition = 'none';
  bar.style.width = '0%';
  requestAnimationFrame(() => requestAnimationFrame(() => {
    bar.style.transition = `width ${SLIDE_INTERVAL}ms linear`;
    bar.style.width = '100%';
  }));
  _sliderTimer = setTimeout(() => {
    const slides = document.querySelectorAll('.offline-slide');
    if (slides.length > 1) goToSlide(_sliderIdx + 1);
  }, SLIDE_INTERVAL);
}

function renderOfflineSlider(vods: any[]) {
  clearTimeout(_sliderTimer!);
  _sliderIdx = 0;
  const grid = document.getElementById('liveGrid')!;
  grid.innerHTML = `<div class="offline-slider-wrap">
    <div class="offline-sl-hd">
      <span>Últimas transmisiones</span>
      <div class="section-line"></div>
      <a href="/vods/">Ver todos →</a>
    </div>
    <div class="offline-stage" id="offlineStage">
      ${vods.map((vod: any, i: number) => {
        const s = ((window as any).STREAMERS||[]).find((x: any) => x.key === vod.channel) || { name: vod.channel.toUpperCase() };
        const bg = vod.thumb ? `style="background-image:url('${vod.thumb}')"` : '';
        const meta = [relativeTime(vod.date), vod.duration ? fmtDuration(vod.duration) : ''].filter(Boolean).join(' · ');
        return `<a class="offline-slide${i === 0 ? ' active' : ''}" href="/${vod.channel}/">
          <div class="offline-slide-bg" ${bg}></div>
          <div class="offline-slide-grad"></div>
          <div class="offline-slide-info">
            <div class="offline-slide-tag"><i class="fa-solid fa-film"></i> Última transmisión</div>
            <div class="offline-slide-name">${s.name}</div>
            <div class="offline-slide-meta">${meta}</div>
          </div>
        </a>`;
      }).join('')}
      <div class="offline-bar-wrap"><div class="offline-bar" id="offlineBar"></div></div>
    </div>
    ${vods.length > 1 ? `<div class="offline-dots">${vods.map((_: any, i: number) =>
      `<button class="offline-dot${i === 0 ? ' active' : ''}" data-i="${i}"></button>`
    ).join('')}</div>` : ''}
  </div>`;

  if (vods.length > 1) {
    document.querySelectorAll('.offline-dot').forEach(d => {
      d.addEventListener('click', () => goToSlide(+(d as HTMLElement).dataset.i!));
    });
    let tx = 0;
    const stage = document.getElementById('offlineStage')!;
    stage.addEventListener('touchstart', (e: TouchEvent) => { tx = e.touches[0].clientX; }, { passive: true });
    stage.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - tx;
      if (Math.abs(dx) > 40) {
        e.preventDefault();
        goToSlide(dx < 0 ? _sliderIdx + 1 : _sliderIdx - 1);
      }
    }, { passive: false });
  }

  startSliderTimer();
}

function vodCards(vods: any[]) {
  return vods.map(vod => {
    const s       = ((window as any).STREAMERS||[]).find((x: any) => x.key === vod.channel) || { name: vod.channel.toUpperCase(), color: '' };
    const dur     = vod.duration ? fmtDuration(vod.duration) : '';
    const preview = _hover && vod.preview ? `<video class="stream-thumb-preview" src="${vod.preview}" muted playsinline preload="none" loop></video>` : '';
    return `<a href="/${vod.channel}/" class="stream-card">
      <div class="stream-thumb">
        <div class="stream-thumb-inner"><span class="stream-thumb-letter">${s.name.charAt(0)}</span></div>
        ${vod.thumb ? `<img src="${vod.thumb}" alt="" class="stream-thumb-img" onerror="this.style.display='none'" loading="lazy">` : ''}
        ${preview}
        ${dur ? `<div class="vod-duration">${dur}</div>` : ''}
      </div>
      <div class="stream-body">
        <div class="stream-card-ava" style="background:${s.color||'var(--crl-accent)'}"><img id="card-ava-${vod.channel}" src="" alt="" style="display:none" onerror="this.style.display='none'"><span id="card-avaf-${vod.channel}">${s.name.charAt(0)}</span></div>
        <div class="stream-card-info">
          <div class="stream-name">${s.name}</div>
          <div class="stream-desc">${relativeTime(vod.date)}</div>
        </div>
      </div>
    </a>`;
  }).join('');
}

function attachPreviewListeners(container: Element) {
  if (!_hover) return;
  container.querySelectorAll('.stream-card').forEach(card => {
    const vid = card.querySelector('.stream-thumb-preview') as HTMLVideoElement | null;
    if (!vid) return;
    card.addEventListener('mouseenter', () => { vid.play().catch(() => { vid.style.display = 'none'; }); });
    card.addEventListener('mouseleave', () => { vid.pause(); vid.currentTime = 0; });
  });
}

function renderGrid(live: any[], offline: any[], paths: any[]) {
  const grid = document.getElementById('liveGrid')!;
  document.getElementById('liveCount')!.textContent = live.length
    ? `${live.length} canal${live.length > 1 ? 'es' : ''} activo${live.length > 1 ? 's' : ''}`
    : 'ninguno en vivo';

  const newState = live.length ? 'live' : (_recentVods.length ? 'offline' : 'empty');

  if (!live.length) {
    if (_recentVods.length) {
      if (_gridState !== 'offline') {
        grid.innerHTML = `<div class="vods-row-header">
          <span>Últimas transmisiones</span>
          <div class="section-line"></div>
          <a href="/vods/">Ver todos →</a>
        </div><div class="cards-carousel">${vodCards(_recentVods)}</div>`;
        attachPreviewListeners(grid);
        const vodKeys = [...grid.querySelectorAll('[id^="card-ava-"]')].map(el => el.id.replace('card-ava-', ''));
        if (vodKeys.length) loadCardAvatars(vodKeys);
      }
    } else {
      if (_gridState !== 'empty') {
        grid.innerHTML = `<div class="no-live-msg"><i class="fa-solid fa-tower-broadcast" style="font-size:1.5rem"></i>Sin streams activos ahora mismo</div>`;
      }
    }
    _gridState = newState;
    return;
  }

  const liveKeys2 = live.map((s: any) => s.key).sort().join(',');
  if (_gridState === 'live' && liveKeys2 === (grid.dataset.liveKeys || '')) {
    // Same live channels — only update viewer counts, skip full re-render
    live.forEach((s: any) => {
      const v = getViewers(paths, s.key);
      const card = grid.querySelector(`[data-channel="${s.key}"]`);
      if (card) {
        const vEl = card.querySelector('.stream-viewers');
        if (v > 0) {
          if (vEl) vEl.textContent = `${v}`;
          else card.querySelector('.stream-thumb')?.insertAdjacentHTML('beforeend',
            `<div class="stream-viewers" data-v><i class="fa-solid fa-eye" style="font-size:9px"></i> ${v}</div>`);
        } else if (vEl) vEl.remove();
      }
    });
    _gridState = newState;
    return;
  }

  const liveHtml = live.map((s: any) => {
    const v = getViewers(paths, s.key);
    return `<a href="/${s.key}/" class="stream-card" data-channel="${s.key}">
      <div class="stream-thumb">
        <div class="stream-thumb-inner"><span class="stream-thumb-letter">${s.name}</span></div>
        <img src="/assets/thumbs/${s.key}.jpg?t=${Math.floor(Date.now()/60000)}" alt="" class="stream-thumb-img" onerror="this.style.display='none'">
        ${_hover ? `<video class="stream-thumb-preview" src="/assets/thumbs/${s.key}-preview.mp4?t=${Math.floor(Date.now()/60000)}" muted playsinline preload="none" loop></video>` : ''}
        <div class="stream-live-tag"><span class="live-dot" style="width:5px;height:5px;box-shadow:none;animation:none"></span> LIVE</div>
        ${v > 0 ? `<div class="stream-viewers"><i class="fa-solid fa-eye" style="font-size:9px"></i> ${v}</div>` : ''}
      </div>
      <div class="stream-body">
        <div class="stream-card-ava is-live" style="background:${s.color||'var(--crl-accent)'}"><img id="card-ava-${s.key}" src="" alt="" style="display:none" onerror="this.style.display='none'"><span id="card-avaf-${s.key}">${s.name.charAt(0)}</span></div>
        <div class="stream-card-info">
          <div class="stream-name">${s.name}</div>
          <div class="stream-desc">${s.sub || 'corillo.live'}</div>
        </div>
      </div>
    </a>`;
  }).join('');

  const liveKeys = new Set(live.map((s: any) => s.key));
  const offlineVods = _recentVods.filter(v => !liveKeys.has(v.channel));

  grid.dataset.liveKeys = liveKeys2;
  grid.innerHTML = liveHtml + (offlineVods.length ? `
    <div class="vods-row-header">
      <span>Últimas transmisiones</span>
      <div class="section-line"></div>
      <a href="/vods/">Ver todos →</a>
    </div><div class="cards-carousel">${vodCards(offlineVods)}</div>` : '');

  _gridState = newState;
  attachPreviewListeners(grid);

  // Load profile photos for cards just rendered
  const keys = [...grid.querySelectorAll('[id^="card-ava-"]')]
    .map(el => el.id.replace('card-ava-', ''));
  if (keys.length) loadCardAvatars(keys);
}

const _avatarCache: Record<string, string | null> = {};

async function loadCardAvatars(keys: string[]) {
  for (const key of keys) {
    if (key in _avatarCache) { applyCardAvatar(key, _avatarCache[key]); continue; }
    try {
      const r = await fetch(`/chat-api/profile/${key}`);
      if (!r.ok) { _avatarCache[key] = null; continue; }
      const d = await r.json();
      _avatarCache[key] = d.avatar_url || null;
      applyCardAvatar(key, _avatarCache[key]);
    } catch { _avatarCache[key] = null; }
  }
}

function applyCardAvatar(key: string, url: string | null) {
  if (!url) return;
  const img = document.getElementById(`card-ava-${key}`) as HTMLImageElement | null;
  const fb  = document.getElementById(`card-avaf-${key}`);
  if (img && img.src !== url) { img.src = url; img.style.display = 'block'; if (fb) (fb as HTMLElement).style.display = 'none'; }
}

async function update() {
  const now = Date.now();
  const tasks: Promise<any>[] = [fetchPaths()];
  if (now - _vodLoadedAt > VOD_TTL) tasks.push(loadVodData());
  const [paths] = await Promise.all(tasks);
  lastPaths       = paths;
  const liveSet   = getLiveSet(paths);
  const streamers = ((window as any).STREAMERS || []).filter((s: any) => !s.soon);
  const live      = streamers.filter((s: any) =>  liveSet.has(s.key));
  const offline   = streamers.filter((s: any) => !liveSet.has(s.key));
  const preferred = (live.find((s: any) => s.host) || live[0])?.key || null;

  const liveKeys   = live.map((s: any) => s.key).join(',');
  const liveChanged = liveKeys !== prevLiveKeys;
  prevLiveKeys = liveKeys;

  updateNav(live.length);
  renderDrawer(live, offline, paths);
  renderSidebar(live, offline, paths, featuredKey || preferred);
  renderGrid(live, offline, paths);

  if (preferred === null) {
    setFeatured(null, paths, false);
  } else if (liveChanged || !featuredKey) {
    const goTo = (featuredKey && liveSet.has(featuredKey)) ? featuredKey : preferred;
    setFeatured(goTo, paths, false);
    startRotation(live);
  } else if (!liveSet.has(featuredKey!)) {
    setFeatured(preferred, paths, false);
    startRotation(live);
  } else {
    document.getElementById('featuredViewerCount')!.textContent = getViewers(paths, featuredKey!);
  }
}

function startPoll() { clearInterval(pollTimer!); pollTimer = setInterval(update, POLL_MS); }

// Refresh live thumbnails every 60s without re-rendering the grid
setInterval(() => {
  const t = Math.floor(Date.now() / 60000);
  document.querySelectorAll('.stream-thumb-img').forEach((img: any) => {
    img.src = img.src.replace(/\?t=\d+/, `?t=${t}`);
  });
  document.querySelectorAll('.stream-thumb-preview').forEach((vid: any) => {
    const src = vid.src.replace(/\?t=\d+/, `?t=${t}`);
    if (vid.src !== src) { vid.src = src; vid.load(); }
  });
}, 60000);
document.addEventListener('visibilitychange', () => {
  if (document.hidden) {
    clearInterval(pollTimer!);
    clearInterval(rotateTimer!);
    clearInterval(vodRotateTimer!);
    cancelAnimationFrame(rafId!);
  } else {
    cache.t = 0;
    update();
    startPoll();
  }
});

// Patch STREAMERS with display_name from PocketBase before first render
(async () => {
  const streamers = ((window as any).STREAMERS || []).filter((s: any) => !s.soon);
  try {
    const results = await Promise.allSettled(
      streamers.map((s: any) =>
        fetch('/chat-api/profile/' + s.key, { signal: AbortSignal.timeout(4000) })
          .then(r => r.ok ? r.json() : null)
      )
    );
    results.forEach((res, i) => {
      if (res.status === 'fulfilled' && res.value) {
        if (res.value.display_name) streamers[i].name = res.value.display_name;
        if (res.value.avatar_url)   streamers[i].avatar_url = res.value.avatar_url;
      }
    });
  } catch {}
  update();
  startPoll();
})();

// Theme toggle
const root = document.documentElement;
const metaTheme = document.querySelector('meta[name="theme-color"]');
const applyTheme = (theme: string) => {
  root.setAttribute('data-theme', theme);
  if (metaTheme) metaTheme.setAttribute('content', theme === 'light' ? '#f0efe9' : '#030a0e');
};
[document.getElementById('themeBtn'), document.getElementById('themeBtnDrawer')].filter(Boolean).forEach(btn => {
  btn!.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    applyTheme(next);
    localStorage.setItem('corillo-theme', next);
  });
});

// Reels strip
(async () => {
  try {
    const res = await fetch(`${PB_URL}/api/collections/reels/records?filter=${encodeURIComponent('public=true')}&sort=-date&perPage=6`);
    const data = await res.json();
    const items: any[] = data.items || [];
    if (!items.length) return;
    const strip  = document.getElementById('reelsStrip')!;
    const track  = document.getElementById('reelsTrack')!;
    items.forEach(r => {
      const dur = r.duration ? `${r.duration}s` : '';
      const thumb = r.thumb ? `background-image:url('${r.thumb}')` : '';
      const a = document.createElement('a');
      a.className = 'reel-card';
      a.href = '/reels/';
      a.innerHTML = `
        <div class="reel-card-thumb" style="${thumb}">
          <div class="reel-card-play"><i class="fa-solid fa-play"></i></div>
          ${dur ? `<div class="reel-card-dur">${dur}</div>` : ''}
        </div>
        <div class="reel-card-info">
          <div class="reel-card-ch">${r.channel.toUpperCase()}</div>
        </div>`;
      track.appendChild(a);
    });
    strip.style.display = '';
  } catch(e) {}
})();

// Footer version
fetch('/version.json').then(r => r.json()).then(d => {
  const el = document.getElementById('footVersion');
  if (el && d.version) el.textContent = 'v' + d.version;
}).catch(() => {});

// Footer accordion — mobile only
if (matchMedia('(max-width:520px)').matches) {
  document.querySelectorAll('[data-foot-toggle]').forEach(title => {
    const links = title.nextElementSibling as HTMLElement;
    title.setAttribute('aria-expanded', 'false');
    title.addEventListener('click', () => {
      const open = links.classList.toggle('open');
      title.setAttribute('aria-expanded', String(open));
    });
  });
}
</script>

<script>if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js');</script>
</body>
</html>
