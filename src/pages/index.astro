<script>
const POLL_MS     = 15000;
const API_TIMEOUT = 5000;
const CACHE_MS    = 8000;
const ROTATE_MS   = 6000;
const VOD_TTL     = 120000;
const PB_URL      = 'https://pb.corillo.live';

const STREAMERS = (window.STREAMERS || []).filter(s => !s.soon);
const _hover    = window.matchMedia('(hover: hover)').matches;

let cache        = { t: 0, data: null };
let hlsInstance  = null;
let searchQuery  = '';
let featuredKey  = undefined; // undefined=unset, null=offline, string=live channel
let rotateTimer  = null;
let statsTimer   = null;
let rafId        = null;
let rotateStart  = null;
let livePlayers  = [];
let rotateIdx    = 0;
let lastPaths    = [];
let statsBase    = { bitrate: 5200, latency: 2.4, viewers: 0 };
let vodList      = [];
let vodRotateIdx = 0;
let vodRotateTimer = null;
let cardBitrates = {}; // key → stable bitrate for card display

let _recentVods     = [];
let _vodLoadedAt    = 0;
let _gridState      = null;
const _avatarCache  = {};

function rowAva(s, dim = false) {
  const opacity = dim ? ';opacity:.45' : '';
  if (s.avatar_url) {
    return `<div class="ch-row-ava" style="background:${s.color || '#1e3a4a'}${opacity}"><img src="${s.avatar_url}" alt="${s.name}"></div>`;
  }
  return `<div class="ch-row-ava" style="background:${s.color || '#1e3a4a'}${opacity}">${s.ava || s.name[0]}</div>`;
}

/* ── Utils ────────────────────────────────────────────── */
function getLiveSet(paths) {
  const s = new Set();
  for (const p of paths) {
    if (!p.ready) continue;
    const m = p.name.match(/^live\/(.+)$/);
    if (m) s.add(m[1]);
  }
  return s;
}

function getViewers(paths, key) {
  const p = paths.find(p => p.name === 'live/' + key);
  return p ? (p.readers?.length ?? 0) : 0;
}

function getReadyTime(paths, key) {
  const p = paths.find(p => p.name === 'live/' + key);
  return p?.readyTime ? new Date(p.readyTime).getTime() : null;
}

function jitter(base, variance) {
  return Math.round(base + (Math.random() - 0.5) * 2 * variance);
}

function fmtDuration(s) {
  if (!s) return '';
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  return h > 0
    ? `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`
    : `${m}:${String(sec).padStart(2,'0')}`;
}

function fmtUptime(ms) {
  const s = Math.floor(ms / 1000);
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), ss = s % 60;
  return [h, m, ss].map(n => String(n).padStart(2,'0')).join(':');
}

function fmtKbps(b) {
  return b >= 1000 ? (b/1000).toFixed(1) + 'M' : b + 'K';
}

function relativeTime(dateStr) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 2)  return 'Hace un momento';
  if (mins < 60) return `Hace ${mins}m`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24)  return `Hace ${hrs}h`;
  const days = Math.floor(hrs / 24);
  if (days === 1) return 'Ayer';
  if (days < 7)  return `Hace ${days} días`;
  return `Hace ${Math.floor(days / 7)} sem`;
}

/* ── API ─────────────────────────────────────────────── */
async function fetchPaths() {
  const now = Date.now();
  if (cache.data && now - cache.t < CACHE_MS) return cache.data;
  const ctrl = new AbortController();
  const tid  = setTimeout(() => ctrl.abort(), API_TIMEOUT);
  try {
    const r = await fetch('/mediamtx-api/v3/paths/list', { signal: ctrl.signal });
    clearTimeout(tid);
    const j = await r.json();
    cache = { t: now, data: j.items || [] };
  } catch {
    clearTimeout(tid);
    if (!cache.data) cache.data = [];
  }
  return cache.data;
}

async function fetchRecentVods(limit) {
  try {
    const r = await fetch(
      `${PB_URL}/api/collections/vods/records?sort=-date&perPage=${limit}&fields=id,channel,filename,thumb,preview,duration,date`,
      { signal: AbortSignal.timeout(5000) }
    );
    return (await r.json()).items || [];
  } catch { return []; }
}

async function loadVodData() {
  const vods = await fetchRecentVods(30);
  const seen = new Set();
  _recentVods = vods.filter(v => {
    if (seen.has(v.channel)) return false;
    seen.add(v.channel);
    return true;
  }).slice(0, 6);
  _vodLoadedAt = Date.now();
}

function vodCards(vods) {
  return vods.map(vod => {
    const s = STREAMERS.find(x => x.key === vod.channel) || {
      key: vod.channel, name: vod.channel.toUpperCase(),
      color: 'linear-gradient(135deg,#1a2a3a,#0a1420)',
      ava: vod.channel[0].toUpperCase()
    };
    const dur     = vod.duration ? fmtDuration(vod.duration) : '';
    const preview = _hover && vod.preview
      ? `<video class="ch-preview-vid" src="${vod.preview}" muted playsinline preload="none" loop></video>` : '';
    return `<a href="/vods/v/?id=${vod.id}" class="ch">
      <div class="ch-thumb">
        <div class="ch-thumb-glow" style="background:${s.color || '#1e3a4a'}"></div>
        <div class="ch-thumb-noise"></div>
        <div class="ch-thumb-inner">${s.ava || s.name[0]}</div>
        ${vod.thumb ? `<img class="ch-thumb-img" src="${vod.thumb}" alt="" onerror="this.style.display='none'" loading="lazy">` : ''}
        ${preview}
        <div class="ch-top"><span class="ch-badge-off">VOD</span></div>
        ${dur ? `<div class="ch-bottom"><span class="ch-bitrate">${dur}</span></div>` : ''}
      </div>
      <div class="ch-body">
        <div class="ch-ava" style="background:${s.color || '#1e3a4a'}">
          <img id="card-ava-${vod.id}" data-channel="${vod.channel}" alt="" style="display:none;width:100%;height:100%;object-fit:cover;border-radius:4px">
          <span id="card-avaf-${vod.id}">${s.ava || s.name[0]}</span>
        </div>
        <div class="ch-info">
          <div class="ch-name">${s.name}</div>
          <div class="ch-sub">${relativeTime(vod.date)}${dur ? ' · ' + dur : ''}</div>
        </div>
      </div>
    </a>`;
  }).join('');
}

function attachPreviewListeners(container) {
  if (!_hover) return;
  container.querySelectorAll('.ch-preview-vid').forEach(vid => {
    const card = vid.closest('.ch');
    if (!card) return;
    card.addEventListener('mouseenter', () => vid.play().catch(() => { vid.style.display = 'none'; }));
    card.addEventListener('mouseleave', () => { vid.pause(); vid.currentTime = 0; });
  });
}

async function loadCardAvatars(ids) {
  for (const id of ids) {
    if (id in _avatarCache) { applyCardAvatar(id, _avatarCache[id]); continue; }
    try {
      const el = document.getElementById('card-ava-' + id);
      const channel = el?.dataset?.channel;
      if (!channel) { _avatarCache[id] = null; continue; }
      const r = await fetch('/chat-api/profile/' + encodeURIComponent(channel));
      if (!r.ok) { _avatarCache[id] = null; continue; }
      const d = await r.json();
      _avatarCache[id] = d.avatar_url || null;
      applyCardAvatar(id, _avatarCache[id]);
    } catch { _avatarCache[id] = null; }
  }
}

function applyCardAvatar(id, url) {
  if (!url) return;
  const img = document.getElementById('card-ava-' + id);
  const fb  = document.getElementById('card-avaf-' + id);
  if (img && img.src !== url) {
    img.src = url;
    img.style.display = 'block';
    if (fb) fb.style.display = 'none';
  }
}

/* ── Chat label ──────────────────────────────────────── */
function updateChatLabel(key) {
  const el = document.querySelector('.chat-panel .panel-title');
  if (!el) return;
  el.innerHTML = `<i class="fa-solid fa-comments"></i> Chat · #${key || 'corillo'}`;
}

/* ── Ticker ──────────────────────────────────────────── */
function renderTicker(liveChannels) {
  const wrap    = document.getElementById('tickerWrap');
  const content = document.getElementById('tickerContent');
  const countEl = document.getElementById('tickerCount');
  if (!wrap) return;
  if (!liveChannels.length) {
    wrap.style.visibility = 'hidden';
    return;
  }
  wrap.style.visibility = '';
  countEl.textContent = liveChannels.length;
  const items = [...liveChannels, ...liveChannels].map(s => {
    const v = s._viewers || 0;
    return `<span class="ticker-item">
      <span class="chan">${s.name}</span>
      <span>${s.sub?.split('·')[0]?.trim() || 'En vivo'}</span>
      ${v > 0 ? `<span class="stat">${v} viewers</span>` : ''}
      <span class="ticker-sep">//</span>
    </span>`;
  }).join('');
  content.innerHTML = items;
}

/* ── Stats animation ─────────────────────────────────── */
function startStatsAnimation(viewers, paths) {
  let uptimeStart = Date.now();
  if (featuredKey) {
    const rt = getReadyTime(paths, featuredKey);
    if (rt) uptimeStart = rt;
  }

  stopStatsAnimation();

  function tick() {
    const uptime = Date.now() - uptimeStart;
    const uptEl = document.getElementById('featuredUptime');
    if (uptEl) uptEl.textContent = fmtUptime(uptime);
  }

  tick();
  statsTimer = setInterval(tick, 1000);
}

function stopStatsAnimation() {
  clearInterval(statsTimer);
  statsTimer = null;
}

/* ── Progress bar ────────────────────────────────────── */
function startProgressBar() {
  cancelAnimationFrame(rafId);
  const bar = document.getElementById('rotateBar');
  if (!bar) return;
  bar.style.transition = 'none';
  bar.style.width = '0%';
  rotateStart = performance.now();
  function tick(now) {
    const pct = Math.min(100, ((now - rotateStart) / ROTATE_MS) * 100);
    bar.style.width = pct + '%';
    if (pct < 100) rafId = requestAnimationFrame(tick);
  }
  rafId = requestAnimationFrame(tick);
}

/* ── Featured player ─────────────────────────────────── */
function setFeaturedLive(key, paths) {
  const s = STREAMERS.find(x => x.key === key) || { key, name: key.toUpperCase(), color: '#1e3a4a', ava: key[0].toUpperCase(), sub: 'corillo.live' };
  const viewers = getViewers(paths, key);

  featuredKey = key;
  statsBase.viewers = viewers;

  updateChatLabel(key);

  // Sim stream
  const sim = document.getElementById('simStream');
  sim.className = 'sim-stream';
  document.getElementById('simTitle').textContent = s.name.split('_')[0];
  document.getElementById('simSub').textContent = s.sub?.split('·').pop()?.trim() || 'Puerto Rico';

  // Top overlay
  document.getElementById('featuredTopLeft').innerHTML = `
    <span class="live-badge" id="liveBadge">En Vivo</span>
    <span class="featured-meta"><i class="fa-solid fa-eye"></i> <span id="featuredViewersMeta">${viewers}</span></span>
    <span class="featured-meta"><i class="fa-regular fa-clock"></i> <span id="featuredUptime">00:00:00</span></span>
  `;

  // Bottom overlay
  const ava = document.getElementById('featuredAva');
  ava.style.background = s.color || '#1e3a4a';
  ava.textContent = s.ava || s.name[0];

  document.getElementById('featuredNameEl').textContent = s.name;
  const subEl = document.getElementById('featuredSubEl');
  subEl.innerHTML = (s.host ? '<span class="host-tag">HOST</span>' : '') + (s.sub || 'corillo.live · Puerto Rico');

  document.getElementById('featuredActions').innerHTML = `
    <a href="/${key}/" class="play-btn"><i class="fa-solid fa-play"></i> Ver Ahora</a>
    ${s.twitch ? `<a href="https://twitch.tv/${s.twitch}" target="_blank" rel="noopener" class="icon-btn" title="Twitch"><i class="fab fa-twitch"></i></a>` : ''}
    <button class="icon-btn" title="Fullscreen" id="featFsBtn"><i class="fa-solid fa-expand"></i></button>
  `;

  document.getElementById('featFsBtn')?.addEventListener('click', () => {
    const vid = document.getElementById('featuredVideo');
    if (vid?.requestFullscreen) vid.requestFullscreen().catch(() => {});
  });

  // HLS setup
  setupHls(key);

  // Stats
  startStatsAnimation(viewers, paths);
}

async function setFeaturedOffline() {
  featuredKey = null;

  // Stop HLS
  const vid = document.getElementById('featuredVideo');
  vid.pause();
  vid.src = '';
  if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
  document.getElementById('featuredVideoWrap').classList.remove('playing');
  stopStatsAnimation();
  clearInterval(vodRotateTimer);
  vodRotateTimer = null;
  vodRotateIdx   = 0;

  updateChatLabel(null);

  // Load VODs if not cached yet
  if (!vodList.length) {
    const raw = await fetchRecentVods(20);
    const seen = new Set();
    vodList = raw.filter(v => {
      if (seen.has(v.channel)) return false;
      seen.add(v.channel);
      return true;
    }).slice(0, 8);
  }

  if (!vodList.length) {
    showFeaturedOfflineStatic();
    return;
  }

  showFeaturedVod(vodList[0]);
  if (vodList.length > 1) {
    startProgressBar();
    vodRotateTimer = setInterval(() => {
      vodRotateIdx = (vodRotateIdx + 1) % vodList.length;
      showFeaturedVod(vodList[vodRotateIdx]);
      startProgressBar();
    }, ROTATE_MS);
  }
}

function showFeaturedVod(vod) {
  const s = STREAMERS.find(x => x.key === vod.channel) || {
    key: vod.channel, name: vod.channel.toUpperCase(),
    color: 'linear-gradient(135deg,#1a2a3a,#0a1420)',
    ava: vod.channel[0].toUpperCase(), sub: 'corillo.live'
  };

  const sim = document.getElementById('simStream');
  sim.className = 'sim-stream offline' + (vod.thumb ? ' has-thumb' : '');
  sim.style.backgroundImage = vod.thumb ? `url('${vod.thumb}')` : '';
  document.getElementById('simTitle').textContent = s.name.split('_')[0];
  document.getElementById('simSub').textContent = `ÚLTIMA TRANSMISIÓN · ${relativeTime(vod.date)}`;

  document.getElementById('featuredTopLeft').innerHTML = `
    <span class="live-badge offline">Offline</span>
    ${vod.date ? `<span class="featured-meta"><i class="fa-regular fa-clock"></i> ${relativeTime(vod.date)}</span>` : ''}
    ${vod.duration ? `<span class="featured-meta"><i class="fa-solid fa-film"></i> ${fmtDuration(vod.duration)}</span>` : ''}
  `;

  document.getElementById('featuredAva').style.background = s.color || '#1e3a4a';
  document.getElementById('featuredAva').textContent = s.ava || s.name[0];
  document.getElementById('featuredNameEl').textContent = s.name;
  document.getElementById('featuredSubEl').innerHTML =
    (s.host ? '<span class="host-tag">HOST</span>' : '') + (s.sub || 'corillo.live · Puerto Rico');

  document.getElementById('featuredActions').innerHTML = `
    <a href="/vods/v/?id=${vod.id}" class="play-btn"><i class="fa-solid fa-play"></i> Ver VOD</a>
    <a href="/${vod.channel}/" class="icon-btn" title="Ir al canal"><i class="fa-solid fa-tower-broadcast"></i></a>
    <a href="/vods/" class="icon-btn" title="Todos los VODs"><i class="fa-solid fa-film"></i></a>
  `;
}

