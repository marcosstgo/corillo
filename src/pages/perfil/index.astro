}

// ── Reel timeline — single handle ──
function initReelTimeline(vodId, duration) {
  if (!duration || duration <= 0) return;
  const tlEl = document.getElementById(`rtl-${vodId}`);
  if (!tlEl || tlEl.dataset.init === '1') return;
  tlEl.dataset.init = '1';

  const fill         = document.getElementById(`rtl-fill-${vodId}`);
  const before       = document.getElementById(`rtl-before-${vodId}`);
  const after        = document.getElementById(`rtl-after-${vodId}`);
  const handle       = document.getElementById(`rtl-hs-${vodId}`);
  const tip          = document.getElementById(`rtl-tip-${vodId}`);
  const startHidden  = document.getElementById(`rstart-${vodId}`);
  const endHidden    = document.getElementById(`rend-${vodId}`);
  const startDisplay = document.getElementById(`rstart-display-${vodId}`);
  const endDisplay   = document.getElementById(`rend-display-${vodId}`);
  const video        = document.getElementById(`rvid-${vodId}`);
  const vwrap        = document.getElementById(`rvwrap-${vodId}`);
  const vbadge       = document.getElementById(`rvbadge-${vodId}`);
  const track        = tlEl.querySelector('.rtl-track');
  const pills        = document.querySelectorAll(`#rdur-pills-${vodId} .reel-dur-pill`);

  let segDur = 30; // selected segment duration in seconds
  let s0 = 0;      // start position in seconds

  // Video setup
  if (video) {
    video.addEventListener('loadedmetadata', () => { if (vwrap) vwrap.classList.add('loaded'); });
    video.addEventListener('seeked', () => { if (vbadge) vbadge.textContent = fmtSec(video.currentTime); });
  }

  function seekVideo(sec) {
    if (!video) return;
    const doSeek = () => { video.currentTime = Math.max(0, Math.min(sec, video.duration || duration)); };
    if (video.readyState >= 1) doSeek();
    else video.addEventListener('loadedmetadata', doSeek, { once: true });
  }

  function render(doSeek) {
    // Clamp start so segment doesn't go past end
    s0 = Math.max(0, Math.min(s0, duration - segDur));
    const e0 = s0 + segDur;

    const sp = (s0 / duration) * 100;
    const ep = (e0 / duration) * 100;

    if (before) { before.style.left = '0'; before.style.width = sp + '%'; }
    fill.style.left  = sp + '%';
    fill.style.width = (ep - sp) + '%';
    if (after)  { after.style.left = ep + '%'; after.style.right = '0'; after.style.width = (100 - ep) + '%'; }
    handle.style.left = sp + '%';

    if (tip) tip.textContent = fmtSec(s0);
    if (startDisplay) startDisplay.textContent = fmtSec(s0);
    if (endDisplay)   endDisplay.textContent   = fmtSec(e0);

    startHidden.value = String(Math.round(s0));
    endHidden.value   = String(Math.round(e0));

    if (doSeek) seekVideo(s0);
  }

  function clampToTrack(clientX) {
    const rect = track.getBoundingClientRect();
    const x = Math.max(0, Math.min(clientX - rect.left, rect.width));
    return (x / rect.width) * duration;
  }

  // Drag the single handle
  handle.addEventListener('pointerdown', e => {
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    e.preventDefault(); e.stopPropagation();
    handle.setPointerCapture(e.pointerId);
    handle.classList.add('dragging');

    function onMove(ev) {
      s0 = clampToTrack(ev.clientX);
      render(true);
    }
    function onUp() {
      handle.classList.remove('dragging');
      handle.removeEventListener('pointermove', onMove);
    }
    handle.addEventListener('pointermove', onMove);
    handle.addEventListener('pointerup',     onUp, { once: true });
    handle.addEventListener('pointercancel', onUp, { once: true });
  });

  // Click anywhere on track → jump start there
  track.addEventListener('pointerdown', e => {
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    s0 = clampToTrack(e.clientX);
    render(true);
  });

  // Duration pill buttons
  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const sec = parseInt(pill.dataset.sec, 10);
      if (isNaN(sec)) return;
      segDur = sec;
      pills.forEach(p => p.classList.toggle('active', p === pill));
      render(false);
    });
  });

  render(true);
}

function toggleReelPanel(vodId, vodDuration, vidSrc, thumb) {
  const panel = document.getElementById(`rpanel-${vodId}`);
  const btn   = document.getElementById(`rbtn-${vodId}`);
  if (!panel) return;
