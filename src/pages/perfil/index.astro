    <!-- ════ CUENTA ════ -->
    <div class="pf-panel" id="t-cuenta">

      <div class="pf-s-label"><i class="fa-solid fa-shield-halved"></i> Seguridad</div>

      <details class="pf-details">
        <summary>Cambiar email</summary>
        <div class="pf-details-body">
          <div class="form-grid">
            <div class="field" style="margin:0">
              <label>Nuevo email</label>
              <input type="email" id="fNewEmail" placeholder="nuevo@email.com" autocomplete="email">
            </div>
            <div class="field" style="margin:0">
              <label>Contraseña actual</label>
              <input type="password" id="fEmailPass" placeholder="••••••••" autocomplete="current-password">
            </div>
            <div class="form-actions" style="margin:0">
              <span class="save-status" id="emailStatus"></span>
              <button class="btn primary" id="changeEmailBtn"><i class="fa-solid fa-envelope"></i> Cambiar email</button>
            </div>
          </div>
        </div>
      </details>

      <details class="pf-details">
        <summary>Cambiar contraseña</summary>
        <div class="pf-details-body">
          <div class="form-grid">
            <div class="field" style="margin:0">
              <label>Contraseña actual</label>
              <input type="password" id="fOldPass" placeholder="••••••••" autocomplete="current-password">
            </div>
            <div class="field" style="margin:0">
              <label>Nueva contraseña</label>
              <input type="password" id="fNewPass" placeholder="••••••••" autocomplete="new-password">
            </div>
            <div class="field" style="margin:0">
              <label>Confirmar nueva contraseña</label>
              <input type="password" id="fNewPassConfirm" placeholder="••••••••" autocomplete="new-password">
            </div>
            <div class="form-actions" style="margin:0">
              <span class="save-status" id="passStatus"></span>
              <button class="btn primary" id="changePassBtn"><i class="fa-solid fa-lock"></i> Cambiar contraseña</button>
            </div>
          </div>
        </div>
      </details>

      <div class="session-card">
        <div>
          <div style="font-size:.72rem;font-family:var(--mono);letter-spacing:1px;color:var(--muted);margin-bottom:3px">SESIÓN ACTIVA</div>
          <span style="font-size:.88rem" id="sessionEmail"></span>
        </div>
        <button class="btn danger" id="logoutBtn">
          <i class="fa-solid fa-arrow-right-from-bracket"></i> Cerrar sesión
        </button>
      </div>
    </div>

  </div><!-- /pf-panels -->
</div><!-- /dashboard -->

<div id="toast"></div>

<script is:inline>
const PB_URL = 'https://pb.corillo.live';
const pb = new PocketBase(PB_URL);

// ── DOM refs ──
const loginScreen  = document.getElementById('loginScreen');
const resetCard    = document.getElementById('resetCard');
const loginCard    = document.getElementById('loginCard');
const resetEmail   = document.getElementById('resetEmail');
const resetBtn     = document.getElementById('resetBtn');
const resetErr     = document.getElementById('resetErr');
const resetOk      = document.getElementById('resetOk');
const forgotBtn    = document.getElementById('forgotBtn');
const backToLogin  = document.getElementById('backToLogin');
const dashboard    = document.getElementById('dashboard');
const loginEmail   = document.getElementById('loginEmail');
const loginPass    = document.getElementById('loginPass');
const loginBtn     = document.getElementById('loginBtn');
const loginErr     = document.getElementById('loginErr');
const sessionEmail = document.getElementById('sessionEmail');
const streamKeyVal = document.getElementById('streamKeyVal');
const obsKeyHint   = document.getElementById('obsKeyHint');
const toggleKey    = document.getElementById('toggleKey');
const copyKey      = document.getElementById('copyKey');
const copyServer   = document.getElementById('copyServer');
const avatarPreview= document.getElementById('avatarPreview');
const avatarInitial= document.getElementById('avatarInitial');
const avatarBtn    = document.getElementById('avatarBtn');
const avatarFile   = document.getElementById('avatarFile');
const fDisplayName = document.getElementById('fDisplayName');
const fStreamTitle = document.getElementById('fStreamTitle');
const fBio         = document.getElementById('fBio');
const fTwitch      = document.getElementById('fTwitch');
const fInstagram   = document.getElementById('fInstagram');
const fTiktok      = document.getElementById('fTiktok');
const saveBtn      = document.getElementById('saveBtn');
const saveStatus   = document.getElementById('saveStatus');
const navRight     = document.getElementById('navRight');
const toast        = document.getElementById('toast');

let keyVisible = false;
let currentRecord = null;
let toastTimer = null;

// ── Theme ──
const root = document.documentElement;
function syncThemeUi() {
  const mode = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
  const meta = document.querySelector('meta[name="theme-color"]');
  const btn  = document.getElementById('themeBtn');
  if (meta) meta.setAttribute('content', mode === 'light' ? '#eef7fb' : '#060608');
  if (btn) btn.innerHTML = mode === 'light'
    ? '<i class="fa-solid fa-moon"></i>'
    : '<i class="fa-solid fa-circle-half-stroke"></i>';
}
document.addEventListener('click', e => {
  if (!e.target.closest('#themeBtn')) return;
  const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  root.setAttribute('data-theme', next);
  localStorage.setItem('corillo-theme', next);
  syncThemeUi();
});
syncThemeUi();

// ── Toast ──
function showToast(msg, type = 'ok') {
  clearTimeout(toastTimer);
  toast.textContent = msg;
  toast.className = `show ${type}`;
  toastTimer = setTimeout(() => toast.className = '', 2800);
}

// ── Init ──
function init() {
  if (pb.authStore.isValid) showDashboard();
  else showLogin();
}
function showLogin() {
  loginScreen.style.display = 'flex';
  dashboard.style.display = 'none';
}
async function showDashboard() {
  loginScreen.style.display = 'none';
  dashboard.style.display = 'block';
  try {
    await pb.collection('streamers').authRefresh();
    currentRecord = pb.authStore.record;
    populateDashboard(currentRecord);
  } catch(e) {
    pb.authStore.clear();
    showLogin();
  }
}

function populateDashboard(rec) {
  // Hero
  const pfSideAva  = document.getElementById('pfSideAva');
  const pfSideName = document.getElementById('pfSideName');
  const pfSideCh   = document.getElementById('pfSideChannel');
  const pfHeroSub  = document.getElementById('pfHeroSub');
  if (pfSideName) pfSideName.textContent = rec.display_name || rec.key || '';
  if (pfHeroSub)  pfHeroSub.textContent  = rec.sub || '';
  if (sessionEmail) sessionEmail.textContent = rec.email || '';
  if (pfSideCh && rec.key) { pfSideCh.href = `/${rec.key}/`; pfSideCh.style.display = ''; }
  if (pfSideAva) updateHeroAva(rec, pfSideAva);

  // Hero color glow
  if (rec.color) {
    const m = rec.color.match(/#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})/);
    if (m) {
      const hex = m[0]; let r2, g, b;
      if (hex.length === 4) {
        r2 = parseInt(hex[1]+hex[1],16); g = parseInt(hex[2]+hex[2],16); b = parseInt(hex[3]+hex[3],16);
      } else {
        r2 = parseInt(hex.slice(1,3),16); g = parseInt(hex.slice(3,5),16); b = parseInt(hex.slice(5,7),16);
      }
      const hero = document.getElementById('pfHero');
      if (hero) hero.style.setProperty('--hero-glow', `rgba(${r2},${g},${b},.09)`);
    }
  }

  // Stream key
  streamKeyVal.textContent = rec.stream_key
    ? `${rec.key}?secret=${rec.stream_key}`
    : '(sin stream key — contacta al admin)';
  streamKeyVal.classList.add('hidden-key');
  keyVisible = false;
  toggleKey.innerHTML = '<i class="fa-regular fa-eye"></i>';
  obsKeyHint.textContent = `${rec.key}?secret=••••••••`;
  document.getElementById('obsKeyFormat').textContent = `${rec.key}?secret=••••••••`;

  // Perfil fields
  fDisplayName.value = rec.display_name || '';
  document.getElementById('fSub').value = rec.sub || '';
  fStreamTitle.value = rec.stream_title || '';
  fBio.value = rec.bio || '';
  fTwitch.value = rec.twitch || '';
  fInstagram.value = rec.instagram || '';
  fTiktok.value = rec.tiktok || '';
  document.getElementById('fVodEnabled').checked = !!rec.vod_enabled;

  // Avatar
  updateAvatarPreview(rec);

  // Paneles
  panels = (rec.panels || []).map(p => ({ title: p.title||'', text: p.text||'', url: p.url||'' }));
  renderPanels();

  // Contenido
  if (rec.vod_enabled) {
    document.getElementById('vodsDisabled').style.display = 'none';
    document.getElementById('vodsCard').style.display = '';
    loadMyVods(rec.key);
  }
  loadMyReels(rec.key);

  // Header nav
  navRight.innerHTML = `<button class="theme-btn" id="themeBtn" title="Cambiar tema"><i class="fa-solid fa-circle-half-stroke"></i></button>`;
  if (rec.key) navRight.innerHTML += `<a class="btn" href="/${rec.key}/"><i class="fa-solid fa-tv"></i> Mi canal</a>`;
  navRight.innerHTML += `<a class="btn" href="/"><i class="fa-solid fa-house"></i></a>`;
  syncThemeUi();

  initDashboardTabs();
  initContentTabs();
}

function updateHeroAva(rec, el) {
  if (rec.avatar) {
    const url = pb.files.getURL(rec, rec.avatar, { thumb: '100x100' });
    el.innerHTML = `<img src="${url}" alt="">`;
    el.style.background = rec.color || '';
  } else {
    el.textContent = (rec.display_name || rec.key || '?')[0].toUpperCase();
    el.style.background = rec.color || '';
  }
}

function updateAvatarPreview(rec) {
  if (rec.avatar) {
    const url = pb.files.getURL(rec, rec.avatar, { thumb: '100x100' });
    avatarInitial.style.display = 'none';
    const img = avatarPreview.querySelector('img') || document.createElement('img');
    img.src = url;
    if (!img.parentNode) avatarPreview.appendChild(img);
  } else {
    avatarInitial.textContent = (rec.display_name || rec.key || '?')[0].toUpperCase();
    avatarInitial.style.display = '';
    const img = avatarPreview.querySelector('img');
    if (img) img.remove();
  }
  const pfSideAva = document.getElementById('pfSideAva');
  if (pfSideAva) updateHeroAva(rec, pfSideAva);
}

// ── Dashboard tabs ──
function initDashboardTabs() {
  const tabs   = document.querySelectorAll('.pf-tb');
  const panels = document.querySelectorAll('.pf-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.dataset.tab)?.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Stats chips → jump to contenido
  document.getElementById('pfStatVodsBtn')?.addEventListener('click', () => {
    switchTab('t-contenido');
    // switch inner tab to vods
    switchCtTab('ct-vods');
  });
  document.getElementById('pfStatReelsBtn')?.addEventListener('click', () => {
    switchTab('t-contenido');
    switchCtTab('ct-reels');
  });
}

function switchTab(tabId) {
  document.querySelectorAll('.pf-tb').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.pf-panel').forEach(p => p.classList.remove('active'));
  document.querySelector(`[data-tab="${tabId}"]`)?.classList.add('active');
  document.getElementById(tabId)?.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Content inner tabs ──
function initContentTabs() {
  document.querySelectorAll('#ctTabs .ct-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      switchCtTab(tab.dataset.ctpanel);
    });
  });
}

function switchCtTab(panelId) {
  document.querySelectorAll('#ctTabs .ct-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('#t-contenido .ct-panel').forEach(p => p.classList.remove('active'));
  document.querySelector(`[data-ctpanel="${panelId}"]`)?.classList.add('active');
  document.getElementById(panelId)?.classList.add('active');
}

// ── Helpers ──
function fmtDur(s) {
  if (!s) return '';
  const h = Math.floor(s/3600), m = Math.floor((s%3600)/60), ss = Math.floor(s%60);
  return h > 0 ? `${h}h ${String(m).padStart(2,'0')}m` : `${m}:${String(ss).padStart(2,'0')}`;
}
function fmtMB(b) {
  if (!b) return '';
  return b > 1073741824 ? (b/1073741824).toFixed(1)+' GB' : Math.round(b/1048576)+' MB';
}
function fmtDate(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('es-PR', { day:'numeric', month:'short', year:'numeric' });
}
function esc(s) { return (s||'').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }
function fmtSec(sec) {
  const m = Math.floor(sec/60), s = Math.floor(sec%60);
  return `${m}:${String(s).padStart(2,'0')}`;
}
function parseSec(str) {
  if (!str) return NaN;
  const parts = str.trim().split(':').map(Number);
  if (parts.some(isNaN)) return NaN;
  if (parts.length === 1) return parts[0];
  if (parts.length === 2) return parts[0]*60 + parts[1];
  if (parts.length === 3) return parts[0]*3600 + parts[1]*60 + parts[2];
  return NaN;
}

// ── VODs ──
async function loadMyVods(channel) {
  try {
    const res   = await pb.collection('vods').getList(1, 50, { filter:`channel="${channel}"`, sort:'-date' });
    const items = res.items || [];
    const list  = document.getElementById('vodsList');
    const empty = document.getElementById('vodsEmpty');

    // Update hero stat
    const pfStatVods = document.getElementById('pfStatVods');
    if (pfStatVods) pfStatVods.textContent = items.length;

    if (!items.length) { empty.style.display = ''; return; }

    list.innerHTML = items.map(v => {
      const vidSrc = v.filename ? `/vods/${channel}/${v.filename}` : '';
      return `
      <div>
        <div class="vod-row" id="vrow-${v.id}">
          <a class="vod-row-link" href="/vods/v/?id=${v.id}" target="_blank" rel="noopener">
            <div class="vod-row-thumb">
              ${v.thumb ? `<img src="${v.thumb}" alt="" onerror="this.style.display='none'" loading="lazy">` : channel.toUpperCase()[0]}
            </div>
            <div class="vod-row-info">
              <div class="vod-row-date">${fmtDate(v.date)}</div>
              <div class="vod-row-meta">${[fmtDur(v.duration), fmtMB(v.size)].filter(Boolean).join(' · ')}</div>
            </div>
          </a>
          <div class="vod-row-actions">
            <button class="vod-row-reel" id="rbtn-${v.id}" onclick="toggleReelPanel('${v.id}',${v.duration||0},'${esc(vidSrc)}','${esc(v.thumb||'')}')" title="Crear Reel"><i class="fa-solid fa-scissors"></i></button>
            <button class="vod-row-del" onclick="deleteVod('${v.id}')" title="Borrar VOD"><i class="fa-solid fa-trash"></i></button>
          </div>
        </div>

        <div class="reel-panel" id="rpanel-${v.id}">
          <div class="reel-panel-header">
            <span class="reel-panel-title"><i class="fa-solid fa-scissors"></i> Crear Reel</span>
            <span class="reel-panel-dur">${fmtDur(v.duration)||'?'} total</span>
          </div>
          <div class="reel-panel-body">
            ${vidSrc ? `
            <div class="reel-crop-layout">
              <div class="reel-video-wrap" id="rvwrap-${v.id}">
                <video class="reel-video" id="rvid-${v.id}" preload="metadata" muted playsinline
                  ${v.thumb ? `poster="${esc(v.thumb)}"` : ''}>
                  <source src="${esc(vidSrc)}" type="video/mp4">
                </video>
                <canvas class="reel-crop-canvas" id="rcanvas-${v.id}"></canvas>
                <div class="reel-video-overlay" id="rvoverlay-${v.id}">Cargando…</div>
                <div class="reel-video-badge" id="rvbadge-${v.id}">0:00</div>
              </div>
              <div class="reel-preview-wrap">
                <div class="reel-preview-label"><i class="fa-solid fa-mobile-screen"></i> Preview 9:16</div>
                <canvas class="reel-preview-canvas" id="rpreview-${v.id}"></canvas>
              </div>
            </div>` : ''}

            <div class="rtl" id="rtl-${v.id}" data-duration="${v.duration||0}">
              <div class="rtl-track">
                <div class="rtl-before" id="rtl-before-${v.id}"></div>
                <div class="rtl-fill"   id="rtl-fill-${v.id}"></div>
                <div class="rtl-after"  id="rtl-after-${v.id}"></div>
                <div class="rtl-handle" id="rtl-hs-${v.id}">
                  <span class="rtl-tip" id="rtl-tip-${v.id}"></span>
                </div>
              </div>
            </div>

            <div class="reel-info-row">
              <div>
                <div class="reel-starttime">
                  <span>Inicio</span><span id="rstart-display-${v.id}">0:00</span>
                  &nbsp;→&nbsp;
                  <span id="rend-display-${v.id}" style="color:var(--muted)">0:30</span>
                </div>
              </div>
              <div class="reel-dur-pills" id="rdur-pills-${v.id}">
                <button class="reel-dur-pill" data-sec="15">15s</button>
                <button class="reel-dur-pill active" data-sec="30">30s</button>
                <button class="reel-dur-pill" data-sec="45">45s</button>
                <button class="reel-dur-pill" data-sec="60">60s</button>
              </div>
            </div>
            <input type="hidden" id="rstart-${v.id}" value="0">
            <input type="hidden" id="rend-${v.id}" value="30">

            <div class="reel-public-row">
              <label class="vod-toggle"><input type="checkbox" id="rpub-${v.id}"><span class="vod-slider"></span></label>
              <span>Publicar en <a href="/reels/" target="_blank" rel="noopener">corillo.live/reels/</a></span>
            </div>
            <div class="reel-actions">
              <button class="btn primary" id="rgen-${v.id}" onclick="generateReel('${v.id}')"><i class="fa-solid fa-wand-magic-sparkles"></i> Generar Reel</button>
              <button class="btn" onclick="toggleReelPanel('${v.id}',0,'','')">Cancelar</button>
            </div>
