---
// Dashboard del streamer — auth, stream key, perfil, VODs, Reels
// NO usa BaseLayout: tiene header propio y estilos propios
---
<!doctype html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>Mi perfil — CORILLO</title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <meta name="robots" content="noindex, nofollow">
  <meta name="theme-color" content="#060608">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/assets/styles.css">
  <script src="https://cdn.jsdelivr.net/npm/pocketbase/dist/pocketbase.umd.js" is:inline></script>
  <script is:inline>
    const savedTheme = localStorage.getItem('corillo-theme');
    if (savedTheme === 'light' || savedTheme === 'dark') {
      document.documentElement.setAttribute('data-theme', savedTheme);
    }
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: var(--ink); color: var(--white); font-family: var(--body); min-height: 100vh; margin: 0; }

    /* ── Header ── */
    .pf-header {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px; height: 52px;
      background: rgba(6,6,8,.88); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .pf-header-brand { display: flex; align-items: center; }
    .pf-header-brand svg { height: 30px; width: auto; }
    .pf-header-brand .crl-brand-word { fill: #e8f6ff; }
    .pf-header-brand .crl-brand-ring-outer { stroke: #e8f6ff; }
    .pf-header-right { display: flex; align-items: center; gap: 8px; }
    [data-theme="light"] .pf-header { background: rgba(238,247,251,.92); }
    [data-theme="light"] .pf-header-brand .crl-brand-word { fill: #0c1a20; }
    [data-theme="light"] .pf-header-brand .crl-brand-ring-outer { stroke: #0c1a20; }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 7px; font-size: .75rem;
      font-family: var(--mono); letter-spacing: 1px; text-transform: uppercase;
      border: 1px solid var(--border); background: transparent;
      color: var(--white); cursor: pointer; transition: .15s; text-decoration: none;
    }
    .btn:hover { border-color: var(--border-h); background: rgba(255,255,255,.05); }
    .btn.primary { background: var(--accent); color: #000; border-color: transparent; font-weight: 700; }
    .btn.primary:hover { opacity: .88; }
    .btn.danger { border-color: rgba(223,48,48,.35); color: #e17055; }
    .btn.danger:hover { background: rgba(223,48,48,.08); }
    .btn.sm { padding: 4px 10px; font-size: .7rem; }

    /* ── Spinner ── */
    .spinner {
      display: inline-block; width: 13px; height: 13px;
      border: 2px solid rgba(255,255,255,.2); border-top-color: var(--white);
      border-radius: 50%; animation: spin .6s linear infinite; vertical-align: middle;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Toast ── */
    #toast {
      position: fixed; bottom: 24px; left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 10px; padding: 12px 20px;
      font-size: .88rem; font-family: var(--mono); letter-spacing: 1px;
      z-index: 300; transition: transform .25s ease;
      pointer-events: none; white-space: nowrap;
    }
    #toast.show { transform: translateX(-50%) translateY(0); }
    #toast.ok  { border-color: rgba(0,184,148,.4); color: #00b894; }
    #toast.err { border-color: rgba(223,48,48,.4); color: #e17055; }

    /* ════════════════════════════════
       LOGIN SCREEN
    ════════════════════════════════ */
    #loginScreen {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: calc(100vh - 52px); gap: 24px; padding: 40px 20px;
    }
    .login-brand-wrap {
      padding: 14px 18px; border-radius: 16px;
      border: 1px solid var(--border);
      background: linear-gradient(160deg,rgba(13,28,40,.82),rgba(7,17,24,.64));
      box-shadow: 0 12px 38px rgba(0,0,0,.22);
    }
    .login-brand svg { height: 52px; width: auto; display: block; }
    .login-brand .crl-brand-word { fill: #e8f6ff; }
    .login-brand .crl-brand-ring-outer { stroke: #e8f6ff; }
    [data-theme="light"] .login-brand-wrap { background: rgba(255,255,255,.72); border-color: rgba(0,0,0,.1); }
    .login-card {
      background: var(--panel); border: 1px solid var(--border);
      border-radius: 14px; padding: 32px 36px; width: 100%; max-width: 380px;
    }
    .login-card h2 { font-family: var(--display); font-size: 1.8rem; margin-bottom: 6px; letter-spacing: 1px; }
    .login-card > p { color: var(--muted); font-size: .85rem; margin-bottom: 24px; }
    [data-theme="light"] .login-card > p { color: rgba(5,16,21,.56); }

    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
    .field label { font-size: .7rem; font-family: var(--mono); letter-spacing: 2px; text-transform: uppercase; color: var(--muted); }
    .field input, .field textarea, .field select {
      background: var(--surface); border: 1px solid var(--border); border-radius: 8px;
      padding: 10px 14px; color: var(--white); font-family: var(--body); font-size: .92rem;
      transition: .15s; width: 100%;
    }
    .field textarea { resize: vertical; min-height: 80px; }
    .field input:focus, .field textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,191,255,.07); }
    [data-theme="light"] .field input, [data-theme="light"] .field textarea { color: #0c1a20; }

    .error-msg { color: #e17055; font-size: .85rem; font-family: var(--mono); margin-bottom: 10px; display: none; }
    .success-msg { color: #00b894; font-size: .85rem; font-family: var(--mono); margin-bottom: 10px; }
    .forgot-link {
      display: block; width: 100%; margin-top: 10px;
      background: none; border: none; color: var(--muted);
      font-size: .75rem; font-family: var(--mono); cursor: pointer;
      text-align: center; transition: color .15s;
    }
    .forgot-link:hover { color: var(--white); }

    /* ════════════════════════════════
       DASHBOARD
    ════════════════════════════════ */
    #dashboard { display: none; }

    /* ── Hero ── */
    .pf-hero {
      position: relative; overflow: hidden;
      padding: 28px 40px 24px;
      border-bottom: 1px solid var(--border);
    }
    .pf-hero::before {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 70% 200% at -5% 50%, rgba(0,191,255,.07) 0%, transparent 60%);
    }
    .pf-hero-inner {
      position: relative; z-index: 1;
      display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
    }
    .pf-hero-ava {
      width: 72px; height: 72px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,.12); background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--display); font-size: 1.8rem; color: #000;
      overflow: hidden; flex-shrink: 0;
      box-shadow: 0 4px 20px rgba(0,0,0,.3);
    }
    .pf-hero-ava img { width: 100%; height: 100%; object-fit: cover; }
    .pf-hero-text { flex: 1; min-width: 0; }
    .pf-hero-name { font-family: var(--display); font-size: 2rem; letter-spacing: 2px; line-height: 1; margin-bottom: 4px; }
    .pf-hero-sub { font-size: .82rem; color: var(--muted); margin-bottom: 8px; min-height: 1.2em; }
    .pf-hero-link {
      font-family: var(--mono); font-size: 10px; letter-spacing: 1px;
      color: var(--accent); text-decoration: none; opacity: .7; transition: opacity .15s;
      display: inline-flex; align-items: center; gap: 5px;
    }
    .pf-hero-link:hover { opacity: 1; }
    .pf-hero-stats { display: flex; gap: 10px; align-items: center; flex-shrink: 0; }
    .pf-stat {
      text-align: center; padding: 10px 18px;
      background: rgba(255,255,255,.03); border: 1px solid var(--border);
      border-radius: 10px; cursor: pointer; transition: border-color .15s;
    }
    .pf-stat:hover { border-color: rgba(0,191,255,.2); }
    .pf-stat strong {
      display: block; font-family: var(--display); font-size: 1.5rem;
      letter-spacing: 1px; color: var(--white); line-height: 1; margin-bottom: 2px;
    }
    .pf-stat span { font-family: var(--mono); font-size: .62rem; letter-spacing: 2px; color: var(--muted); text-transform: uppercase; }

    /* ── Tab bar ── */
    .pf-tabbar {
      position: sticky; top: 52px; z-index: 50;
      display: flex;
      background: rgba(3,10,14,.92); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 32px; overflow-x: auto; scrollbar-width: none;
    }
    .pf-tabbar::-webkit-scrollbar { display: none; }
    .pf-tb {
      display: flex; align-items: center; gap: 8px;
      padding: 0 18px; height: 46px;
      background: none; border: none; border-bottom: 2px solid transparent;
      font-family: var(--mono); font-size: .7rem; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--muted); cursor: pointer;
      transition: color .15s; white-space: nowrap; margin-bottom: -1px;
      -webkit-tap-highlight-color: transparent;
    }
    .pf-tb i { font-size: 11px; }
    .pf-tb:hover { color: var(--white); }
    .pf-tb.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* ── Tab panels ── */
    .pf-panels { padding: 36px 40px 100px; }
    .pf-panel { display: none; max-width: 680px; }
    .pf-panel.active { display: block; }
    .pf-panel.wide { max-width: 900px; }

    /* ── Section label ── */
    .pf-s-label {
      font-family: var(--mono); font-size: .65rem; letter-spacing: 3px;
      text-transform: uppercase; color: var(--muted);
      margin-bottom: 14px; margin-top: 36px; padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 8px;
    }
    .pf-s-label:first-child { margin-top: 0; }
    .pf-s-label i { color: var(--accent); font-size: 10px; }

    /* ── Cards ── */
    .card { background: var(--panel); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 12px; }
    .card-title { font-family: var(--mono); font-size: .72rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin-bottom: 18px; }
    .form-grid { display: flex; flex-direction: column; gap: 14px; }
    .form-actions { display: flex; align-items: center; justify-content: space-between; margin-top: 6px; flex-wrap: wrap; gap: 10px; }
    .save-status { font-size: .75rem; font-family: var(--mono); color: var(--muted); }
    .save-status.ok  { color: #00b894; }
    .save-status.err { color: #e17055; }
    .field-hint { font-size: .7rem; color: var(--muted); line-height: 1.5; margin-top: -4px; }

    /* ── Stream key ── */
    .key-hero {
      background: linear-gradient(135deg,rgba(0,191,255,.06),rgba(0,191,255,.02));
      border: 1px solid rgba(0,191,255,.15); border-radius: 12px;
      padding: 20px; margin-bottom: 14px;
    }
    .key-label { font-family: var(--mono); font-size: .65rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
    .key-value-wrap {
      display: flex; align-items: center; gap: 8px;
      background: rgba(0,0,0,.25); border: 1px solid rgba(0,191,255,.1);
      border-radius: 8px; padding: 10px 14px;
    }
    .key-value { flex: 1; font-family: var(--mono); font-size: .82rem; color: var(--white); word-break: break-all; letter-spacing: .5px; }
    .key-value.hidden-key { filter: blur(5px); user-select: none; }
    .key-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .icon-btn {
      width: 30px; height: 30px; border-radius: 6px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: .82rem; transition: .15s; flex-shrink: 0;
    }
    .icon-btn:hover { border-color: var(--border-h); color: var(--white); background: rgba(255,255,255,.06); }
    .icon-btn.copied { border-color: #00b894; color: #00b894; }
    .key-warning {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 10px 14px; border-radius: 8px; font-size: .85rem;
      background: rgba(223,48,48,.07); border: 1px solid rgba(223,48,48,.18);
      color: rgba(242,239,233,.7); margin-bottom: 14px;
    }
    .key-warning i { color: #e17055; margin-top: 2px; flex-shrink: 0; }
    .key-warning.neutral { background: rgba(255,255,255,.03); border-color: var(--border); }
    .key-warning.neutral i { color: var(--muted); }
    .obs-hint {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 8px; padding: 14px; font-size: .78rem; line-height: 1.7;
    }
    .obs-hint strong { font-family: var(--mono); font-size: .8rem; letter-spacing: 1px; color: var(--muted); text-transform: uppercase; }
    .obs-hint code { font-family: var(--mono); color: var(--accent); font-size: .85rem; }
    [data-theme="light"] .key-value-wrap { background: rgba(255,255,255,.64); }
    [data-theme="light"] .obs-hint { background: rgba(255,255,255,.64); }

    /* ── Avatar ── */
    .avatar-row { display: flex; align-items: center; gap: 18px; }
    .avatar-preview {
      width: 72px; height: 72px; border-radius: 50%;
      border: 2px solid var(--border); background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      font-family: var(--display); font-size: 1.8rem; color: var(--muted);
      flex-shrink: 0; overflow: hidden;
    }
    .avatar-preview img { width: 100%; height: 100%; object-fit: cover; }
    .file-input { display: none; }
    .avatar-actions { display: flex; flex-direction: column; gap: 8px; }

    /* ── Social grid ── */
    .social-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    /* ── VOD toggle ── */
    .vod-toggle { position: relative; display: inline-block; width: 38px; height: 21px; flex-shrink: 0; }
    .vod-toggle input { opacity: 0; width: 0; height: 0; }
    .vod-slider { position: absolute; inset: 0; background: rgba(255,255,255,.1); border-radius: 21px; cursor: pointer; transition: .2s; border: 1px solid rgba(255,255,255,.1); }
    .vod-slider::before { content: ''; position: absolute; width: 15px; height: 15px; left: 2px; top: 2px; background: rgba(255,255,255,.4); border-radius: 50%; transition: .2s; }
    .vod-toggle input:checked + .vod-slider { background: var(--accent); border-color: var(--accent); }
    .vod-toggle input:checked + .vod-slider::before { transform: translateX(17px); background: #030a0e; }

    /* ── Content inner tabs ── */
    .ct-tabs { display: flex; gap: 4px; border-bottom: 1px solid var(--border); margin-bottom: 20px; }
    .ct-tab {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 16px; background: none; border: none;
      font-family: var(--mono); font-size: .7rem; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--muted); cursor: pointer;
      border-bottom: 2px solid transparent; margin-bottom: -1px; transition: .15s;
    }
    .ct-tab:hover { color: var(--white); }
    .ct-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
    .ct-panel { display: none; }
    .ct-panel.active { display: block; }

    /* ── VOD list ── */
    .vod-rows { display: flex; flex-direction: column; gap: 8px; }
    .vod-row {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px; background: var(--surface);
      border: 1px solid var(--border); border-radius: 10px; transition: border-color .15s;
    }
    .vod-row:hover { border-color: rgba(0,191,255,.15); }
    .vod-row-thumb {
      width: 88px; height: 50px; border-radius: 6px;
      background: rgba(0,191,255,.06); flex-shrink: 0;
      overflow: hidden; display: flex; align-items: center; justify-content: center;
      font-family: var(--display); font-size: 1rem; color: rgba(0,191,255,.2); position: relative;
    }
    .vod-row-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .vod-row-info { flex: 1; min-width: 0; }
    .vod-row-date { font-family: var(--mono); font-size: .72rem; color: var(--white); }
    .vod-row-meta { font-family: var(--mono); font-size: .65rem; color: var(--muted); margin-top: 2px; }
    .vod-row-link { text-decoration: none; color: inherit; flex: 1; min-width: 0; display: flex; align-items: center; gap: 12px; }
    .vod-row-link:hover .vod-row-date { color: var(--accent); }
    .vod-row-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .vod-row-del, .vod-row-reel {
      width: 30px; height: 30px; border-radius: 6px;
      border: 1px solid var(--border); background: transparent;
      color: var(--muted); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-size: .78rem; transition: .15s; flex-shrink: 0;
    }
    .vod-row-del:hover  { border-color: #e17055; color: #e17055; }
    .vod-row-reel:hover { border-color: var(--accent); color: var(--accent); }
    .vod-row-reel.active { border-color: var(--accent); color: var(--accent); background: rgba(0,191,255,.08); }
    .vod-row-del.loading { opacity: .4; pointer-events: none; }

    /* ── Reel panel ── */
    .reel-panel {
      display: none; margin-top: 6px; margin-bottom: 8px;
      background: var(--panel); border: 1px solid rgba(0,191,255,.18);
      border-radius: 12px; overflow: hidden;
    }
    .reel-panel.open { display: block; }
    .reel-panel-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 18px 12px;
      border-bottom: 1px solid rgba(0,191,255,.1);
      background: rgba(0,191,255,.03);
    }
    .reel-panel-title {
      font-family: var(--mono); font-size: .68rem; letter-spacing: 2px;
      text-transform: uppercase; color: var(--accent);
    }
    .reel-panel-dur { font-family: var(--mono); font-size: .65rem; color: var(--muted); }
    .reel-panel-body { padding: 18px 20px 20px; }

    /* ── Reel video preview ── */
    .reel-video-wrap {
      position: relative; border-radius: 8px; overflow: hidden;
      background: #000; margin-bottom: 18px;
      aspect-ratio: 16/9;
      border: 1px solid rgba(255,255,255,.08);
    }
    .reel-video {
      width: 100%; height: 100%; object-fit: contain;
      display: block;
    }
    .reel-video-overlay {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,.4);
      font-family: var(--mono); font-size: .65rem; letter-spacing: 2px;
      color: rgba(255,255,255,.4); text-transform: uppercase;
      pointer-events: none; transition: opacity .2s;
    }
    .reel-video-wrap.loaded .reel-video-overlay { opacity: 0; }
    /* Scrub position badge */
    .reel-video-badge {
      position: absolute; bottom: 8px; right: 10px;
      background: rgba(0,0,0,.72); border-radius: 5px;
      font-family: var(--mono); font-size: .72rem; letter-spacing: 1px;
      color: rgba(255,255,255,.9); padding: 3px 8px;
      pointer-events: none;
    }

    /* ── Reel Timeline ── */
    .rtl { padding: 4px 0 8px; user-select: none; touch-action: none; }
    .rtl-track {
      position: relative; height: 8px;
      background: rgba(255,255,255,.1); border-radius: 4px;
      margin: 28px 14px 10px; cursor: pointer;
    }
    [data-theme="light"] .rtl-track { background: rgba(0,0,0,.12); }
    .rtl-fill {
      position: absolute; height: 100%;
      background: var(--accent); border-radius: 4px;
      opacity: .55; pointer-events: none;
    }
    .rtl-handle {
      position: absolute; top: 50%;
      transform: translate(-50%,-50%);
      width: 20px; height: 20px; border-radius: 50%;
      background: var(--white); border: 2.5px solid var(--accent);
      cursor: grab; box-shadow: 0 2px 8px rgba(0,0,0,.45);
      transition: box-shadow .1s, transform .1s; z-index: 3;
      -webkit-tap-highlight-color: transparent;
    }
    .rtl-handle::before { content: ''; position: absolute; inset: -14px; border-radius: 50%; }
    .rtl-handle:hover { box-shadow: 0 2px 14px rgba(0,191,255,.5); }
    .rtl-handle:active, .rtl-handle.dragging {
      cursor: grabbing; transform: translate(-50%,-50%) scale(1.22);
      box-shadow: 0 4px 18px rgba(0,191,255,.45);
    }
    .rtl-handle .rtl-tip {
      display: none; position: absolute; bottom: calc(100% + 10px); left: 50%;
      transform: translateX(-50%);
      background: var(--panel); border: 1px solid var(--border-h);
      color: var(--white); font-family: var(--mono); font-size: 10px;
      padding: 3px 7px; border-radius: 5px; white-space: nowrap;
      pointer-events: none; z-index: 10;
    }
    .rtl-handle.dragging .rtl-tip { display: block; }

    /* ── Reel time inputs ── */
    .reel-time-row {
      display: flex; align-items: flex-end; gap: 12px; margin: 16px 0;
    }
    .reel-time-field { display: flex; flex-direction: column; gap: 6px; flex: 1; }
    .reel-time-field label {
      font-family: var(--mono); font-size: .62rem; letter-spacing: 2px;
      text-transform: uppercase; color: var(--muted);
    }
    .reel-time-input {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 12px;
      color: var(--white); font-family: var(--mono); font-size: 1rem;
      letter-spacing: 1px; text-align: center; width: 100%; transition: .15s;
    }
    .reel-time-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(0,191,255,.07); }
    [data-theme="light"] .reel-time-input { color: #0c1a20; }
    .reel-time-mid {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      padding-bottom: 10px; flex-shrink: 0;
    }
    .reel-time-mid i { color: var(--muted); font-size: .75rem; }
    .rtl-t-dur {
      font-size: 11px; font-weight: 700; letter-spacing: 1px;
      padding: 3px 9px; border-radius: 5px; background: rgba(255,255,255,.05);
      font-family: var(--mono); white-space: nowrap;
    }
    .rtl-t-dur.ok  { color: #00b894; background: rgba(0,184,148,.08); }
    .rtl-t-dur.err { color: #e17055; background: rgba(223,48,48,.08); }

    .reel-public-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; font-size: .85rem; }
    .reel-public-row a { color: var(--accent); text-decoration: none; }
    .reel-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .reel-result {
      margin-top: 14px; padding: 12px 14px;
      background: rgba(0,184,148,.07); border: 1px solid rgba(0,184,148,.2);
      border-radius: 8px; font-size: .85rem; display: none;
    }
    .reel-result.show { display: block; }
    .reel-result a { color: var(--accent); text-decoration: none; }

    /* ── Reel list ── */
    .reel-rows { display: flex; flex-direction: column; gap: 8px; }
    .reel-row {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 12px; background: var(--surface);
      border: 1px solid var(--border); border-radius: 10px;
    }
    .reel-row-thumb {
      width: 40px; height: 72px; border-radius: 5px;
      background: rgba(0,191,255,.06); flex-shrink: 0; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      font-size: .75rem; color: rgba(0,191,255,.3); position: relative;
    }
    .reel-row-thumb img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
    .reel-row-info { flex: 1; min-width: 0; }
    .reel-row-date { font-family: var(--mono); font-size: .72rem; color: var(--white); }
    .reel-row-meta { font-family: var(--mono); font-size: .65rem; color: var(--muted); margin-top: 2px; }
    .reel-row-pub {
      display: inline-flex; align-items: center; gap: 4px;
      font-family: var(--mono); font-size: .62rem; letter-spacing: 1px;
      text-transform: uppercase; padding: 2px 6px; border-radius: 3px; margin-top: 4px;
    }
    .reel-row-pub.pub  { background: rgba(0,191,255,.1); color: var(--accent); }
    .reel-row-pub.priv { background: rgba(255,255,255,.05); color: var(--muted); }
    .reel-row-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .reel-row-dl, .reel-row-del {
      width: 30px; height: 30px; border-radius: 6px;
      border: 1px solid var(--border); background: transparent; color: var(--muted);
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      font-size: .78rem; transition: .15s; text-decoration: none;
    }
    .reel-row-dl:hover  { border-color: var(--accent); color: var(--accent); }
    .reel-row-del:hover { border-color: #e17055; color: #e17055; }
    .reel-row-del.loading { opacity: .4; pointer-events: none; }

    /* ── Paneles ── */
    .panel-row {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 14px 16px;
      display: flex; flex-direction: column; gap: 10px; margin-bottom: 10px;
    }
    .panel-row-header { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
    .panel-row-label { font-family: var(--mono); font-size: .7rem; letter-spacing: 2px; color: var(--muted); }

    /* ── Details accordion ── */
    .pf-details { border: 1px solid var(--border); border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .pf-details summary {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 18px; cursor: pointer; list-style: none;
      font-family: var(--mono); font-size: .72rem; letter-spacing: 2px;
      text-transform: uppercase; color: var(--muted); transition: .15s;
      background: var(--panel);
    }
    .pf-details summary::-webkit-details-marker { display: none; }
    .pf-details summary::after { content: '\002B'; font-size: 1rem; opacity: .5; }
    .pf-details[open] summary::after { content: '\2212'; }
    .pf-details summary:hover { color: var(--white); }
    .pf-details-body { padding: 18px; background: var(--panel); border-top: 1px solid var(--border); }

    /* ── Session card ── */
    .session-card {
      display: flex; align-items: center; justify-content: space-between;
      gap: 16px; flex-wrap: wrap;
      padding: 16px 18px; background: var(--panel);
      border: 1px solid var(--border); border-radius: 10px; margin-top: 10px;
    }

    /* ════════════════════════════════
       LIGHT MODE
    ════════════════════════════════ */
    [data-theme="light"] .pf-tabbar { background: rgba(238,247,251,.95); }
    [data-theme="light"] .pf-hero::before { background: radial-gradient(ellipse 70% 200% at -5% 50%, rgba(0,136,187,.06) 0%, transparent 60%); }
    [data-theme="light"] .pf-stat { background: rgba(0,0,0,.02); }
    [data-theme="light"] .pf-details summary { background: rgba(255,255,255,.7); }
    [data-theme="light"] .pf-details-body { background: rgba(255,255,255,.7); }
    [data-theme="light"] .session-card { background: rgba(255,255,255,.7); }
    [data-theme="light"] .panel-row { background: rgba(255,255,255,.64); }
    [data-theme="light"] .card { background: rgba(255,255,255,.7); }
    [data-theme="light"] .vod-row { background: rgba(255,255,255,.64); }
    [data-theme="light"] .reel-row { background: rgba(255,255,255,.64); }
    [data-theme="light"] .reel-panel { background: rgba(255,255,255,.8); }
    [data-theme="light"] .key-warning { color: rgba(5,16,21,.7); }

    /* ════════════════════════════════
       MOBILE
    ════════════════════════════════ */
    @media (max-width: 760px) {
      .pf-hero { padding: 20px 16px 18px; }
      .pf-hero-name { font-size: 1.6rem; }
      .pf-hero-stats { display: none; }
      .pf-tabbar { padding: 0 8px; }
      .pf-panels { padding: 24px 16px 80px; }
      .social-grid { grid-template-columns: 1fr; }
      .reel-video-wrap { margin-bottom: 14px; }
    }
    @media (max-width: 480px) {
      .login-card { padding: 24px 20px; }
      .key-hero { padding: 14px; }
      .card { padding: 16px; }
    }
  </style>
</head>
<body class="crl-body">

<!-- ── HEADER ── -->
<header class="pf-header">
  <a href="/" class="pf-header-brand" aria-label="CORILLO">
    <svg viewBox="0 0 304 88" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs><radialGradient id="pf-ng" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#00bfff" stop-opacity="0.18"/><stop offset="100%" stop-color="#00bfff" stop-opacity="0"/></radialGradient></defs>
      <text x="0" y="74" font-family="Bebas Neue, cursive" font-size="82" class="crl-brand-word">C</text>
      <circle cx="72" cy="42" r="36" fill="url(#pf-ng)"/>
      <circle cx="72" cy="42" r="34" class="crl-brand-ring-outer" stroke-width="9" fill="none"/>
      <circle cx="72" cy="42" r="20" stroke="#00bfff" stroke-width="6" fill="none"/>
      <circle cx="72" cy="42" r="8" fill="#00bfff"/>
      <circle cx="72" cy="42" r="3.5" fill="#00ff9d"/>
      <text x="114" y="74" font-family="Bebas Neue, cursive" font-size="82" class="crl-brand-word">RILLO</text>
    </svg>
  </a>
  <div class="pf-header-right" id="navRight">
    <button class="theme-btn" id="themeBtn" title="Cambiar tema"><i class="fa-solid fa-circle-half-stroke"></i></button>
    <a class="btn" href="/"><i class="fa-solid fa-house"></i></a>
  </div>
</header>

<!-- ══════════════════════════════════
     LOGIN
══════════════════════════════════ -->
<div id="loginScreen">
  <div class="login-brand-wrap">
    <a href="/" class="login-brand" aria-label="CORILLO">
      <svg viewBox="0 0 250 88" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs><radialGradient id="pf-lg2" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#00bfff" stop-opacity="0.18"/><stop offset="100%" stop-color="#00bfff" stop-opacity="0"/></radialGradient></defs>
        <text x="0" y="74" font-family="Bebas Neue, cursive" font-size="82" class="crl-brand-word">C</text>
        <circle cx="72" cy="42" r="36" fill="url(#pf-lg2)"/>
        <circle cx="72" cy="42" r="34" class="crl-brand-ring-outer" stroke-width="9" fill="none"/>
        <circle cx="72" cy="42" r="20" stroke="#00bfff" stroke-width="6" fill="none"/>
        <circle cx="72" cy="42" r="8" fill="#00bfff"/>
        <circle cx="72" cy="42" r="3.5" fill="#00ff9d"/>
        <text x="114" y="74" font-family="Bebas Neue, cursive" font-size="82" class="crl-brand-word">RILLO</text>
      </svg>
    </a>
  </div>
  <div class="login-card" id="loginCard">
    <h2>MI PERFIL</h2>
    <p>Entra con tu cuenta de CORILLO para gestionar tu canal.</p>
    <div class="field">
      <label>Email</label>
      <input type="email" id="loginEmail" placeholder="tu@email.com" autocomplete="email">
    </div>
    <div class="field">
      <label>Contraseña</label>
      <input type="password" id="loginPass" placeholder="••••••••" autocomplete="current-password">
    </div>
    <div class="error-msg" id="loginErr"></div>
    <button class="btn primary" id="loginBtn" style="width:100%;justify-content:center;padding:10px;margin-top:4px">
      <i class="fa-solid fa-arrow-right-to-bracket"></i> Entrar
    </button>
    <button class="forgot-link" id="forgotBtn">¿Olvidaste tu contraseña?</button>
    <p style="margin-top:14px;font-size:.75rem;color:var(--muted);text-align:center">
      ¿No tienes cuenta? <a href="/join/" style="color:var(--accent);text-decoration:none">Solicita acceso →</a>
    </p>
  </div>
  <div class="login-card" id="resetCard" style="display:none">
    <h2>RESET</h2>
    <p>Ingresa tu email y te enviaremos un link para crear una nueva contraseña.</p>
    <div class="field">
      <label>Email</label>
      <input type="email" id="resetEmail" placeholder="tu@email.com" autocomplete="email">
    </div>
    <div class="error-msg" id="resetErr"></div>
    <div class="success-msg" id="resetOk" style="display:none"></div>
    <button class="btn primary" id="resetBtn" style="width:100%;justify-content:center;padding:10px;margin-top:4px">
      <i class="fa-solid fa-paper-plane"></i> Enviar link
    </button>
    <button class="forgot-link" id="backToLogin">← Volver al login</button>
  </div>
</div>

<!-- ══════════════════════════════════
     DASHBOARD
══════════════════════════════════ -->
<div id="dashboard">

  <!-- ── Hero ── -->
  <div class="pf-hero" id="pfHero">
    <div class="pf-hero-inner">
      <div class="pf-hero-ava" id="pfSideAva">?</div>
      <div class="pf-hero-text">
        <div class="pf-hero-name" id="pfSideName">—</div>
        <div class="pf-hero-sub" id="pfHeroSub"></div>
        <a class="pf-hero-link" id="pfSideChannel" href="#" style="display:none">
          <i class="fa-solid fa-arrow-up-right-from-square" style="font-size:8px"></i> Ver mi canal
        </a>
      </div>
      <div class="pf-hero-stats">
        <div class="pf-stat" id="pfStatVodsBtn" style="cursor:pointer" title="Ir a transmisiones">
          <strong id="pfStatVods">—</strong>
          <span>VODs</span>
        </div>
        <div class="pf-stat" id="pfStatReelsBtn" style="cursor:pointer" title="Ir a reels">
          <strong id="pfStatReels">—</strong>
          <span>Reels</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Tab bar ── -->
  <div class="pf-tabbar" role="tablist" id="pfTabbar">
    <button class="pf-tb active" data-tab="t-stream" role="tab">
      <i class="fa-solid fa-tower-broadcast"></i> Stream
    </button>
    <button class="pf-tb" data-tab="t-perfil" role="tab">
      <i class="fa-solid fa-user"></i> Perfil
    </button>
    <button class="pf-tb" data-tab="t-contenido" role="tab">
      <i class="fa-solid fa-film"></i> Contenido
    </button>
    <button class="pf-tb" data-tab="t-cuenta" role="tab">
      <i class="fa-solid fa-gear"></i> Cuenta
    </button>
  </div>

  <!-- ── Tab panels ── -->
  <div class="pf-panels">

    <!-- ════ STREAM ════ -->
    <div class="pf-panel active" id="t-stream">

      <div class="key-warning">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span>No compartas tu stream key con nadie. Quien la tenga puede transmitir en tu canal.</span>
      </div>

      <div class="key-hero">
        <div class="key-label">Servidor RTMP</div>
        <div class="key-value-wrap" style="margin-bottom:14px">
          <span class="key-value">rtmp://corillo.live/live</span>
          <div class="key-actions">
            <button class="icon-btn" id="copyServer" title="Copiar"><i class="fa-regular fa-copy"></i></button>
          </div>
        </div>
        <div class="key-label">Stream Key</div>
        <div class="key-value-wrap">
          <span class="key-value hidden-key" id="streamKeyVal">cargando...</span>
          <div class="key-actions">
            <button class="icon-btn" id="toggleKey" title="Mostrar / ocultar"><i class="fa-regular fa-eye"></i></button>
            <button class="icon-btn" id="copyKey" title="Copiar"><i class="fa-regular fa-copy"></i></button>
          </div>
        </div>
      </div>

      <div class="key-warning neutral" style="margin-bottom:14px">
        <i class="fa-solid fa-rotate"></i>
        <div style="flex:1;font-size:.85rem">¿Tu stream key fue comprometida? Genera una nueva — los streams activos se cortarán.</div>
        <button class="btn danger sm" id="regenKeyBtn" style="flex-shrink:0"><i class="fa-solid fa-rotate"></i> Regenerar</button>
      </div>

      <div class="obs-hint">
        <strong>En OBS / Meld Studio</strong><br>
        Configuración → Stream → Servicio: <code>Personalizado</code><br>
        Servidor: <code>rtmp://corillo.live/live</code><br>
        Clave: <code id="obsKeyHint">••••••••</code><br>
        <span style="color:rgba(242,239,233,.35);font-size:.72rem">Formato: <code id="obsKeyFormat" style="color:rgba(242,239,233,.35)">&#123;canal&#125;?secret=••••••••</code></span>
      </div>
    </div>

    <!-- ════ PERFIL ════ -->
    <div class="pf-panel" id="t-perfil">

      <div class="pf-s-label"><i class="fa-solid fa-user"></i> Identidad</div>

      <div class="card">
        <div class="card-title">Foto y nombre</div>
        <div class="form-grid">
          <div class="avatar-row">
            <div class="avatar-preview" id="avatarPreview">
              <span id="avatarInitial">?</span>
            </div>
            <div class="avatar-actions">
              <button class="btn" id="avatarBtn"><i class="fa-solid fa-image"></i> Cambiar foto</button>
              <input type="file" id="avatarFile" class="file-input" accept="image/jpeg,image/png,image/webp">
              <span style="font-size:.72rem;color:var(--muted)">JPG, PNG o WebP · máx 5MB</span>
            </div>
          </div>
          <div class="field" style="margin:0">
            <label>Nombre visible</label>
            <input type="text" id="fDisplayName" placeholder="KATATONIA" maxlength="40">
          </div>
          <div class="field" style="margin:0">
            <label>Estado <span style="color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;font-family:var(--body);font-size:.82rem">— debajo de tu nombre en el player</span></label>
            <input type="text" id="fSub" placeholder="Just chatting · vibes" maxlength="60">
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Stream</div>
        <div class="form-grid">
          <div class="field" style="margin:0">
            <label>Juego / Título <span style="color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;font-family:var(--body);font-size:.82rem">— qué estás haciendo ahora</span></label>
            <input type="text" id="fStreamTitle" placeholder="Minecraft, Just Chatting…" maxlength="80">
          </div>
          <div class="field" style="margin:0">
            <label>Bio</label>
            <textarea id="fBio" placeholder="Cuéntale algo a tu audiencia…" maxlength="280"></textarea>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">Redes sociales</div>
        <div class="social-grid">
          <div class="field" style="margin:0">
            <label><i class="fa-brands fa-twitch" style="color:#9146ff"></i> Twitch</label>
            <input type="text" id="fTwitch" placeholder="tu_usuario">
          </div>
          <div class="field" style="margin:0">
            <label><i class="fa-brands fa-instagram" style="color:#e1306c"></i> Instagram</label>
            <input type="text" id="fInstagram" placeholder="tu_usuario">
          </div>
          <div class="field" style="margin:0">
            <label><i class="fa-brands fa-tiktok"></i> TikTok</label>
            <input type="text" id="fTiktok" placeholder="tu_usuario">
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">VODs</div>
        <label style="display:flex;align-items:center;justify-content:space-between;cursor:default;gap:16px">
          <div>
            <div style="font-size:.9rem;margin-bottom:4px"><i class="fa-solid fa-film" style="color:var(--accent)"></i> Guardar transmisiones</div>
            <div class="field-hint" style="margin:0">Tus streams se guardan y quedan disponibles para ver después.</div>
          </div>
          <label class="vod-toggle">
            <input type="checkbox" id="fVodEnabled">
            <span class="vod-slider"></span>
          </label>
        </label>
      </div>

      <div class="form-actions" style="margin-bottom:40px">
        <span class="save-status" id="saveStatus"></span>
        <button class="btn primary" id="saveBtn"><i class="fa-solid fa-floppy-disk"></i> Guardar cambios</button>
      </div>

      <div class="pf-s-label"><i class="fa-solid fa-table-cells-large"></i> Paneles</div>
      <p style="font-size:.85rem;color:var(--muted);margin:0 0 16px">Aparecen debajo de tu perfil en tu canal. Máximo 4 paneles.</p>
      <div id="panelsList"></div>
      <div class="form-actions">
        <button class="btn" id="addPanelBtn"><i class="fa-solid fa-plus"></i> Agregar panel</button>
        <div style="display:flex;align-items:center;gap:12px">
          <span class="save-status" id="panelsStatus"></span>
          <button class="btn primary" id="savePanelsBtn"><i class="fa-solid fa-floppy-disk"></i> Guardar paneles</button>
        </div>
      </div>
    </div>

    <!-- ════ CONTENIDO ════ -->
    <div class="pf-panel wide" id="t-contenido">

      <div class="ct-tabs" id="ctTabs">
        <button class="ct-tab active" data-ctpanel="ct-vods">
          <i class="fa-solid fa-film"></i> Transmisiones
        </button>
        <button class="ct-tab" data-ctpanel="ct-reels">
          <i class="fa-solid fa-scissors"></i> Reels
        </button>
      </div>

      <div class="ct-panel active" id="ct-vods">
        <div id="vodsCard" style="display:none">
          <div class="vod-rows" id="vodsList"></div>
          <p id="vodsEmpty" style="display:none;font-size:.85rem;color:var(--muted);font-family:var(--mono);padding:8px 0">No tienes transmisiones guardadas aún.</p>
        </div>
        <p id="vodsDisabled" style="font-size:.85rem;color:var(--muted);font-family:var(--mono);padding:8px 0">Activa la opción de guardar transmisiones en la sección Perfil para ver tus VODs aquí.</p>
      </div>

      <div class="ct-panel" id="ct-reels">
        <div style="margin-bottom:14px">
          <a href="/reels/" class="btn" target="_blank" rel="noopener" style="font-size:.7rem"><i class="fa-solid fa-film"></i> Ver página pública de Reels</a>
        </div>
        <div class="reel-rows" id="reelsList"></div>
        <p id="reelsEmpty" style="display:none;font-size:.85rem;color:var(--muted);font-family:var(--mono);padding:8px 0">No tienes reels aún. Crea uno desde tus transmisiones.</p>
      </div>
    </div>

    <!-- ════ CUENTA ════ -->
    <div class="pf-panel" id="t-cuenta">

      <div class="pf-s-label"><i class="fa-solid fa-shield-halved"></i> Seguridad</div>

      <details class="pf-details">
        <summary>Cambiar email</summary>
        <div class="pf-details-body">
          <div class="form-grid">
            <div class="field" style="margin:0">
              <label>Nuevo email</label>
              <input type="email" id="fNewEmail" placeholder="nuevo@email.com" autocomplete="email">
            </div>
            <div class="field" style="margin:0">
              <label>Contraseña actual</label>
              <input type="password" id="fEmailPass" placeholder="••••••••" autocomplete="current-password">
            </div>
            <div class="form-actions" style="margin:0">
              <span class="save-status" id="emailStatus"></span>
              <button class="btn primary" id="changeEmailBtn"><i class="fa-solid fa-envelope"></i> Cambiar email</button>
            </div>
          </div>
        </div>
      </details>

      <details class="pf-details">
        <summary>Cambiar contraseña</summary>
        <div class="pf-details-body">
          <div class="form-grid">
            <div class="field" style="margin:0">
              <label>Contraseña actual</label>
              <input type="password" id="fOldPass" placeholder="••••••••" autocomplete="current-password">
            </div>
            <div class="field" style="margin:0">
              <label>Nueva contraseña</label>
              <input type="password" id="fNewPass" placeholder="••••••••" autocomplete="new-password">
            </div>
            <div class="field" style="margin:0">
              <label>Confirmar nueva contraseña</label>
