    <!-- ════ CONTENIDO ════ -->
    <div class="pf-panel wide" id="t-contenido">

      <div class="ct-tabs" id="ctTabs">
        <button class="ct-tab active" data-ctpanel="ct-vods">
          <i class="fa-solid fa-film"></i> Transmisiones
        </button>
        <button class="ct-tab" data-ctpanel="ct-reels">
          <i class="fa-solid fa-scissors"></i> Reels
        </button>
      </div>

      <div class="ct-panel active" id="ct-vods">
        <div id="vodsCard" style="display:none">
          <div class="vod-rows" id="vodsList"></div>
          <p id="vodsEmpty" style="display:none;font-size:.85rem;color:var(--muted);font-family:var(--mono);padding:8px 0">No tienes transmisiones guardadas aún.</p>
        </div>
        <p id="vodsDisabled" style="font-size:.85rem;color:var(--muted);font-family:var(--mono);padding:8px 0">Activa la opción de guardar transmisiones en la sección Perfil para ver tus VODs aquí.</p>
      </div>

      <div class="ct-panel" id="ct-reels">
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:14px;flex-wrap:wrap">
          <a href="/reels/" class="btn" target="_blank" rel="noopener" style="font-size:.7rem"><i class="fa-solid fa-film"></i> Ver página de Reels</a>
          <button class="btn btn-primary" id="btnOpenUpload" style="font-size:.7rem"><i class="fa-solid fa-upload"></i> Subir Reel</button>
        </div>

        <!-- Upload panel -->
        <div id="reelUploadPanel" style="display:none;margin-bottom:20px">
          <div class="pf-s-label" style="margin-bottom:12px"><i class="fa-solid fa-upload"></i> Subir video</div>

          <div class="reel-upload-drop" id="reelDropZone">
            <input type="file" id="reelFileInput" accept="video/*">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <div>Arrastra tu video aquí o toca para seleccionar</div>
            <div style="font-size:.65rem;margin-top:6px;opacity:.6">Máx 60 seg · Máx 500 MB · Sube en 9:16 para mejor calidad — si es 16:9 se recorta el centro</div>
          </div>

          <div class="reel-upload-preview" id="reelUploadPreview">
            <video id="reelUploadVideo" playsinline muted></video>
