let keyVisible = false;
let currentRecord = null;
let toastTimer = null;

// ── Theme ──
const root = document.documentElement;
function syncThemeUi() {
  const mode = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
  const meta = document.querySelector('meta[name="theme-color"]');
  const btn  = document.getElementById('themeBtn');
  if (meta) meta.setAttribute('content', mode === 'light' ? '#eef7fb' : '#060608');
  if (btn) btn.innerHTML = mode === 'light'
    ? '<i class="fa-solid fa-moon"></i>'
    : '<i class="fa-solid fa-circle-half-stroke"></i>';
}
document.addEventListener('click', e => {
  if (!e.target.closest('#themeBtn')) return;
  const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
  root.setAttribute('data-theme', next);
  localStorage.setItem('corillo-theme', next);
  syncThemeUi();
});
syncThemeUi();

// ── Toast ──
function showToast(msg, type = 'ok') {
  clearTimeout(toastTimer);
  toast.textContent = msg;
  toast.className = `show ${type}`;
  toastTimer = setTimeout(() => toast.className = '', 2800);
}

// ── Init ──
function init() {
  if (pb.authStore.isValid) showDashboard();
  else showLogin();
}
function showLogin() {
  loginScreen.style.display = 'flex';
  dashboard.style.display = 'none';
}
async function showDashboard() {
  loginScreen.style.display = 'none';
  dashboard.style.display = 'block';
  try {
    await pb.collection('streamers').authRefresh();
    currentRecord = pb.authStore.record;
    populateDashboard(currentRecord);
  } catch(e) {
    pb.authStore.clear();
    showLogin();
  }
}

function populateDashboard(rec) {
  // Hero
  const pfSideAva  = document.getElementById('pfSideAva');
  const pfSideName = document.getElementById('pfSideName');
  const pfSideCh   = document.getElementById('pfSideChannel');
  const pfHeroSub  = document.getElementById('pfHeroSub');
  if (pfSideName) pfSideName.textContent = rec.display_name || rec.key || '';
  if (pfHeroSub)  pfHeroSub.textContent  = rec.sub || '';
  if (sessionEmail) sessionEmail.textContent = rec.email || '';
  if (pfSideCh && rec.key) { pfSideCh.href = `/${rec.key}/`; pfSideCh.style.display = ''; }
  if (pfSideAva) updateHeroAva(rec, pfSideAva);

  // Hero color glow
  if (rec.color) {
    const m = rec.color.match(/#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})/);
    if (m) {
      const hex = m[0]; let r2, g, b;
      if (hex.length === 4) {
        r2 = parseInt(hex[1]+hex[1],16); g = parseInt(hex[2]+hex[2],16); b = parseInt(hex[3]+hex[3],16);
      } else {
        r2 = parseInt(hex.slice(1,3),16); g = parseInt(hex.slice(3,5),16); b = parseInt(hex.slice(5,7),16);
      }
      const hero = document.getElementById('pfHero');
      if (hero) hero.style.setProperty('--hero-glow', `rgba(${r2},${g},${b},.09)`);
    }
  }

  // Stream key
  streamKeyVal.textContent = rec.stream_key
    ? `${rec.key}?secret=${rec.stream_key}`
    : '(sin stream key — contacta al admin)';
  streamKeyVal.classList.add('hidden-key');
  keyVisible = false;
  toggleKey.innerHTML = '<i class="fa-regular fa-eye"></i>';
  obsKeyHint.textContent = `${rec.key}?secret=••••••••`;
  document.getElementById('obsKeyFormat').textContent = `${rec.key}?secret=••••••••`;

  // Perfil fields
  fDisplayName.value = rec.display_name || '';
  document.getElementById('fSub').value = rec.sub || '';
  fStreamTitle.value = rec.stream_title || '';
  fBio.value = rec.bio || '';
  fTwitch.value = rec.twitch || '';
  fInstagram.value = rec.instagram || '';
  fTiktok.value = rec.tiktok || '';
  document.getElementById('fVodEnabled').checked = !!rec.vod_enabled;

  // Avatar
  updateAvatarPreview(rec);

  // Paneles
  panels = (rec.panels || []).map(p => ({ title: p.title||'', text: p.text||'', url: p.url||'' }));
  renderPanels();

  // Contenido
  if (rec.vod_enabled) {
    document.getElementById('vodsDisabled').style.display = 'none';
    document.getElementById('vodsCard').style.display = '';
    loadMyVods(rec.key);
  }
  loadMyReels(rec.key);

  // Header nav
  navRight.innerHTML = `<button class="theme-btn" id="themeBtn" title="Cambiar tema"><i class="fa-solid fa-circle-half-stroke"></i></button>`;
  if (rec.key) navRight.innerHTML += `<a class="btn" href="/${rec.key}/"><i class="fa-solid fa-tv"></i> Mi canal</a>`;
  navRight.innerHTML += `<a class="btn" href="/"><i class="fa-solid fa-house"></i></a>`;
  syncThemeUi();

  initDashboardTabs();
  initContentTabs();
}

function updateHeroAva(rec, el) {
  if (rec.avatar) {
    const url = pb.files.getURL(rec, rec.avatar, { thumb: '100x100' });
    el.innerHTML = `<img src="${url}" alt="">`;
    el.style.background = rec.color || '';
  } else {
    el.textContent = (rec.display_name || rec.key || '?')[0].toUpperCase();
    el.style.background = rec.color || '';
  }
}

function updateAvatarPreview(rec) {
  if (rec.avatar) {
    const url = pb.files.getURL(rec, rec.avatar, { thumb: '100x100' });
    avatarInitial.style.display = 'none';
    const img = avatarPreview.querySelector('img') || document.createElement('img');
    img.src = url;
    if (!img.parentNode) avatarPreview.appendChild(img);
  } else {
    avatarInitial.textContent = (rec.display_name || rec.key || '?')[0].toUpperCase();
    avatarInitial.style.display = '';
    const img = avatarPreview.querySelector('img');
    if (img) img.remove();
  }
  const pfSideAva = document.getElementById('pfSideAva');
  if (pfSideAva) updateHeroAva(rec, pfSideAva);
}

// ── Dashboard tabs ──
function initDashboardTabs() {
  const tabs   = document.querySelectorAll('.pf-tb');
  const panels = document.querySelectorAll('.pf-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.dataset.tab)?.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });

  // Stats chips → jump to contenido
  document.getElementById('pfStatVodsBtn')?.addEventListener('click', () => {
    switchTab('t-contenido');
    // switch inner tab to vods
    switchCtTab('ct-vods');
  });
  document.getElementById('pfStatReelsBtn')?.addEventListener('click', () => {
    switchTab('t-contenido');
    switchCtTab('ct-reels');
  });
}

function switchTab(tabId) {
  document.querySelectorAll('.pf-tb').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.pf-panel').forEach(p => p.classList.remove('active'));
  document.querySelector(`[data-tab="${tabId}"]`)?.classList.add('active');
  document.getElementById(tabId)?.classList.add('active');
