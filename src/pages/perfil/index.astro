// ── Reel timeline ──
function initReelTimeline(vodId, duration) {
  if (!duration || duration <= 0) return;
  const tlEl = document.getElementById(`rtl-${vodId}`);
  if (!tlEl || tlEl.dataset.init === '1') return;
  tlEl.dataset.init = '1';

  const fill       = document.getElementById(`rtl-fill-${vodId}`);
  const hs         = document.getElementById(`rtl-hs-${vodId}`);
  const he         = document.getElementById(`rtl-he-${vodId}`);
  const tipHs      = document.getElementById(`rtl-tip-hs-${vodId}`);
  const tipHe      = document.getElementById(`rtl-tip-he-${vodId}`);
  const td         = document.getElementById(`rtl-td-${vodId}`);
  const startInput = document.getElementById(`rstart-${vodId}`);
  const endInput   = document.getElementById(`rend-${vodId}`);
  const video      = document.getElementById(`rvid-${vodId}`);
  const vwrap      = document.getElementById(`rvwrap-${vodId}`);
  const vbadge     = document.getElementById(`rvbadge-${vodId}`);
  const track      = tlEl.querySelector('.rtl-track');

  const MIN = 5, MAX = 60;
  let s0 = 0, e0 = Math.min(30, duration);

  // Video events
  if (video) {
    video.addEventListener('loadedmetadata', () => {
      if (vwrap) vwrap.classList.add('loaded');
    });
    video.addEventListener('seeked', () => {
      if (vbadge) vbadge.textContent = fmtSec(video.currentTime);
    });
  }

  function seekVideo(sec) {
    if (!video) return;
    if (video.readyState >= 1) {
      video.currentTime = Math.max(0, Math.min(sec, video.duration || duration));
    } else {
      video.addEventListener('loadedmetadata', () => {
        video.currentTime = Math.max(0, Math.min(sec, video.duration || duration));
      }, { once: true });
    }
  }

  function render(seekTo) {
    const sp = (s0 / duration) * 100;
    const ep = (e0 / duration) * 100;
    fill.style.left  = sp + '%';
    fill.style.width = (ep - sp) + '%';
    hs.style.left = sp + '%';
    he.style.left = ep + '%';
    if (tipHs) tipHs.textContent = fmtSec(s0);
    if (tipHe) tipHe.textContent = fmtSec(e0);
    startInput.value = fmtSec(s0);
    endInput.value   = fmtSec(e0);
    const dur = e0 - s0;
    td.textContent = dur + 's';
    td.className = 'rtl-t-dur' + (dur >= MIN && dur <= MAX ? ' ok' : ' err');
    if (seekTo !== undefined) seekVideo(seekTo);
  }

  function clampToTrack(clientX) {
    const rect = track.getBoundingClientRect();
    const x = Math.max(0, Math.min(clientX - rect.left, rect.width));
    return Math.round((x / rect.width) * duration);
  }

  function drag(handle, isStart) {
    handle.addEventListener('pointerdown', e => {
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      e.preventDefault();
      e.stopPropagation();
      handle.setPointerCapture(e.pointerId);
      handle.classList.add('dragging');

      function onMove(ev) {
        const sec = clampToTrack(ev.clientX);
        if (isStart) {
          s0 = Math.max(0, Math.min(sec, e0 - MIN));
          render(s0);
        } else {
          e0 = Math.min(duration, Math.max(sec, s0 + MIN));
          if (e0 - s0 > MAX) e0 = s0 + MAX;
          render(e0);
        }
      }
      function onUp() {
        handle.classList.remove('dragging');
        handle.removeEventListener('pointermove', onMove);
      }
      handle.addEventListener('pointermove', onMove);
      handle.addEventListener('pointerup',     onUp, { once: true });
      handle.addEventListener('pointercancel', onUp, { once: true });
    });
  }

  // Track click → nearest handle
  track.addEventListener('pointerdown', e => {
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    const sec = clampToTrack(e.clientX);
    if (Math.abs(sec - s0) <= Math.abs(sec - e0)) {
      s0 = Math.max(0, Math.min(sec, e0 - MIN));
      render(s0);
    } else {
      e0 = Math.min(duration, Math.max(sec, s0 + MIN));
      if (e0 - s0 > MAX) e0 = s0 + MAX;
      render(e0);
    }
  });

  // Text input handlers
  function applyStart() {
    const parsed = parseSec(startInput.value);
    if (isNaN(parsed) || parsed < 0 || parsed >= duration) { startInput.value = fmtSec(s0); return; }
    const prevDur = e0 - s0;
    s0 = Math.round(parsed);
    e0 = Math.min(duration, s0 + prevDur);
    if (e0 - s0 < MIN) e0 = Math.min(duration, s0 + MIN);
    if (e0 - s0 > MAX) e0 = s0 + MAX;
    render(s0);
  }
  function applyEnd() {
    const parsed = parseSec(endInput.value);
    if (isNaN(parsed)) { endInput.value = fmtSec(e0); return; }
    e0 = Math.max(s0 + MIN, Math.min(duration, Math.round(parsed)));
    if (e0 - s0 > MAX) e0 = s0 + MAX;
    render(e0);
  }

  startInput.addEventListener('blur',  applyStart);
  endInput.addEventListener('blur',    applyEnd);
  startInput.addEventListener('keydown', ev => { if (ev.key === 'Enter') { applyStart(); endInput.focus(); } });
  endInput.addEventListener('keydown',   ev => { if (ev.key === 'Enter') applyEnd(); });

  drag(hs, true);
  drag(he, false);
  render(s0);
}

function toggleReelPanel(vodId, vodDuration, vidSrc, thumb) {
  const panel = document.getElementById(`rpanel-${vodId}`);
  const btn   = document.getElementById(`rbtn-${vodId}`);
  if (!panel) return;
  const opening = !panel.classList.contains('open');
  panel.classList.toggle('open');
  btn?.classList.toggle('active', opening);
  if (opening) initReelTimeline(vodId, vodDuration);
}

async function generateReel(vodId) {
  const start = parseSec(document.getElementById(`rstart-${vodId}`)?.value);
  const end   = parseSec(document.getElementById(`rend-${vodId}`)?.value);
  const pub   = document.getElementById(`rpub-${vodId}`)?.checked || false;
  const dur   = end - start;
  const btn   = document.getElementById(`rgen-${vodId}`);
  const result= document.getElementById(`rresult-${vodId}`);

  if (isNaN(start) || isNaN(end) || dur < 5 || dur > 60) {
    showToast('Revisa el tiempo — entre 5 y 60 segundos', 'err'); return;
  }
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Generando…';
  result.className = 'reel-result'; result.innerHTML = '';

  try {
    const res = await fetch('/chat-api/reel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': pb.authStore.token },
      body: JSON.stringify({ vod_id: vodId, record_id: currentRecord.id, start, end, public: pub }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail || 'Error desconocido');
    result.innerHTML = `
      <div style="margin-bottom:8px"><strong style="color:#00b894">¡Reel creado!</strong> ${dur}s · 9:16</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a href="${data.download_url}" download class="btn" style="font-size:.72rem"><i class="fa-solid fa-download"></i> Descargar MP4</a>
        ${pub ? `<a href="/reels/" target="_blank" class="btn" style="font-size:.72rem"><i class="fa-solid fa-film"></i> Ver en /reels/</a>` : ''}
      </div>`;
    result.className = 'reel-result show';
    showToast('¡Reel generado!');
    loadMyReels(currentRecord.key);
  } catch(e) {
    result.innerHTML = `<span style="color:#e17055"><i class="fa-solid fa-circle-exclamation"></i> ${e.message}</span>`;
    result.className = 'reel-result show';
    showToast('Error generando el reel', 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Generar Reel';
  }
}

async function deleteVod(id) {
  if (!confirm('¿Seguro que quieres borrar este VOD? No se puede deshacer.')) return;
  const btn = document.querySelector(`#vrow-${id} .vod-row-del`);
  if (btn) btn.classList.add('loading');
  try {
    await pb.collection('vods').delete(id);
    document.getElementById(`vrow-${id}`)?.closest('div')?.remove();
    if (!document.querySelector('.vod-row')) document.getElementById('vodsEmpty').style.display = '';
  } catch(e) {
    if (btn) btn.classList.remove('loading');
    alert('No se pudo borrar el VOD.');
  }
}

// ── Reels ──
async function loadMyReels(channel) {
  try {
    const res   = await pb.collection('reels').getList(1, 50, { filter:`channel="${channel}"`, sort:'-date' });
    const items = res.items || [];
    const list  = document.getElementById('reelsList');
    const empty = document.getElementById('reelsEmpty');

    // Update hero stat
    const pfStatReels = document.getElementById('pfStatReels');
    if (pfStatReels) pfStatReels.textContent = items.length;

    list.innerHTML = '';
    if (!items.length) { empty.style.display = ''; return; }
    empty.style.display = 'none';
    list.innerHTML = items.map(r => `
      <div class="reel-row" id="rrow-${r.id}">
        <div class="reel-row-thumb">
          ${r.thumb ? `<img src="${r.thumb}" alt="" onerror="this.style.display='none'" loading="lazy">` : '<i class="fa-solid fa-film"></i>'}
        </div>
        <div class="reel-row-info">
          <div class="reel-row-date">${fmtDate(r.date)}</div>
          <div class="reel-row-meta">${r.duration ? r.duration+'s' : ''}${r.size ? ' · '+fmtMB(r.size) : ''}</div>
          <div class="reel-row-pub ${r.public?'pub':'priv'}">
            <i class="fa-solid fa-${r.public?'globe':'lock'}"></i> ${r.public?'Público':'Privado'}
          </div>
        </div>
        <div class="reel-row-actions">
          <a class="reel-row-dl" href="/vods/reels/${channel}/${r.filename}" download title="Descargar"><i class="fa-solid fa-download"></i></a>
          <button class="reel-row-del" onclick="deleteReel('${r.id}','${channel}')" title="Borrar"><i class="fa-solid fa-trash"></i></button>
        </div>
      </div>`).join('');
  } catch(e) { console.error('loadMyReels:', e); }
}

async function deleteReel(id, channel) {
  if (!confirm('¿Borrar este reel? No se puede deshacer.')) return;
  const btn = document.querySelector(`#rrow-${id} .reel-row-del`);
  if (btn) btn.classList.add('loading');
  try {
    const res = await fetch(`/chat-api/reel/${id}`, { method: 'DELETE', headers: { 'Authorization': pb.authStore.token } });
    if (!res.ok) throw new Error();
    document.getElementById(`rrow-${id}`)?.remove();
    if (!document.querySelector('.reel-row')) document.getElementById('reelsEmpty').style.display = '';
    showToast('Reel eliminado');
  } catch(e) {
    if (btn) btn.classList.remove('loading');
    showToast('Error al borrar.', 'err');
  }
}

// ── Login ──
loginBtn.addEventListener('click', doLogin);
loginEmail.addEventListener('keydown', e => { if (e.key==='Enter') loginPass.focus(); });
loginPass.addEventListener('keydown',  e => { if (e.key==='Enter') doLogin(); });

async function doLogin() {
  const email = loginEmail.value.trim();
  const pass  = loginPass.value;
  if (!email || !pass) return;
  loginBtn.disabled = true;
  loginBtn.innerHTML = '<span class="spinner"></span> Entrando…';
  loginErr.style.display = 'none';
  try {
    await pb.collection('streamers').authWithPassword(email, pass);
    currentRecord = pb.authStore.record;
    showDashboard();
  } catch(e) {
    loginErr.textContent = 'Email o contraseña incorrectos.';
    loginErr.style.display = 'block';
  } finally {
    loginBtn.disabled = false;
    loginBtn.innerHTML = '<i class="fa-solid fa-arrow-right-to-bracket"></i> Entrar';
  }
}

// ── Stream key ──
toggleKey.addEventListener('click', () => {
  keyVisible = !keyVisible;
  streamKeyVal.classList.toggle('hidden-key', !keyVisible);
  toggleKey.innerHTML = keyVisible ? '<i class="fa-regular fa-eye-slash"></i>' : '<i class="fa-regular fa-eye"></i>';
  const full = `${currentRecord?.key}?secret=${currentRecord?.stream_key}`;
  obsKeyHint.textContent = keyVisible ? full : `${currentRecord?.key}?secret=••••••••`;
  document.getElementById('obsKeyFormat').textContent = keyVisible ? full : `${currentRecord?.key}?secret=••••••••`;
});
copyKey.addEventListener('click',    () => copyText(`${currentRecord?.key}?secret=${currentRecord?.stream_key}`, copyKey));
copyServer.addEventListener('click', () => copyText('rtmp://corillo.live/live', copyServer));

async function copyText(text, btn) {
  if (!text) return;
  try {
    await navigator.clipboard.writeText(text);
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-check"></i>';
    btn.classList.add('copied');
    setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 1800);
    showToast('Copiado al portapapeles');
  } catch(e) { showToast('No se pudo copiar', 'err'); }
}

// ── Avatar ──
avatarBtn.addEventListener('click', () => avatarFile.click());
avatarFile.addEventListener('change', async () => {
  const file = avatarFile.files[0];
  if (!file) return;
  if (file.size > 5*1024*1024) { showToast('La imagen es demasiado grande (máx 5MB)', 'err'); return; }
  avatarBtn.disabled = true;
  avatarBtn.innerHTML = '<span class="spinner"></span> Subiendo…';
  try {
    const fd = new FormData();
    fd.append('avatar', file);
    currentRecord = await pb.collection('streamers').update(currentRecord.id, fd);
    updateAvatarPreview(currentRecord);
    showToast('Foto actualizada');
  } catch(e) { showToast('Error subiendo la foto', 'err'); }
  finally {
    avatarBtn.disabled = false;
    avatarBtn.innerHTML = '<i class="fa-solid fa-image"></i> Cambiar foto';
    avatarFile.value = '';
  }
});

// ── Guardar perfil ──
saveBtn.addEventListener('click', async () => {
  saveBtn.disabled = true;
  saveBtn.innerHTML = '<span class="spinner"></span> Guardando…';
  saveStatus.textContent = ''; saveStatus.className = 'save-status';
  try {
    currentRecord = await pb.collection('streamers').update(currentRecord.id, {
      display_name: fDisplayName.value.trim(),
      sub:          document.getElementById('fSub').value.trim(),
      stream_title: fStreamTitle.value.trim(),
      bio:          fBio.value.trim(),
      twitch:       fTwitch.value.trim(),
      instagram:    fInstagram.value.trim(),
      tiktok:       fTiktok.value.trim(),
      vod_enabled:  document.getElementById('fVodEnabled').checked,
    });
    saveStatus.textContent = 'Cambios guardados'; saveStatus.className = 'save-status ok';
    showToast('Perfil actualizado');
    const pfSideName = document.getElementById('pfSideName');
    if (pfSideName) pfSideName.textContent = currentRecord.display_name || currentRecord.key || '';
    const pfHeroSub = document.getElementById('pfHeroSub');
    if (pfHeroSub) pfHeroSub.textContent = currentRecord.sub || '';
  } catch(e) {
    saveStatus.textContent = 'Error al guardar'; saveStatus.className = 'save-status err';
    showToast('Error al guardar los cambios', 'err');
  } finally {
    saveBtn.disabled = false;
    saveBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Guardar cambios';
  }
});

// ── Paneles ──
const panelsList    = document.getElementById('panelsList');
const addPanelBtn   = document.getElementById('addPanelBtn');
const savePanelsBtn = document.getElementById('savePanelsBtn');
const panelsStatus  = document.getElementById('panelsStatus');
let panels = [];

function renderPanels() {
  panelsList.innerHTML = '';
  panels.forEach((p, i) => {
    const row = document.createElement('div');
    row.className = 'panel-row';
    row.innerHTML = `
      <div class="panel-row-header">
        <span class="panel-row-label">Panel ${i+1}</span>
        <button class="btn danger sm" data-del="${i}"><i class="fa-solid fa-trash"></i></button>
      </div>
      <div class="field" style="margin:0"><label>Título</label>
        <input type="text" value="${esc(p.title)}" placeholder="Mi Discord" maxlength="40" data-field="title" data-idx="${i}">
      </div>
      <div class="field" style="margin:0"><label>Texto</label>
        <input type="text" value="${esc(p.text)}" placeholder="Únete al servidor" maxlength="100" data-field="text" data-idx="${i}">
      </div>
      <div class="field" style="margin:0"><label>Link (opcional)</label>
        <input type="url" value="${esc(p.url)}" placeholder="https://..." maxlength="200" data-field="url" data-idx="${i}">
      </div>`;
    row.querySelector('[data-del]').addEventListener('click', () => { panels.splice(i,1); renderPanels(); });
    row.querySelectorAll('input').forEach(inp => {
      inp.addEventListener('input', () => { panels[inp.dataset.idx][inp.dataset.field] = inp.value; });
    });
    panelsList.appendChild(row);
  });
  addPanelBtn.disabled = panels.length >= 4;
}

addPanelBtn.addEventListener('click', () => {
  if (panels.length >= 4) return;
  panels.push({ title:'', text:'', url:'' });
  renderPanels();
});

savePanelsBtn.addEventListener('click', async () => {
  savePanelsBtn.disabled = true;
  savePanelsBtn.innerHTML = '<span class="spinner"></span> Guardando…';
  panelsStatus.textContent = ''; panelsStatus.className = 'save-status';
  try {
    const clean = panels.filter(p => p.title.trim()).map(p => ({ title: p.title.trim(), text: p.text.trim(), url: p.url.trim() }));
    currentRecord = await pb.collection('streamers').update(currentRecord.id, { panels: clean });
    panels = (currentRecord.panels||[]).map(p => ({...p}));
    renderPanels();
    panelsStatus.textContent = 'Paneles guardados'; panelsStatus.className = 'save-status ok';
    showToast('Paneles actualizados');
  } catch(e) {
    panelsStatus.textContent = 'Error al guardar'; panelsStatus.className = 'save-status err';
    showToast('Error al guardar los paneles', 'err');
  } finally {
    savePanelsBtn.disabled = false;
    savePanelsBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Guardar paneles';
  }
});

// ── Regenerar key ──
document.getElementById('regenKeyBtn').addEventListener('click', async () => {
  if (!confirm('¿Seguro? Esto invalidará tu stream key actual. Si estás en vivo, el stream se cortará.')) return;
  const btn = document.getElementById('regenKeyBtn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>';
  try {
    const res = await fetch('/chat-api/regen-stream-key', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': pb.authStore.token },
      body: JSON.stringify({ record_id: currentRecord.id }),
    });
    if (!res.ok) throw new Error();
    const data = await res.json();
    currentRecord.stream_key = data.stream_key;
    streamKeyVal.textContent = `${currentRecord.key}?secret=${data.stream_key}`;
    if (keyVisible) {
      const full = `${currentRecord.key}?secret=${data.stream_key}`;
      obsKeyHint.textContent = full;
      document.getElementById('obsKeyFormat').textContent = full;
    }
    showToast('Stream key regenerada');
  } catch(e) { showToast('Error al regenerar. Intenta de nuevo.', 'err'); }
  finally { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-rotate"></i> Regenerar'; }
});

// ── Cambiar contraseña ──
document.getElementById('changePassBtn').addEventListener('click', async () => {
  const oldPass = document.getElementById('fOldPass').value;
  const newPass = document.getElementById('fNewPass').value;
  const confirm = document.getElementById('fNewPassConfirm').value;
  const status  = document.getElementById('passStatus');
  status.className = 'save-status'; status.textContent = '';
  if (!oldPass||!newPass||!confirm) { status.textContent='Completa todos los campos'; status.className='save-status err'; return; }
  if (newPass.length < 8) { status.textContent='Mínimo 8 caracteres'; status.className='save-status err'; return; }
  if (newPass !== confirm) { status.textContent='Las contraseñas no coinciden'; status.className='save-status err'; return; }
  const btn = document.getElementById('changePassBtn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Guardando…';
  try {
    await pb.collection('streamers').update(currentRecord.id, { oldPassword: oldPass, password: newPass, passwordConfirm: confirm });
    document.getElementById('fOldPass').value = '';
    document.getElementById('fNewPass').value = '';
    document.getElementById('fNewPassConfirm').value = '';
    status.textContent = 'Contraseña actualizada'; status.className = 'save-status ok';
    showToast('Contraseña actualizada');
  } catch(e) {
    status.textContent = 'Contraseña actual incorrecta'; status.className = 'save-status err';
    showToast('Error al cambiar la contraseña', 'err');
  } finally { btn.disabled=false; btn.innerHTML='<i class="fa-solid fa-lock"></i> Cambiar contraseña'; }
});

// ── Cambiar email ──
document.getElementById('changeEmailBtn').addEventListener('click', async () => {
  const newEmail = document.getElementById('fNewEmail').value.trim();
  const status   = document.getElementById('emailStatus');
  status.textContent = ''; status.className = 'save-status';
  if (!newEmail) { status.textContent='Ingresa el nuevo email.'; status.className='save-status err'; return; }
  const btn = document.getElementById('changeEmailBtn');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span> Enviando…';
  try {
    await pb.collection('streamers').requestEmailChange(newEmail);
    status.textContent = 'Revisa tu nuevo email para confirmar el cambio.'; status.className = 'save-status ok';
    document.getElementById('fNewEmail').value = '';
    document.getElementById('fEmailPass').value = '';
    showToast('Email de confirmación enviado');
  } catch(e) {
    status.textContent = 'Error. Verifica el email.'; status.className = 'save-status err';
    showToast('Error al cambiar el email', 'err');
  } finally { btn.disabled=false; btn.innerHTML='<i class="fa-solid fa-envelope"></i> Cambiar email'; }
});

// ── Forgot password ──
forgotBtn.addEventListener('click', () => {
  loginCard.style.display = 'none'; resetCard.style.display = 'block';
  resetEmail.value = loginEmail.value;
  resetErr.style.display = 'none'; resetOk.style.display = 'none';
});
backToLogin.addEventListener('click', () => { resetCard.style.display = 'none'; loginCard.style.display = 'block'; });
resetBtn.addEventListener('click', async () => {
  const email = resetEmail.value.trim();
  resetErr.style.display = 'none'; resetOk.style.display = 'none';
  if (!email) { resetErr.textContent='Ingresa tu email.'; resetErr.style.display='block'; return; }
  resetBtn.disabled = true; resetBtn.innerHTML = '<span class="spinner"></span> Enviando…';
  try { await pb.collection('streamers').requestPasswordReset(email); } catch(e) {}
  finally {
    resetOk.textContent = 'Si ese email existe, recibirás el link en unos momentos.';
    resetOk.style.display = 'block'; resetBtn.style.display = 'none';
    resetBtn.disabled = false; resetBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Enviar link';
  }
});

// ── Logout ──
function doLogout() {
  pb.authStore.clear(); showLogin();
  loginEmail.value = ''; loginPass.value = '';
}
document.getElementById('logoutBtn').addEventListener('click', doLogout);

// ── Start ──
init();
</script>
</body>
</html>
