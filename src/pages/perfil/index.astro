    initCropBox(vodId);
  }
}

// ── Crop box: draggable 9:16 selector sobre el video 16:9 ──
function initCropBox(vodId) {
  const canvas  = document.getElementById(`rcanvas-${vodId}`);
  const preview = document.getElementById(`rpreview-${vodId}`);
  const video   = document.getElementById(`rvid-${vodId}`);
  if (!canvas || !video) return;
  if (canvas.dataset.init === '1') return;
  canvas.dataset.init = '1';

  // crop_x normalizado (0=izquierda, 1=derecha, 0.5=centro)
  canvas._cropX = 0.5;

  const ctx     = canvas.getContext('2d');
  const pctx    = preview?.getContext('2d');

  function drawCropBox() {
    const W = canvas.offsetWidth;
    const H = canvas.offsetHeight;
    canvas.width  = W;
    canvas.height = H;

    // Ancho del box: H * 9/16 (proporción 9:16 en el display 16:9)
    const boxW = Math.round(H * 9 / 16);
    const maxX = W - boxW;
    const boxX = Math.round(canvas._cropX * maxX);

    ctx.clearRect(0, 0, W, H);

    // Oscurecer las zonas fuera del box
    ctx.fillStyle = 'rgba(0,0,0,0.55)';
    ctx.fillRect(0, 0, boxX, H);
    ctx.fillRect(boxX + boxW, 0, W - (boxX + boxW), H);

    // Borde del box
    ctx.strokeStyle = '#00bfff';
    ctx.lineWidth   = 2;
    ctx.strokeRect(boxX + 1, 1, boxW - 2, H - 2);

    // Esquinas resaltadas
    const cs = 12;
    ctx.lineWidth = 3;
    [[boxX, 0], [boxX + boxW - cs, 0], [boxX, H - cs], [boxX + boxW - cs, H - cs]].forEach(([x, y]) => {
      ctx.beginPath();
      ctx.moveTo(x, y + cs); ctx.lineTo(x, y); ctx.lineTo(x + cs, y);
      ctx.stroke();
    });

    // Label de posición
    const pct = Math.round(canvas._cropX * 100);
    ctx.fillStyle = 'rgba(0,191,255,0.9)';
    ctx.font = '10px monospace';
    ctx.fillText(pct === 50 ? 'Centro' : pct < 50 ? '← Izquierda' : 'Derecha →', boxX + 6, H - 8);

    drawPreview(boxX, boxW, W, H);
  }

  function drawPreview(boxX, boxW, W, H) {
    if (!pctx || !preview || video.readyState < 2) return;
    const PW = preview.width  = preview.offsetWidth  || 90;
    const PH = preview.height = preview.offsetHeight || 160;

    // Calcular la región del video real que corresponde al box
    // El video puede tener letterbox (object-fit: contain), hay que compensar
    const vW = video.videoWidth  || 1920;
    const vH = video.videoHeight || 1080;
    const scale = Math.min(W / vW, H / vH);
    const dispW = vW * scale;
    const dispH = vH * scale;
    const offX  = (W - dispW) / 2;
    const offY  = (H - dispH) / 2;

    // Convertir boxX del display al espacio del video real
    const sx = ((boxX - offX) / dispW) * vW;
    const sw = (boxW / dispW) * vW;
    const sy = 0;
    const sh = vH;

    pctx.clearRect(0, 0, PW, PH);
    pctx.drawImage(video, Math.max(0, sx), sy, Math.min(sw, vW - Math.max(0, sx)), sh, 0, 0, PW, PH);
  }

  // Drag logic
  let dragging = false;
  let dragStartX = 0;
  let dragStartCropX = 0.5;

  function getBoxW() {
    return Math.round(canvas.offsetHeight * 9 / 16);
  }
  function clampCropX(x) {
    return Math.max(0, Math.min(1, x));
  }
  function onStart(clientX) {
    dragging = true;
    dragStartX = clientX;
    dragStartCropX = canvas._cropX;
  }
  function onMove(clientX) {
    if (!dragging) return;
    const W    = canvas.offsetWidth;
    const boxW = getBoxW();
    const maxX = W - boxW;
    const dx   = clientX - dragStartX;
    canvas._cropX = clampCropX(dragStartCropX + dx / maxX);
    drawCropBox();
  }
  function onEnd() { dragging = false; }

  canvas.addEventListener('mousedown',  e => onStart(e.clientX));
  window.addEventListener('mousemove',  e => { if (dragging) onMove(e.clientX); });
  window.addEventListener('mouseup',    onEnd);
  canvas.addEventListener('touchstart', e => { e.preventDefault(); onStart(e.touches[0].clientX); }, { passive: false });
  window.addEventListener('touchmove',  e => { if (dragging) { e.preventDefault(); onMove(e.touches[0].clientX); } }, { passive: false });
  window.addEventListener('touchend',   onEnd);

  // Redibujar en cada frame del video
  video.addEventListener('timeupdate', drawCropBox);
  video.addEventListener('seeked',     drawCropBox);
  video.addEventListener('loadeddata', () => { drawCropBox(); });

  // Redibujar al resize
  const ro = new ResizeObserver(drawCropBox);
  ro.observe(canvas);

  drawCropBox();
}

async function generateReel(vodId) {
  const start = parseInt(document.getElementById(`rstart-${vodId}`)?.value, 10);
  const end   = parseInt(document.getElementById(`rend-${vodId}`)?.value,   10);
  const pub   = document.getElementById(`rpub-${vodId}`)?.checked || false;
  const cropCanvas = document.getElementById(`rcanvas-${vodId}`);
  const crop_x = cropCanvas?._cropX ?? null;
  const dur   = end - start;
  const btn   = document.getElementById(`rgen-${vodId}`);
  const result= document.getElementById(`rresult-${vodId}`);

  if (isNaN(start) || isNaN(end) || dur < 5 || dur > 60) {
    showToast('Revisa el tiempo — entre 5 y 60 segundos', 'err'); return;
  }
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Generando…';
  result.className = 'reel-result'; result.innerHTML = '';

  try {
    const res = await fetch('/chat-api/reel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': pb.authStore.token },
      body: JSON.stringify({ vod_id: vodId, record_id: currentRecord.id, start, end, public: pub, crop_x }),
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.detail || 'Error desconocido');
    result.innerHTML = `
      <div style="margin-bottom:8px"><strong style="color:#00b894">¡Reel creado!</strong> ${dur}s · 9:16</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a href="${data.download_url}" download class="btn" style="font-size:.72rem"><i class="fa-solid fa-download"></i> Descargar MP4</a>
        ${pub ? `<a href="/reels/" target="_blank" class="btn" style="font-size:.72rem"><i class="fa-solid fa-film"></i> Ver en /reels/</a>` : ''}
      </div>`;
    result.className = 'reel-result show';
    showToast('¡Reel generado!');
    loadMyReels(currentRecord.key);
  } catch(e) {
    result.innerHTML = `<span style="color:#e17055"><i class="fa-solid fa-circle-exclamation"></i> ${e.message}</span>`;
    result.className = 'reel-result show';
    showToast('Error generando el reel', 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i> Generar Reel';
  }
}

async function deleteVod(id) {
