  </div><!-- /pf-panels -->
</div><!-- /dashboard -->

<div id="toast"></div>

<script is:inline>
const PB_URL = 'https://pb.corillo.live';
const pb = new PocketBase(PB_URL);

// ── DOM refs ──
const loginScreen  = document.getElementById('loginScreen');
const resetCard    = document.getElementById('resetCard');
const loginCard    = document.getElementById('loginCard');
const resetEmail   = document.getElementById('resetEmail');
const resetBtn     = document.getElementById('resetBtn');
const resetErr     = document.getElementById('resetErr');
const resetOk      = document.getElementById('resetOk');
const forgotBtn    = document.getElementById('forgotBtn');
const backToLogin  = document.getElementById('backToLogin');
const dashboard    = document.getElementById('dashboard');
const loginEmail   = document.getElementById('loginEmail');
const loginPass    = document.getElementById('loginPass');
const loginBtn     = document.getElementById('loginBtn');
const loginErr     = document.getElementById('loginErr');
const sessionEmail = document.getElementById('sessionEmail');
const streamKeyVal = document.getElementById('streamKeyVal');
const obsKeyHint   = document.getElementById('obsKeyHint');
const toggleKey    = document.getElementById('toggleKey');
const copyKey      = document.getElementById('copyKey');
const copyServer   = document.getElementById('copyServer');
const avatarPreview= document.getElementById('avatarPreview');
const avatarInitial= document.getElementById('avatarInitial');
const avatarBtn    = document.getElementById('avatarBtn');
const avatarFile   = document.getElementById('avatarFile');
const fDisplayName = document.getElementById('fDisplayName');
const fStreamTitle = document.getElementById('fStreamTitle');
const fBio         = document.getElementById('fBio');
const fTwitch      = document.getElementById('fTwitch');
const fInstagram   = document.getElementById('fInstagram');
const fTiktok      = document.getElementById('fTiktok');
const saveBtn      = document.getElementById('saveBtn');
const saveStatus   = document.getElementById('saveStatus');
