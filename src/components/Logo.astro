---
interface Props {
  gid: string;       // gradient ID — must be unique per page
  cls?: string;      // extra CSS classes
}
const { gid, cls = '' } = Astro.props;
---
<svg class={`crl-brand-logo ${cls}`} viewBox="0 0 304 88" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <radialGradient id={gid} cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#00bfff" stop-opacity="0.18"/>
      <stop offset="100%" stop-color="#00bfff" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <text class="crl-brand-word" x="0" y="74" font-family="Bebas Neue, cursive" font-size="82">C</text>
  <circle cx="72" cy="42" r="36" fill={`url(#${gid})`}/>
  <circle class="crl-brand-ring-outer" cx="72" cy="42" r="34" stroke-width="9" fill="none"/>
  <circle cx="72" cy="42" r="20" stroke="#00bfff" stroke-width="6" fill="none"/>
  <circle cx="72" cy="42" r="8" fill="#00bfff"/>
  <circle cx="72" cy="42" r="3.5" fill="#00ff9d"/>
  <text class="crl-brand-word" x="114" y="74" font-family="Bebas Neue, cursive" font-size="82">RILLO</text>
</svg>
